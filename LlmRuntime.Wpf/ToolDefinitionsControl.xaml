<UserControl x:Class="LlmRuntime.Wpf.ToolDefinitionsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1280"
             d:DesignHeight="760">
    <Grid Background="#101216">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Margin="0,0,0,8">
                <Button x:Name="NewButton" Width="58" Margin="0,0,6,0" Click="NewButton_Click" Content="New" />
                <Button x:Name="RefreshButton" Width="72" Click="RefreshButton_Click" Content="Refresh" />
                <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" Foreground="#C8D0DC" Text="Tools" />
            </DockPanel>

            <ListBox x:Name="ToolList"
                     Grid.Row="1"
                     SelectionChanged="ToolList_SelectionChanged"
                     Background="#181C22"
                     Foreground="#F2F4F8"
                     BorderBrush="#2D3440">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="2,4">
                            <TextBlock Text="{Binding Name}" Foreground="#F2F4F8" />
                            <TextBlock Text="{Binding Visibility}" Foreground="#8FA0B6" FontSize="11" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Grid.Row="2" Margin="0,8,0,0">
                <TextBlock x:Name="StatusText" Foreground="#C8D0DC" Text="Ready" TextWrapping="Wrap" />
                <TextBlock x:Name="BadgesText" Margin="0,6,0,0" Foreground="#8FD6A4" TextWrapping="Wrap" />
                <TextBlock x:Name="CompatibilityText" Margin="0,4,0,0" Foreground="#93B7FF" TextWrapping="Wrap" />
                <Button x:Name="ExportButton" Margin="0,8,0,0" Click="ExportButton_Click" Content="Export Selected To Clipboard" />
                <Button x:Name="ImportButton" Margin="0,6,0,0" Click="ImportButton_Click" Content="Import From Clipboard" />
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Foreground="#C8D0DC" Text="Id" />
                <TextBox x:Name="IdBox" Grid.Row="0" Grid.Column="1" Margin="0,0,10,8" IsReadOnly="True" />
                <TextBlock Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Foreground="#C8D0DC" Text="Name" />
                <TextBox x:Name="NameBox" Grid.Row="0" Grid.Column="3" Margin="0,0,0,8" />

                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Foreground="#C8D0DC" Text="Visibility" />
                <ComboBox x:Name="VisibilityCombo" Grid.Row="1" Grid.Column="1" Margin="0,0,10,8" />
                <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Foreground="#C8D0DC" Text="Source Type" />
                <ComboBox x:Name="SourceTypeCombo" Grid.Row="1" Grid.Column="3" Margin="0,0,0,8" />

                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Foreground="#C8D0DC" Text="Approval" />
                <ComboBox x:Name="ApprovalCombo" Grid.Row="2" Grid.Column="1" Margin="0,0,10,8" />
                <TextBlock Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" Foreground="#C8D0DC" Text="Timeout" />
                <TextBox x:Name="TimeoutBox" Grid.Row="2" Grid.Column="3" Margin="0,0,0,8" />

                <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Foreground="#C8D0DC" Text="Source" />
                <TextBox x:Name="SourceBox" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" Margin="0,0,0,8" />

                <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Foreground="#C8D0DC" Text="Vendor" />
                <TextBox x:Name="VendorBox" Grid.Row="4" Grid.Column="1" Margin="0,0,10,8" />
                <TextBlock Grid.Row="4" Grid.Column="2" VerticalAlignment="Center" Foreground="#C8D0DC" Text="License" />
                <TextBox x:Name="LicenseBox" Grid.Row="4" Grid.Column="3" Margin="0,0,0,8" />

                <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Foreground="#C8D0DC" Text="Tags" />
                <TextBox x:Name="TagsBox" Grid.Row="5" Grid.Column="1" Margin="0,0,10,8" />
                <TextBlock Grid.Row="5" Grid.Column="2" VerticalAlignment="Top" Foreground="#C8D0DC" Text="Allowed Projects" />
                <TextBox x:Name="AllowedProjectsBox" Grid.Row="5" Grid.Column="3" Height="48" Margin="0,0,0,8" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />

                <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Top" Foreground="#C8D0DC" Text="Description" />
                <TextBox x:Name="DescriptionBox" Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="3" Height="62" Margin="0,0,0,8" AcceptsReturn="True" TextWrapping="Wrap" />

                <TextBlock Grid.Row="7" Grid.Column="0" VerticalAlignment="Top" Foreground="#C8D0DC" Text="Permissions" />
                <WrapPanel Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="3" Margin="0,0,0,8">
                    <CheckBox x:Name="FsReadCheck" Margin="0,0,12,4" Foreground="#F2F4F8" Content="FS Read" />
                    <CheckBox x:Name="FsWriteCheck" Margin="0,0,12,4" Foreground="#F2F4F8" Content="FS Write" />
                    <CheckBox x:Name="ShellCheck" Margin="0,0,12,4" Foreground="#F2F4F8" Content="Shell" />
                    <CheckBox x:Name="NetworkCheck" Margin="0,0,12,4" Foreground="#F2F4F8" Content="Network" />
                    <CheckBox x:Name="BrowserCheck" Margin="0,0,12,4" Foreground="#F2F4F8" Content="Browser" />
                    <CheckBox x:Name="RepoCheck" Margin="0,0,12,4" Foreground="#F2F4F8" Content="Repo" />
                    <CheckBox x:Name="SecretsCheck" Margin="0,0,12,4" Foreground="#F2F4F8" Content="Secrets" />
                </WrapPanel>

                <TextBlock Grid.Row="8" Grid.Column="0" VerticalAlignment="Top" Foreground="#C8D0DC" Text="Secrets" />
                <TextBox x:Name="SecretsBox" Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="3" Height="52" Margin="0,0,0,8" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />

                <TextBlock Grid.Row="9" Grid.Column="0" VerticalAlignment="Top" Foreground="#C8D0DC" Text="Secret Values" />
                <Grid Grid.Row="9" Grid.Column="1" Grid.ColumnSpan="3" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="120" />
                    </Grid.ColumnDefinitions>
                    <PasswordBox x:Name="SecretValuesBox" Height="28" />
                    <Button x:Name="SaveSecretsButton" Grid.Column="1" Margin="8,0,0,0" Click="SaveSecretsButton_Click" Content="Save Secrets" />
                </Grid>

                <Grid Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="4" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,6,0">
                        <TextBlock Foreground="#C8D0DC" Text="HTTP Headers" />
                        <TextBox x:Name="HeadersBox" Height="70" Margin="0,4,0,0" AcceptsReturn="True" FontFamily="Consolas" FontSize="12" VerticalScrollBarVisibility="Auto" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="6,0,0,0">
                        <TextBlock Foreground="#C8D0DC" Text="Environment Variables" />
                        <TextBox x:Name="EnvironmentBox" Height="70" Margin="0,4,0,0" AcceptsReturn="True" FontFamily="Consolas" FontSize="12" VerticalScrollBarVisibility="Auto" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="11" Grid.Column="0" Grid.ColumnSpan="4" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,6,0">
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Foreground="#C8D0DC" Text="Input Schema" />
                            <Button x:Name="SchemaFromExampleButton" DockPanel.Dock="Right" Width="170" Click="SchemaFromExampleButton_Click" Content="Schema From Test Input" />
                        </DockPanel>
                        <TextBox x:Name="InputSchemaBox" Height="150" AcceptsReturn="True" FontFamily="Consolas" FontSize="12" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="6,0,0,0">
                        <TextBlock Margin="0,0,0,4" Foreground="#C8D0DC" Text="Result Schema" />
                        <TextBox x:Name="ResultSchemaBox" Height="150" AcceptsReturn="True" FontFamily="Consolas" FontSize="12" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="12" Grid.Column="0" Grid.ColumnSpan="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <DockPanel Margin="0,0,0,8">
                        <Button x:Name="SaveButton" Width="80" Margin="0,0,8,0" Click="SaveButton_Click" Content="Save" />
                        <Button x:Name="DeleteButton" Width="80" Margin="0,0,8,0" Click="DeleteButton_Click" Content="Delete" />
                        <Button x:Name="TestButton" Width="112" Margin="0,0,8,0" Click="TestButton_Click" Content="Test Tool" />
                        <CheckBox x:Name="ApprovedCheck" VerticalAlignment="Center" Foreground="#F2F4F8" Content="Approved" />
                    </DockPanel>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,6,0">
                            <TextBlock Foreground="#C8D0DC" Text="Test Input" />
                            <TextBox x:Name="TestInputBox" Height="120" Margin="0,4,0,0" AcceptsReturn="True" FontFamily="Consolas" FontSize="12" Text="{}{&quot;query&quot;:&quot;hello&quot;}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="6,0,0,0">
                            <TextBlock Foreground="#C8D0DC" Text="Test Output" />
                            <TextBox x:Name="TestOutputBox" Height="120" Margin="0,4,0,0" AcceptsReturn="True" FontFamily="Consolas" FontSize="12" IsReadOnly="True" VerticalScrollBarVisibility="Auto" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
