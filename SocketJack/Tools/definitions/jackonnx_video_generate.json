      "prompt": {
        "type": "string"
      },
      "modelId": {
        "type": "string"
      },
      "width": {
        "type": "integer"
      },
      "height": {
        "type": "integer"
      },
      "seconds": {
        "type": "number",
        "minimum": 0.1,
        "maximum": 30,
        "description": "Desired clip duration. If seconds multiplied by fps exceeds 96 output frames, JackONNX caps frames and shortens the effective duration."
      },
      "fps": {
        "type": "integer",
