        "maximum": 24,
        "description": "Playback frames per second. Higher FPS consumes the 96-frame output budget faster."
      },
      "frames": {
        "type": "integer",
        "minimum": 1,
        "maximum": 96,
        "description": "Total output frame budget. Current local video generation is capped at 96 frames."
      },
      "seed": {
        "type": "integer"
      }
