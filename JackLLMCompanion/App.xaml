<Application x:Class="JackLLMCompanion.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Startup="OnStartup"
             Exit="OnExit"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#A80A0F16"/>
        <SolidColorBrush x:Key="TitleBarBrush" Color="#66111924"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#D91A2230"/>
        <SolidColorBrush x:Key="PanelAltBrush" Color="#66111924"/>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#334E5E74"/>
        <SolidColorBrush x:Key="TextBrush" Color="#F1F7FF"/>
        <SolidColorBrush x:Key="SubtleTextBrush" Color="#9FB1C8"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#59D6C9"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#FFB35A"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#FF5C7A"/>
        <SolidColorBrush x:Key="ControlBrush" Color="#AA263448"/>
        <SolidColorBrush x:Key="ControlHoverBrush" Color="#CC324761"/>
        <SolidColorBrush x:Key="ControlPressedBrush" Color="#DD38536E"/>
        <SolidColorBrush x:Key="ControlBorderBrush" Color="#554E6A8B"/>
        <SolidColorBrush x:Key="AeroTabInactiveBorderBrush" Color="#334E5E74"/>
        <SolidColorBrush x:Key="AeroTabHoverBorderBrush" Color="#667DD3FC"/>
        <SolidColorBrush x:Key="AeroTabSelectedBorderBrush" Color="#C659D6C9"/>

        <LinearGradientBrush x:Key="AeroTabInactiveBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#AA101723" Offset="0"/>
            <GradientStop Color="#AA172232" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="AeroTabHoverBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#CC172A3C" Offset="0"/>
            <GradientStop Color="#CC203A50" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="AeroTabSelectedBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#F2264F63" Offset="0"/>
            <GradientStop Color="#F21A8A82" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="CompanionWindowBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0A080B10" Offset="0"/>
            <GradientStop Color="#0A111827" Offset="0.48"/>
            <GradientStop Color="#0A072021" Offset="1"/>
        </LinearGradientBrush>

        <Style TargetType="{x:Type Window}">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="350"/>
            <Setter Property="ToolTipService.ShowDuration" Value="12000"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <Style TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="#F4FBFF"/>
            <Setter Property="Background" Value="{StaticResource ControlBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{StaticResource ControlHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{StaticResource ControlPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Foreground" Value="#F4FBFF"/>
            <Setter Property="Background" Value="#99111924"/>
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Margin" Value="0,2,0,10"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="SelectionBrush" Value="#456E8A"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border x:Name="InputChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#554E6A8B"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect x:Name="InputGlow"
                                                  Color="#59D6C9"
                                                  BlurRadius="18"
                                                  ShadowDepth="0"
                                                  Opacity="0"/>
                            </Border.Effect>
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="InputChrome" Property="Background" Value="#B3182636"/>
                                <Setter TargetName="InputChrome" Property="BorderBrush" Value="#777DD3FC"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="InputChrome" Property="Background" Value="#BB13242E"/>
                                <Setter TargetName="InputChrome" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="InputGlow"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.72"
                                                             Duration="0:0:0.18"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="InputGlow"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="0:0:0.28"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type CheckBox}">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="#88263448"/>
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,3,16,9"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type CheckBox}">
                        <Grid SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="BoxChrome"
                                    Width="18"
                                    Height="18"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5"
                                    VerticalAlignment="Center">
                                <Grid>
                                    <Border x:Name="AccentFill"
                                            Background="{StaticResource AccentBrush}"
                                            CornerRadius="4"
                                            Opacity="0"/>
                                    <Path x:Name="CheckGlyph"
                                          Data="M 4.2 9.2 L 7.2 12.2 L 13.9 5.4"
                                          Stroke="#061316"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Opacity="0"/>
                                    <Path x:Name="IndeterminateGlyph"
                                          Data="M 5 9 H 13"
                                          Stroke="#061316"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Opacity="0"/>
                                </Grid>
                            </Border>
                            <ContentPresenter Grid.Column="1"
                                              Margin="8,0,0,0"
                                              RecognizesAccessKey="True"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BoxChrome" Property="Background" Value="{StaticResource ControlHoverBrush}"/>
                                <Setter TargetName="BoxChrome" Property="BorderBrush" Value="#806E8CA8"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="BoxChrome" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="AccentFill" Property="Opacity" Value="1"/>
                                <Setter TargetName="CheckGlyph" Property="Opacity" Value="1"/>
                                <Setter TargetName="BoxChrome" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="{x:Null}">
                                <Setter TargetName="AccentFill" Property="Opacity" Value="1"/>
                                <Setter TargetName="IndeterminateGlyph" Property="Opacity" Value="1"/>
                                <Setter TargetName="BoxChrome" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BoxChrome" Property="Background" Value="{StaticResource ControlPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlassScrollBarPageButtonStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlassScrollBarThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="ThumbChrome"
                                Background="#6659D6C9"
                                CornerRadius="4"
                                Margin="2"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbChrome" Property="Background" Value="#AA59D6C9"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbChrome" Property="Background" Value="#E659D6C9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Opacity" Value="0.72"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="OverridesDefaultStyle" Value="True"/>
                    <Setter Property="Width" Value="10"/>
                    <Setter Property="MinWidth" Value="10"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type ScrollBar}">
                                <Grid Background="Transparent">
                                    <Track x:Name="PART_Track" IsDirectionReversed="True" Focusable="False">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource GlassScrollBarPageButtonStyle}" Command="ScrollBar.PageUpCommand"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource GlassScrollBarThumbStyle}"/>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource GlassScrollBarPageButtonStyle}" Command="ScrollBar.PageDownCommand"/>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="OverridesDefaultStyle" Value="True"/>
                    <Setter Property="Height" Value="10"/>
                    <Setter Property="MinHeight" Value="10"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type ScrollBar}">
                                <Grid Background="Transparent">
                                    <Track x:Name="PART_Track" IsDirectionReversed="False" Focusable="False">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource GlassScrollBarPageButtonStyle}" Command="ScrollBar.PageLeftCommand"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource GlassScrollBarThumbStyle}"/>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource GlassScrollBarPageButtonStyle}" Command="ScrollBar.PageRightCommand"/>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type TabControl}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabControl}">
                        <Grid KeyboardNavigation.TabNavigation="Local"
                              Background="{TemplateBinding Background}"
                              ClipToBounds="False"
                              SnapsToDevicePixels="True">
                            <Grid.RowDefinitions>
                                <RowDefinition x:Name="HeaderRow" Height="Auto"/>
                                <RowDefinition x:Name="ContentRow" Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="ContentColumn" Width="*"/>
                                <ColumnDefinition x:Name="HeaderColumn" Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <ContentPresenter x:Name="PART_SelectedContentHost"
                                              Grid.Row="1"
                                              Grid.Column="0"
                                              Grid.ColumnSpan="2"
                                              ContentSource="SelectedContent"
                                              KeyboardNavigation.TabIndex="2"
                                              KeyboardNavigation.TabNavigation="Local"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>

                            <Border x:Name="HeaderShell"
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="2"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="12,10,12,6"
                                    ClipToBounds="False"
                                    Panel.ZIndex="1">
                                <TabPanel x:Name="HeaderPanel"
                                          IsItemsHost="True"
                                          Background="Transparent"
                                          ClipToBounds="False"
                                          KeyboardNavigation.TabIndex="1"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type TabItem}">
            <Setter Property="Foreground" Value="#C9D7E6"/>
            <Setter Property="Background" Value="{StaticResource AeroTabInactiveBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AeroTabInactiveBorderBrush}"/>
            <Setter Property="Padding" Value="15,7"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="ClipToBounds" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Grid Margin="0,2,0,2"
                              ClipToBounds="False"
                              SnapsToDevicePixels="True">
                            <Border x:Name="SelectedGlow"
                                    Background="#4459D6C9"
                                    CornerRadius="8"
                                    Opacity="0">
                                <Border.Effect>
                                    <DropShadowEffect Color="#59D6C9"
                                                      BlurRadius="16"
                                                      ShadowDepth="0"
                                                      Opacity="0.58"/>
                                </Border.Effect>
                            </Border>
                            <Border x:Name="TabChrome"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="7"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter x:Name="HeaderContent"
                                                  ContentSource="Header"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"
                                                  TextElement.Foreground="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}"
                                                  TextElement.FontWeight="{Binding FontWeight, RelativeSource={RelativeSource TemplatedParent}}"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AeroTabHoverBrush}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource AeroTabHoverBorderBrush}"/>
                                <Setter Property="Foreground" Value="#F4FBFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Panel.ZIndex" Value="2"/>
                                <Setter Property="Background" Value="{StaticResource AeroTabSelectedBrush}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource AeroTabSelectedBorderBrush}"/>
                                <Setter Property="Foreground" Value="#FFFFFFFF"/>
                                <Setter TargetName="SelectedGlow" Property="Opacity" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
