<Window x:Class="SocketJack.Update.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SocketJack Update"
        Width="1420"
        Height="620"
        MinWidth="1220"
        MinHeight="520"
        Background="#090d0b"
        Foreground="#c9ffd4"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="SocketJack Update" FontSize="30" FontWeight="Bold" Foreground="#49ff78" />
                <TextBlock Text="{Binding EndpointText}" Foreground="#7fdc95" Margin="1,4,0,0" />
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Start" Width="88" Margin="8,0,0,0" Click="StartButton_Click" />
                <Button Content="Stop" Width="88" Margin="8,0,0,0" Click="StopButton_Click" />
                <Button Content="Refresh" Width="88" Margin="8,0,0,0" Click="RefreshButton_Click" />
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1" BorderBrush="#1f6f33" BorderThickness="1" Background="#0f1712" Padding="12" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="110" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding Status}" FontSize="16" FontWeight="SemiBold" Foreground="#49ff78" />
                    <TextBlock Text="{Binding AuthStatus}" Foreground="#a8efb6" Margin="0,4,0,0" />
                </StackPanel>
                <TextBox x:Name="AdminUserTextBox" Grid.Column="1" Margin="10,0,0,0" VerticalContentAlignment="Center" ToolTip="Admin username" />
                <PasswordBox x:Name="AdminPasswordBox" Grid.Column="2" Margin="10,0,0,0" VerticalContentAlignment="Center" ToolTip="Admin password" />
                <Button Grid.Column="3" Content="Set Login" Margin="10,0,0,0" Click="SetLoginButton_Click" />
            </Grid>
        </Border>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Channels}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  Background="#0f1712"
                  Foreground="#d8ffe0"
                  RowBackground="#101b14"
                  AlternatingRowBackground="#0c140f"
                  BorderBrush="#1f6f33">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Channel" Binding="{Binding Id}" Width="170" />
                <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="220" />
                <DataGridTemplateColumn Width="92">
                    <DataGridTemplateColumn.Header>
                        <CheckBox x:Name="AllAutoStartCheckBox"
                                  Content="Auto"
                                  IsThreeState="True"
                                  Foreground="#d8ffe0"
                                  Click="HeaderAutoStartCheckBox_Click" />
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding AutoStartAfterUpdate, Mode=OneWay}"
                                      IsEnabled="{Binding IsProcessManaged}"
                                      HorizontalAlignment="Center"
                                      Click="ChannelAutoStartCheckBox_Click" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Status" Binding="{Binding ProcessStatus}" Width="150" />
                <DataGridTextColumn Header="Last Update" Binding="{Binding LastUpdateText}" Width="175" />
                <DataGridTextColumn Header="Files" Binding="{Binding FileCount}" Width="80" />
                <DataGridTextColumn Header="Bytes" Binding="{Binding SizeText}" Width="120" />
                <DataGridTemplateColumn Header="Process" Width="300">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="Start" Width="58" Margin="4,0,0,0" Click="ChannelStartButton_Click" IsEnabled="{Binding CanStartProcess}" />
                                <Button Content="Stop" Width="58" Margin="4,0,0,0" Click="ChannelStopButton_Click" IsEnabled="{Binding CanStopProcess}" />
                                <Button Content="Restart" Width="70" Margin="4,0,0,0" Click="ChannelRestartButton_Click" IsEnabled="{Binding CanRestartProcess}" />
                                <Button Content="{Binding StartupButtonText}" Width="88" Margin="4,0,0,0" Click="ChannelStartupButton_Click" IsEnabled="{Binding IsProcessManaged}" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Actions" Width="92">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Remove"
                                    Width="74"
                                    HorizontalAlignment="Center"
                                    Click="ChannelRemoveButton_Click"
                                    IsEnabled="{Binding CanRemove}"
                                    ToolTip="Remove this added update item" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Update Directory" Binding="{Binding UpdateDirectory}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="3"
                   Text="{Binding FooterText}"
                   Foreground="#75d889"
                   Margin="0,12,0,0"
                   TextWrapping="Wrap" />
    </Grid>
</Window>
