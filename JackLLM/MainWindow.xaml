                                            <Grid Margin="0,8,0,0">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>
                                                <DockPanel>
                                                    <Button x:Name="ServerRefreshSessionsButton"
                                                            Content="Refresh"
                                                            DockPanel.Dock="Right"
                                                            Click="RefreshSessionsButton_Click"
                                                            Padding="8,3"/>
                                                    <TextBlock Text="Sessions"
                                                               FontSize="16"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center"/>
                                                </DockPanel>
                                                <Expander x:Name="ServerSessionsRequestsExpander"
                                                           Grid.Row="1"
                                                          Header="Requests"
                                                          IsExpanded="False"
                                                          Foreground="{StaticResource TextBrush}"
                                                          Margin="0,7,0,7">
                                                    <Grid Margin="0,7,0,0">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <DockPanel>
                                                            <Button Content="Refresh"
                                                                    DockPanel.Dock="Right"
                                                                    Click="RefreshRequestsButton_Click"
                                                                    Padding="8,3"/>
                                                            <TextBlock Text="Registration and token-rate requests"
                                                                       FontWeight="SemiBold"
                                                                       VerticalAlignment="Center"/>
                                                        </DockPanel>
                                                        <ListBox x:Name="SessionsRequestsListBox"
                                                                 Grid.Row="1"
                                                                 MaxHeight="190"
                                                                 Background="#66070A10"
                                                                 BorderBrush="{StaticResource PanelBorderBrush}"
                                                                 BorderThickness="1"
                                                                 Foreground="{StaticResource TextBrush}"
                                                                 HorizontalContentAlignment="Stretch"
                                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                                 Margin="0,7,0,0">
                                                            <ListBox.ItemContainerStyle>
                                                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                                                    <Setter Property="Padding" Value="0"/>
                                                                    <Setter Property="Margin" Value="0,0,0,6"/>
                                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                                </Style>
                                                            </ListBox.ItemContainerStyle>
                                                            <ListBox.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Background="#99111924"
                                                                            BorderBrush="#334E5E74"
                                                                            BorderThickness="1"
                                                                            CornerRadius="7"
                                                                            Padding="8">
                                                                        <Grid>
                                                                            <Grid.RowDefinitions>
                                                                                <RowDefinition Height="Auto"/>
                                                                                <RowDefinition Height="Auto"/>
                                                                                <RowDefinition Height="Auto"/>
                                                                            </Grid.RowDefinitions>
                                                                            <TextBlock Text="{Binding Title}"
                                                                                       FontWeight="SemiBold"
                                                                                       TextWrapping="Wrap"/>
                                                                            <TextBlock Grid.Row="1"
                                                                                       Text="{Binding Detail}"
                                                                                       Foreground="{StaticResource SubtleTextBrush}"
                                                                                       TextWrapping="Wrap"
                                                                                       Margin="0,4,0,0"/>
                                                                            <WrapPanel Grid.Row="2" Margin="0,8,0,0">
                                                                                <Button Content="Approve"
                                                                                        Tag="{Binding}"
                                                                                        Click="ApproveServerManagementRequestButton_Click"
                                                                                        Padding="8,3"
                                                                                        Background="#1F7A68"
                                                                                        Margin="0,0,7,0"/>
                                                                                <Button Content="Deny"
                                                                                        Tag="{Binding}"
                                                                                        Click="DenyServerManagementRequestButton_Click"
                                                                                        Padding="8,3"
                                                                                        Background="#893442"/>
                                                                            </WrapPanel>
                                                                        </Grid>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ListBox.ItemTemplate>
                                                        </ListBox>
                                                    </Grid>
                                                </Expander>
                                                <TextBlock x:Name="ServerSessionsSummaryText"
                                                           Grid.Row="2"
                                                           Text="No sessions loaded"
                                                           Foreground="{StaticResource SubtleTextBrush}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,7,0,7"/>
                                                <ListBox x:Name="ServerSessionsListBox"
                                                         Grid.Row="3"
                                                         Background="#66070A10"
                                                         BorderBrush="{StaticResource PanelBorderBrush}"
                                                         BorderThickness="1"
                                                         Foreground="{StaticResource TextBrush}"
                                                         HorizontalContentAlignment="Stretch"
                                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                         ScrollViewer.CanContentScroll="True"
                                                         VirtualizingPanel.IsVirtualizing="True"
                                                         VirtualizingPanel.VirtualizationMode="Recycling"
                                                         VirtualizingPanel.ScrollUnit="Pixel"
                                                         SelectionChanged="ServerSessionsListBox_SelectionChanged">
                                                    <ListBox.ItemContainerStyle>
                                                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                                            <Setter Property="Padding" Value="0"/>
                                                            <Setter Property="Margin" Value="0,0,0,7"/>
                                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                        </Style>
                                                    </ListBox.ItemContainerStyle>
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#99111924"
                                                                    BorderBrush="#334E5E74"
                                                                    BorderThickness="1"
                                                                    CornerRadius="7"
                                                                    Padding="8">
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding Title}"
                                                                               FontWeight="SemiBold"
                                                                               TextWrapping="Wrap"/>
                                                                    <TextBlock Text="{Binding OwnerLine}"
                                                                               Foreground="{StaticResource SubtleTextBrush}"
                                                                               TextWrapping="Wrap"
                                                                               Margin="0,4,0,0"/>
                                                                    <TextBlock Text="{Binding DetailLine}"
                                                                               Foreground="{StaticResource SubtleTextBrush}"
                                                                               TextWrapping="Wrap"
                                                                               Margin="0,2,0,0"/>
                                                                    <ProgressBar Height="5"
                                                                                 Minimum="0"
                                                                                 Maximum="100"
                                                                                 Value="{Binding PromptTokenPercent}"
                                                                                 Margin="0,7,0,0"/>
                                                                    <TextBlock Text="{Binding PromptTokenLine}"
                                                                               Foreground="{StaticResource SubtleTextBrush}"
                                                                               FontSize="11"
                                                                               TextWrapping="Wrap"
                                                                               Margin="0,3,0,0"/>
                                                                    <TextBlock Text="{Binding UpdatedLine}"
                                                                               Foreground="{StaticResource SubtleTextBrush}"
                                                                               TextWrapping="Wrap"
                                                                               Margin="0,2,0,0"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </Grid>
                                        </TabItem>

                                        <TabItem Header="Explorer">
                                            <Grid Margin="0,8,0,0">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>
                                                <DockPanel>
                                                    <Button x:Name="ServerRefreshExplorerButton"
                                                            Content="Refresh"
                                                            DockPanel.Dock="Right"
                                                            Click="RefreshExplorerButton_Click"
                                                            Padding="8,3"/>
                                                    <Button x:Name="ServerBrowseAccessibleDirectoryButton"
                                                            Content="Add Dir"
                                                            DockPanel.Dock="Right"
                                                            Click="BrowseAccessibleDirectoryButton_Click"
                                                            Padding="8,3"
                                                            Margin="0,0,6,0"/>
                                                    <TextBlock Text="Solution Explorer"
                                                               FontSize="16"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center"/>
                                                </DockPanel>
                                                <StackPanel Grid.Row="1" Margin="0,7,0,7">
                                                    <TextBlock x:Name="ServerFilesystemOwnerText"
                                                               Text="Owner: global"
                                                               Foreground="{StaticResource SubtleTextBrush}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock x:Name="ServerFilesystemAccessStatusText"
                                                               Text="Select a session to view that user's accessible directories."
                                                               Foreground="{StaticResource SubtleTextBrush}"
                                                               TextWrapping="Wrap"
                                                               Margin="0,2,0,0"/>
                                                    <TextBlock x:Name="ServerWorkspaceSummaryText"
                                                               Text="No workspace loaded"
                                                               Foreground="{StaticResource SubtleTextBrush}"
                                                               TextWrapping="Wrap"
                                                               Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <TreeView x:Name="ServerWorkspaceTreeView"
                                                          Grid.Row="2"
                                                          Background="#66070A10"
                                                          BorderBrush="{StaticResource PanelBorderBrush}"
                                                          BorderThickness="1"
                                                          Foreground="{StaticResource TextBrush}"
                                                          SelectedItemChanged="WorkspaceTreeView_SelectedItemChanged"
                                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                                                    <TreeView.ItemContainerStyle>
                                                        <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                                                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                                            <Setter Property="Padding" Value="0"/>
                                                        </Style>
                                                    </TreeView.ItemContainerStyle>
                                                    <TreeView.ItemTemplate>
                                                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                                            <Border Background="#99111924"
                                                                    BorderBrush="#334E5E74"
                                                                    BorderThickness="1"
                                                                    CornerRadius="6"
                                                                    Padding="7"
                                                                    Margin="0,1,0,4">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Text="{Binding Icon}"
                                                                               FontFamily="Consolas"
                                                                               Foreground="{Binding AccentBrush}"
                                                                               Margin="0,1,7,0"/>
                                                                    <StackPanel Grid.Column="1">
                                                                        <TextBlock Text="{Binding DisplayName}"
                                                                                   FontWeight="{Binding FontWeight}"
                                                                                   TextTrimming="CharacterEllipsis"/>
                                                                        <TextBlock Text="{Binding Detail}"
                                                                                   Foreground="{StaticResource SubtleTextBrush}"
                                                                                   FontSize="11"
                                                                                   TextTrimming="CharacterEllipsis"
                                                                                   Margin="0,2,0,0"/>
                                                                    </StackPanel>
                                                                    <StackPanel Grid.Column="2"
                                                                                Orientation="Horizontal"
                                                                                VerticalAlignment="Top"
                                                                                Margin="8,0,0,0">
                                                                        <Button Content="ZIP"
                                                                                Tag="{Binding}"
                                                                                Click="DownloadWorkspaceTreeDirectoryZipButton_Click"
                                                                                Padding="7,2"
                                                                                MinWidth="36"
                                                                                Height="24"
                                                                                Margin="0,0,6,0"
                                                                                FontSize="11"
                                                                                Visibility="{Binding ZipVisibility}"/>
                                                                        <Button Content="X"
                                                                                Tag="{Binding}"
                                                                                Click="RemoveWorkspaceTreeDirectoryButton_Click"
                                                                                Padding="7,2"
                                                                                MinWidth="26"
                                                                                Height="24"
                                                                                Visibility="{Binding RemoveVisibility}"/>
                                                                    </StackPanel>
                                                                </Grid>
                                                            </Border>
                                                        </HierarchicalDataTemplate>
                                                    </TreeView.ItemTemplate>
                                                </TreeView>
                                            </Grid>
                                        </TabItem>
                                    </TabControl>

                                    <Grid Grid.Column="1">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <DockPanel Margin="0,0,0,8">
                                            <Button x:Name="RefreshSessionLogButton"
                                                    Content="Refresh"
                                                    DockPanel.Dock="Right"
                                                    Click="RefreshSessionLogButton_Click"
                                                    Padding="8,3"/>
                                            <StackPanel>
                                                <TextBlock x:Name="ServerSessionLogTitleText"
                                                           Text="Session log"
                                                           FontSize="16"
                                                           FontWeight="SemiBold"/>
                                                <TextBlock x:Name="ServerSessionLogMetaText"
                                                           Text="Select a session to render its chat log."
                                                           Foreground="{StaticResource SubtleTextBrush}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </DockPanel>
                                        <Border Grid.Row="1"
                                                Background="#EE0B111C"
                                                BorderBrush="{StaticResource PanelBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="7"
                                                Padding="1">
                                            <ContentControl x:Name="SessionLogBrowserHost"/>
                                        </Border>
                                        <TextBlock x:Name="SessionLogStatusText"
                                                   Grid.Row="2"
                                                   Text="Session log viewer ready."
                                                   Foreground="{StaticResource SubtleTextBrush}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,8,0,0"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </TabItem>
            </TabControl>

            <Canvas x:Name="CoachmarkCanvas"
                    Grid.RowSpan="2"
                    Panel.ZIndex="40"
                    IsHitTestVisible="False"
                    Visibility="Collapsed">
                <Path x:Name="CoachmarkArrow"
                      Width="34"
                      Height="24"
                      Fill="{StaticResource AccentBrush}"
                      Stretch="Fill"
                      Data="M 0 0 L 34 12 L 0 24 Z">
                    <Path.RenderTransform>
                        <TranslateTransform x:Name="CoachmarkArrowTransform"/>
                    </Path.RenderTransform>
                    <Path.Effect>
                        <DropShadowEffect Color="#FF5C7A"
                                          BlurRadius="16"
                                          ShadowDepth="0"
                                          Opacity="0.85"/>
                    </Path.Effect>
                </Path>
                <Border x:Name="CoachmarkBubble"
                        Width="280"
                        Background="#F1111827"
                        BorderBrush="{StaticResource AccentBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                    <StackPanel>
                        <TextBlock x:Name="CoachmarkTitleText"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Foreground="{StaticResource TextBrush}"
                                   TextWrapping="Wrap"/>
                        <TextBlock x:Name="CoachmarkBodyText"
                                   Foreground="{StaticResource SubtleTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </Canvas>

            <Grid x:Name="WelcomeSplashOverlay"
                  Grid.RowSpan="2"
                  Panel.ZIndex="50"
                  Background="#D9080B10"
                  Visibility="Collapsed">
                <Border MaxWidth="760"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="#F1111827"
                        BorderBrush="{StaticResource AccentBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="26"
                        Margin="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel>
                            <TextBlock Text="Welcome to JackLLM Workstation"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"/>
                            <TextBlock Text="JackLLM Workstation is the WPF control room for local model hosting: start the local proxy, chat with local or remote LM services, publish this PC to SocketJack.com, watch runtime health, manage sessions, and review file or terminal permissions from one place."
                                       Foreground="{StaticResource SubtleTextBrush}"
                                       TextWrapping="Wrap"
                                       FontSize="14"
                                       Margin="0,10,0,0"/>
                        </StackPanel>

                        <UniformGrid Grid.Row="1"
                                     Columns="2"
                                     Margin="0,20,0,0">
                            <Border Background="#55101723"
                                    BorderBrush="#334E5E74"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12"
                                    Margin="0,0,8,8">
                                <StackPanel>
                                    <TextBlock Text="Default hotkeys"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="Enter sends chat. Shift+Enter adds a new line. Esc hides this welcome panel. F5 refreshes the selected live view. Ctrl+L focuses the SocketJack login name."
                                               Foreground="{StaticResource SubtleTextBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#55101723"
                                    BorderBrush="#334E5E74"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12"
                                    Margin="8,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="Worth noticing"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="SocketJack.com sign-in owns uploads, account storage, public listings, and paid token usage. Session files count against the user's storage cap."
                                               Foreground="{StaticResource SubtleTextBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#55101723"
                                    BorderBrush="#334E5E74"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12"
                                    Margin="0,8,8,0">
                                <StackPanel>
                                    <TextBlock Text="Models tab"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="If no local models are found yet, open the Models tab. You can download more models there, then enable or load the one you want for chat."
                                               Foreground="{StaticResource SubtleTextBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#55101723"
                                    BorderBrush="#334E5E74"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12"
                                    Margin="8,8,0,0">
                                <StackPanel>
                                    <TextBlock Text="Safety hints"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="File, terminal, FTP, and VS tool access are permissioned per user. Watch the pending approval panels before granting broad access."
                                               Foreground="{StaticResource SubtleTextBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <WrapPanel Grid.Row="2"
                                   HorizontalAlignment="Right"
                                   Margin="0,24,0,0">
                            <Button x:Name="WelcomeSplashCloseButton"
                                    Content="Start"
                                    Click="WelcomeSplashCloseButton_Click"
                                    Padding="18,7"
                                    MinWidth="92"
                                    Background="#1F7A68"
                                    Margin="0,0,8,0"/>
                            <Button x:Name="WelcomeSplashSkipButton"
                                    Content="Hide tips"
                                    Click="WelcomeSplashSkipButton_Click"
                                    Padding="18,7"
                                    MinWidth="92"/>
                        </WrapPanel>
                    </Grid>
                </Border>
            </Grid>

            <Canvas x:Name="RemoteCursorOverlay"
                    Grid.RowSpan="2"
                    Panel.ZIndex="1000"
                    IsHitTestVisible="False"
                    ClipToBounds="False"/>
        </Grid>
    </Border>
</Window>
