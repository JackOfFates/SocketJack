<Window x:Class="JackLLM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:llmwpf="clr-namespace:LlmRuntime.Wpf;assembly=LlmRuntime.Wpf"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="JackLLM Workstation"
        Width="1280"
        Height="1100"
        MinWidth="700"
        MinHeight="540"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="CanResize"
        StateChanged="Window_StateChanged"
        SourceInitialized="Window_SourceInitialized"
        Loaded="Window_Loaded"
        SizeChanged="Window_SizeChanged"
        Closing="Window_Closing">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44"
                            ResizeBorderThickness="7"
                            GlassFrameThickness="0"
                            CornerRadius="6"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border x:Name="WindowFrame"
            BorderBrush="{StaticResource PanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="6"
            SnapsToDevicePixels="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#A8080B10" Offset="0"/>
                <GradientStop Color="#A8111827" Offset="0.45"/>
                <GradientStop Color="#A8072021" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="14,0,6,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Width="11"
                            Height="11"
                            CornerRadius="6"
                            Background="{StaticResource AccentBrush}"
                            VerticalAlignment="Center"
                            Margin="0,0,10,0"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button x:Name="MinimizeButton"
                                Style="{StaticResource WindowChromeButtonStyle}"
                                Click="MinimizeButton_Click"
                                ToolTip="Minimize">
                            <Path Data="M 4 9 H 12"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.7"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"/>
                        </Button>
                        <Button x:Name="MaximizeRestoreButton"
                                Style="{StaticResource WindowChromeButtonStyle}"
                                Click="MaximizeRestoreButton_Click"
                                ToolTip="Maximize">
                            <Grid Width="16" Height="16">
                                <Path x:Name="MaximizeGlyph"
                                      Data="M 4 4 H 12 V 12 H 4 Z"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1.35"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"/>
                                <Path x:Name="RestoreGlyph"
                                      Data="M 6 3 H 13 V 10 M 3 6 H 10 V 13 H 3 Z"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1.35"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Visibility="Collapsed"/>
                            </Grid>
                        </Button>
                        <Button x:Name="CloseButton"
                                Style="{StaticResource WindowChromeCloseButtonStyle}"
                                Click="CloseButton_Click"
                                ToolTip="Close">
                            <Path Data="M 4 4 L 12 12 M 12 4 L 4 12"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.6"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <TabControl x:Name="MainTabs"
                        Grid.Row="1"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="{StaticResource TextBrush}"
                        SelectionChanged="MainTabs_SelectionChanged">
                <TabItem Header="Diagnostics">
                <Grid x:Name="MainDiagnosticsViewport"
                      Margin="14,12,14,14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="JackLLM Workstation Diagnostics" FontSize="24" FontWeight="SemiBold"/>
                            <TextBlock Text="LM Studio &lt;-&gt; App &lt;-&gt; VS Copilot metrics and debug console"
                               Foreground="{StaticResource SubtleTextBrush}"
                               FontSize="13"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"/>
                            <StackPanel x:Name="CompanionUpdateStatusPanel"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Margin="0,7,0,0"
                                        Visibility="Collapsed">
                                <ProgressBar x:Name="CompanionUpdateProgressBar"
                                             Width="58"
                                             Height="5"
                                             IsIndeterminate="True"
                                             Foreground="#9CA3AF"
                                             Background="#22303D"
                                             Margin="0,0,8,0"/>
                                <TextBlock x:Name="CompanionUpdateFileText"
                                           Foreground="#9CA3AF"
                                           Opacity="0.78"
                                           FontFamily="Consolas"
                                           FontSize="11"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <Border x:Name="RemoteCursorRestorePanel"
                                    Background="#172331"
                                    BorderBrush="#38506B"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8,6"
                                    Margin="0,8,0,0"
                                    MaxWidth="620"
                                    HorizontalAlignment="Left"
                                    Visibility="Collapsed">
                                <DockPanel LastChildFill="True">
                                    <CheckBox x:Name="RemoteCursorRestoreToggle"
                                              Content="Show remote cursor again"
                                              DockPanel.Dock="Right"
                                              VerticalAlignment="Center"
                                              Margin="12,0,0,0"
                                              Checked="RemoteCursorRestoreToggle_Checked"/>
                                    <StackPanel>
                                        <TextBlock Text="Remote cursor hidden"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextBrush}"
                                                   FontSize="12"/>
                                        <TextBlock Text="Codex remote-control cursor is hidden in the WPF app."
                                                   Foreground="{StaticResource SubtleTextBrush}"
                                                   FontSize="11"
                                                   TextWrapping="Wrap"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </StackPanel>

                        <WrapPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0" ItemHeight="32">
                            <TextBlock x:Name="UpdateStatusText"
                                       Text="updates: checking"
                                       Foreground="{StaticResource SubtleTextBrush}"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       Visibility="Collapsed"/>
                            <Button x:Name="UpdateNowButton"
                                    Content="update"
                                    Click="UpdateNowButton_Click"
                                    Background="#1F8A4E"
                                    BorderBrush="#6FF2A6"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Padding="10,4"
                                    Margin="0,0,8,0"
                                    Visibility="Collapsed">
                                <Button.Effect>
                                    <DropShadowEffect Color="#6FF2A6"
                                                      BlurRadius="18"
                                                      ShadowDepth="0"
                                                      Opacity="0.85"/>
                                </Button.Effect>
                            </Button>
                            <Button x:Name="ProbeButton" Content="Probe Provider" Click="ProbeButton_Click" Margin="0,0,8,0" Visibility="Collapsed"/>
                            <Button x:Name="OpenChatButton" Content="Open Chat UI" Click="OpenChatButton_Click" Margin="0,0,8,0" IsEnabled="False"/>
                            <Button x:Name="OpenMagicWorkflowButton" Content="Magic Workflow" Click="OpenMagicWorkflowButton_Click" Margin="0,0,8,0" IsEnabled="False" Visibility="Collapsed"/>
                            <Button x:Name="RefreshMagicWorkflowButton" Content="Workflow Status" Click="RefreshMagicWorkflowButton_Click" Margin="0,0,8,0" IsEnabled="False" Visibility="Collapsed"/>
                            <ComboBox x:Name="MagicWorkflowControlComboBox" Width="132" Height="28" Margin="0,0,8,0" SelectedIndex="0" IsEnabled="False" Visibility="Collapsed">
                                <ComboBoxItem Content="status"/>
                                <ComboBoxItem Content="pause"/>
                                <ComboBoxItem Content="resume"/>
                                <ComboBoxItem Content="cancel"/>
                                <ComboBoxItem Content="retry_blocked_step"/>
                                <ComboBoxItem Content="skip"/>
                            </ComboBox>
                            <Button x:Name="ApplyMagicWorkflowControlButton" Content="Apply Workflow" Click="ApplyMagicWorkflowControlButton_Click" Margin="0,0,8,0" IsEnabled="False" Visibility="Collapsed"/>
                            <Button x:Name="StartCompanionButton" Content="Start Companion" Click="StartCompanionButton_Click" Margin="0,0,8,0" Visibility="Collapsed"/>
                            <Button x:Name="OpenCompanionButton" Content="Open Companion" Click="OpenCompanionButton_Click" Margin="0,0,8,0"/>
                            <Button x:Name="StartStopButton" Content="Start Proxy" Click="StartStopButton_Click" Background="#1F7A68"/>
                            <TextBlock x:Name="MagicWorkflowStatusText"
                                       Text="Magic workflow: start proxy"
                                       Foreground="{StaticResource SubtleTextBrush}"
                                       FontFamily="Consolas"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       TextWrapping="Wrap"
                                       MaxWidth="360"
                                       Visibility="Collapsed"/>
                        </WrapPanel>
                    </Grid>

                    <Border Grid.Row="1"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10"
                        Margin="0,0,0,12">
                        <Grid x:Name="SettingsGroupsPanel">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="0.78*"/>
                                <ColumnDefinition Width="1.03*"/>
                                <ColumnDefinition Width="1.18*"/>
                                <ColumnDefinition Width="1.46*"/>
                            </Grid.ColumnDefinitions>
                            <GroupBox Header="Application" Grid.Column="0" Padding="8,10,8,8" Margin="0,0,8,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <CheckBox x:Name="StartByDefaultCheckBox"
                                          Content="Start proxy on open"
                                          IsChecked="True"
                                          Checked="StartByDefaultCheckBox_Changed"
                                          Unchecked="StartByDefaultCheckBox_Changed"/>
                                    <WrapPanel Grid.Row="1" Margin="0,10,0,0">
                                        <CheckBox x:Name="WindowsStartupCheckBox"
                                              Content="Start with Windows"
                                              Checked="WindowsStartupCheckBox_Changed"
                                              Unchecked="WindowsStartupCheckBox_Changed"/>
                                        <CheckBox x:Name="HideToTrayOnStartupCheckBox"
                                              Content="Hide to tray"
                                              Margin="16,0,0,0"
                                              IsChecked="True"
                                              Checked="HideToTrayOnStartupCheckBox_Changed"
                                              Unchecked="HideToTrayOnStartupCheckBox_Changed"/>
                                    </WrapPanel>

                                    <StackPanel Grid.Row="2" Margin="0,10,0,0">
                                        <TextBlock Text="Models Location"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource SubtleTextBrush}"
                                                   Margin="0,0,0,4"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="ModelsLocationTextBox"
                                                     IsReadOnly="True"
                                                     MinWidth="120"
                                                     TextWrapping="NoWrap"
                                                     VerticalContentAlignment="Center"
                                                     ToolTip="Base folder containing Models and CompleteModels."/>
                                            <Button Grid.Column="1"
                                                    Content="..."
                                                    MinWidth="34"
                                                    Margin="6,0,0,0"
                                                    Padding="8,3"
                                                    ToolTip="Choose the base folder for Models and CompleteModels."
                                                    Click="ModelsLocationBrowseButton_Click"/>
                                        </Grid>
                                    </StackPanel>

                                    <StackPanel Grid.Row="3" Margin="0,8,0,0">

                                        <TextBlock x:Name="SettingsStatusText"
                                               Text="Saved in runtime directory."
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource SubtleTextBrush}"
                                               Margin="0,5,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </GroupBox>

                            <GroupBox Header="Network" Grid.Column="1" Padding="8,10,8,8" Margin="0,0,8,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Provider"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0"/>
                                    <ComboBox x:Name="ModelRuntimeProviderComboBox"
                                              Grid.Column="1"
                                              Height="30"
                                              MinWidth="170"
                                              SelectionChanged="ModelRuntimeProviderComboBox_SelectionChanged"
                                              ToolTip="Choose the local model runtime used by JackLLM Workstation.">
                                        <ComboBoxItem Content="Embedded LlmRuntime" Tag="llmruntime"/>
                                        <ComboBoxItem Content="LM Studio" Tag="lmstudio"/>
                                    </ComboBox>
                                    <TextBlock x:Name="ModelRuntimeProviderStatusText"
                                               Grid.Row="1"
                                               Grid.ColumnSpan="2"
                                               Text="Embedded LlmRuntime is the local provider."
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource SubtleTextBrush}"
                                               Margin="0,6,0,0"/>
                                    <CheckBox x:Name="RemoteLmStudioCheckBox"
                                          Grid.Row="6"
                                          Content="Remote LM Studio"
                                          Checked="RemoteLmStudioCheckBox_Changed"
                                          Unchecked="RemoteLmStudioCheckBox_Changed"
                                          Visibility="Collapsed"/>
                                    <TextBox x:Name="RemoteServerTextBox"
                                         Grid.Row="6"
                                         Grid.Column="1"
                                         Text="127.0.0.1:11435"
                                         Height="30"
                                         Margin="12,0,0,0"
                                         VerticalContentAlignment="Center"
                                         IsEnabled="False"
                                         TextChanged="RemoteServerTextBox_TextChanged"
                                         ToolTip="Use host, host:port, or http(s) URL. The local app still talks to localhost:11435."
                                         Visibility="Collapsed"/>
                                    <TextBlock x:Name="ShellModeStatusText"
                                           Grid.Row="7"
                                           Grid.ColumnSpan="2"
                                           Text="Shell mode disabled."
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource SubtleTextBrush}"
                                           Margin="0,6,0,0"
                                           Visibility="Collapsed"/>
                                    <CheckBox x:Name="PortForwardingCheckBox"
                                              Grid.Row="2"
                                              Grid.ColumnSpan="2"
                                              Content="Forward web and FTP ports 11436, 2121"
                                              Margin="0,10,0,0"
                                              IsChecked="True"
                                              Checked="PortForwardingCheckBox_Changed"
                                              Unchecked="PortForwardingCheckBox_Changed"
                                              Visibility="Collapsed"/>
                                    <CheckBox x:Name="WebChatModelLoadApiCheckBox"
                                              Grid.Row="2"
                                              Grid.ColumnSpan="2"
                                              Content="Allow web chat to load any model"
                                              Margin="0,10,0,0"
                                              Checked="WebChatModelLoadApiCheckBox_Changed"
                                              Unchecked="WebChatModelLoadApiCheckBox_Changed"
                                              ToolTip="Global override for the web chat model-load API. Leave off to require each model's Enabled checkbox in the Models tab."/>
                                    <TextBlock x:Name="PortForwardStatusText"
                                           Grid.Row="3"
                                           Grid.ColumnSpan="2"
                                           Text="Enabled. Waiting to forward TCP 11436, 2121."
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource SubtleTextBrush}"
                                           Margin="0,8,0,0"/>
                                    <CheckBox x:Name="AllowOpenRegistrationCheckBox"
                                          Grid.Row="4"
                                          Grid.ColumnSpan="2"
                                          Content="SocketJack.com handles registration"
                                          Foreground="#F87171"
                                          BorderBrush="#EF4444"
                                          FontWeight="SemiBold"
                                          Margin="0,10,0,0"
                                          IsEnabled="False"
                                          Visibility="Collapsed"
                                          Checked="AllowOpenRegistrationCheckBox_Changed"
                                          Unchecked="AllowOpenRegistrationCheckBox_Changed"/>
                                    <TextBlock x:Name="OpenRegistrationWarningText"
                                           Grid.Row="5"
                                           Grid.ColumnSpan="2"
                                           Text="SocketJack.com handles account registration and login."
                                           Foreground="#FACC15"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           Margin="0,6,0,0"
                                           Visibility="Collapsed"/>
                                </Grid>
                            </GroupBox>

                            <GroupBox Header="Billing" Grid.Column="2" Padding="8,10,8,8" Margin="0,0,8,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                    <Border Width="28" Height="28" CornerRadius="7" Background="#3340C9A2" BorderBrush="#6640C9A2" BorderThickness="1" VerticalAlignment="Center" Margin="0,0,10,0">
                                        <TextBlock Text="$" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Storage" FontWeight="SemiBold"/>
                                        <TextBlock Text="Base cost profile" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                    </StackPanel>
                                    <ComboBox x:Name="StorageTypeComboBox"
                                          Grid.Column="2"
                                          MinWidth="118"
                                          Height="30"
                                          VerticalContentAlignment="Center"
                                          SelectionChanged="StorageCostSettings_Changed"
                                          ToolTip="Storage base cost per GB: NVMe and SATA SSD $0.10, SATA HDD $0.015.">
                                        <ComboBoxItem Content="Nvme"/>
                                        <ComboBoxItem Content="SATA SSD"/>
                                        <ComboBoxItem Content="SATA HDD"/>
                                    </ComboBox>
                                    <Border Grid.Row="1" Width="28" Height="28" CornerRadius="7" Background="#333B82F6" BorderBrush="#663B82F6" BorderThickness="1" VerticalAlignment="Center" Margin="0,12,10,0">
                                        <TextBlock Text="GB" Foreground="#9CC3FF" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Cost factor (x)" Foreground="{StaticResource SubtleTextBrush}" VerticalAlignment="Center" Margin="0,12,10,0"/>
                                    <Grid Grid.Row="1" Grid.Column="2" Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="48"/>
                                        </Grid.ColumnDefinitions>
                                        <Slider x:Name="StorageCostFactorSlider"
                                            Minimum="1"
                                            Maximum="5"
                                            Value="1"
                                            TickFrequency="0.1"
                                            IsSnapToTickEnabled="True"
                                            VerticalAlignment="Center"
                                            ValueChanged="StorageCostSettings_Changed"
                                            ToolTip="1.0 uses base storage cost; 5.0 charges five times base storage cost."/>
                                        <TextBlock x:Name="StorageCostFactorText"
                                               Grid.Column="1"
                                               Text="1.0x"
                                               Foreground="{StaticResource TextBrush}"
                                               FontFamily="Consolas"
                                               VerticalAlignment="Center"
                                               TextAlignment="Right"
                                               Margin="10,0,0,0"/>
                                    </Grid>
                                    <Border Grid.Row="2" Width="28" Height="28" CornerRadius="7" Background="#3322C55E" BorderBrush="#6622C55E" BorderThickness="1" VerticalAlignment="Center" Margin="0,12,10,0">
                                        <TextBlock Text="GPU" Foreground="#86EFAC" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Power profile (TDP)" Foreground="{StaticResource SubtleTextBrush}" VerticalAlignment="Center" Margin="0,12,10,0"/>
                                    <TextBlock x:Name="GpuTdpBillingText"
                                           Grid.Row="2"
                                           Grid.Column="2"
                                           Text="not detected"
                                           Foreground="{StaticResource TextBrush}"
                                           FontFamily="Consolas"
                                           VerticalAlignment="Center"
                                           TextAlignment="Right"
                                           Margin="0,12,0,0"/>
                                    <Border Grid.Row="3" Width="28" Height="28" CornerRadius="7" Background="#33A855F7" BorderBrush="#66A855F7" BorderThickness="1" VerticalAlignment="Center" Margin="0,12,10,0">
                                        <TextBlock Text="CPU" Foreground="#C4B5FD" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="CPU TDP estimate" Foreground="{StaticResource SubtleTextBrush}" VerticalAlignment="Center" Margin="0,12,10,0"/>
                                    <TextBlock x:Name="CpuTdpBillingText"
                                           Grid.Row="3"
                                           Grid.Column="2"
                                           Text="not detected"
                                           Foreground="{StaticResource TextBrush}"
                                           FontFamily="Consolas"
                                           VerticalAlignment="Center"
                                           TextAlignment="Right"
                                           Margin="0,12,0,0"
                                           ToolTip="CPU TDP estimate used by chat electricity cost calculations."/>
                                </Grid>
                            </GroupBox>

                            <GroupBox x:Name="HealthGroupBox" Header="Health" Grid.Column="3" Padding="8,10,8,8" Margin="0">
                                <UniformGrid x:Name="HealthMetricsGrid"
                                             Columns="3"
                                             Rows="0"
                                             Margin="-2">
                                    <Border Height="36" MinHeight="36" Background="#7A0F172A" BorderBrush="#405B6B82" BorderThickness="1" CornerRadius="7" Padding="7,4" Margin="2">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="CPU" Foreground="{StaticResource SubtleTextBrush}" FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                                <TextBlock x:Name="CpuUsageHealthText" Grid.Column="1" Text="measuring" Foreground="{StaticResource TextBrush}" FontFamily="Consolas" FontSize="11" FontWeight="SemiBold" TextAlignment="Right" TextTrimming="CharacterEllipsis" Margin="8,0,0,0"/>
                                            </Grid>
                                            <ProgressBar x:Name="CpuUsageProgressBar" Grid.Row="1" Style="{StaticResource HealthMeterProgressBarStyle}" Foreground="#A855F7" Margin="0,4,0,0"/>
                                        </Grid>
                                    </Border>
                                    <Border Height="36" MinHeight="36" Background="#7A0F172A" BorderBrush="#405B6B82" BorderThickness="1" CornerRadius="7" Padding="7,4" Margin="2">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="RAM" Foreground="{StaticResource SubtleTextBrush}" FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                                <TextBlock x:Name="RamUsageHealthText" Grid.Column="1" Text="measuring" Foreground="{StaticResource TextBrush}" FontFamily="Consolas" FontSize="11" FontWeight="SemiBold" TextAlignment="Right" TextTrimming="CharacterEllipsis" Margin="8,0,0,0"/>
                                            </Grid>
                                            <ProgressBar x:Name="RamUsageProgressBar" Grid.Row="1" Style="{StaticResource HealthMeterProgressBarStyle}" Foreground="#F59E0B" Margin="0,4,0,0"/>
                                        </Grid>
                                    </Border>
                                    <Border Height="36" MinHeight="36" Background="#7A0F172A" BorderBrush="#405B6B82" BorderThickness="1" CornerRadius="7" Padding="7,4" Margin="2">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="GPU" Foreground="{StaticResource SubtleTextBrush}" FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                                <TextBlock x:Name="GpuUtilizationHealthText" Grid.Column="1" Text="unavailable" Foreground="{StaticResource TextBrush}" FontFamily="Consolas" FontSize="11" FontWeight="SemiBold" TextAlignment="Right" TextTrimming="CharacterEllipsis" Margin="8,0,0,0"/>
                                            </Grid>
                                            <ProgressBar x:Name="GpuUtilizationProgressBar" Grid.Row="1" Style="{StaticResource HealthMeterProgressBarStyle}" Foreground="#22C55E" Margin="0,4,0,0"/>
                                        </Grid>
                                    </Border>
                                    <Border Height="36" MinHeight="36" Background="#7A0F172A" BorderBrush="#405B6B82" BorderThickness="1" CornerRadius="7" Padding="7,4" Margin="2">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="VRAM" Foreground="{StaticResource SubtleTextBrush}" FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                                <TextBlock x:Name="VramUsageHealthText" Grid.Column="1" Text="unavailable" Foreground="{StaticResource TextBrush}" FontFamily="Consolas" FontSize="11" FontWeight="SemiBold" TextAlignment="Right" TextTrimming="CharacterEllipsis" Margin="8,0,0,0"/>
                                            </Grid>
                                            <ProgressBar x:Name="VramUsageProgressBar" Grid.Row="1" Style="{StaticResource HealthMeterProgressBarStyle}" Foreground="#FF5C7A" Margin="0,4,0,0"/>
                                        </Grid>
                                    </Border>
                                    <Border Height="36" MinHeight="36" Background="#7A0F172A" BorderBrush="#405B6B82" BorderThickness="1" CornerRadius="7" Padding="7,4" Margin="2">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="NET DN" Foreground="{StaticResource SubtleTextBrush}" FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                                <TextBlock x:Name="NetworkDownHealthText" Grid.Column="1" Text="0.0 kbps" Foreground="{StaticResource TextBrush}" FontFamily="Consolas" FontSize="11" FontWeight="SemiBold" TextAlignment="Right" TextTrimming="CharacterEllipsis" Margin="8,0,0,0"/>
                                            </Grid>
                                            <ProgressBar x:Name="NetworkDownProgressBar" Grid.Row="1" Style="{StaticResource HealthMeterProgressBarStyle}" Foreground="#F97316" Margin="0,4,0,0"/>
                                        </Grid>
                                    </Border>
                                    <Border Height="36" MinHeight="36" Background="#7A0F172A" BorderBrush="#405B6B82" BorderThickness="1" CornerRadius="7" Padding="7,4" Margin="2">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="NET UP" Foreground="{StaticResource SubtleTextBrush}" FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                                <TextBlock x:Name="NetworkUpHealthText" Grid.Column="1" Text="0.0 kbps" Foreground="{StaticResource TextBrush}" FontFamily="Consolas" FontSize="11" FontWeight="SemiBold" TextAlignment="Right" TextTrimming="CharacterEllipsis" Margin="8,0,0,0"/>
                                            </Grid>
                                            <ProgressBar x:Name="NetworkUpProgressBar" Grid.Row="1" Style="{StaticResource HealthMeterProgressBarStyle}" Foreground="#F43F5E" Margin="0,4,0,0"/>
                                        </Grid>
                                    </Border>
                                    <Border Height="36" MinHeight="36" Background="#7A0F172A" BorderBrush="#405B6B82" BorderThickness="1" CornerRadius="7" Padding="7,4" Margin="2">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="I/O" Foreground="{StaticResource SubtleTextBrush}" FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                                <TextBlock x:Name="IoTotalHealthText" Grid.Column="1" Text="0 B/s" Foreground="{StaticResource TextBrush}" FontFamily="Consolas" FontSize="11" FontWeight="SemiBold" TextAlignment="Right" TextTrimming="CharacterEllipsis" Margin="8,0,0,0"/>
                                            </Grid>
                                            <ProgressBar x:Name="IoProgressBar" Grid.Row="1" Style="{StaticResource HealthMeterProgressBarStyle}" Foreground="#F97316" Margin="0,4,0,0"/>
                                            <WrapPanel Grid.Row="2" Visibility="Collapsed">
                                                <TextBlock Text="R " Foreground="{StaticResource SubtleTextBrush}" FontFamily="Consolas" FontSize="10"/>
                                                <TextBlock x:Name="IoReadHealthText" Text="0 B/s" Foreground="{StaticResource TextBrush}" FontFamily="Consolas" FontSize="10" Margin="0,0,8,0"/>
                                                <TextBlock Text="W " Foreground="{StaticResource SubtleTextBrush}" FontFamily="Consolas" FontSize="10"/>
                                                <TextBlock x:Name="IoWriteHealthText" Text="0 B/s" Foreground="{StaticResource TextBrush}" FontFamily="Consolas" FontSize="10"/>
                                            </WrapPanel>
                                        </Grid>
                                    </Border>
                                    <Border Height="36" MinHeight="36" Background="#7A0F172A" BorderBrush="#405B6B82" BorderThickness="1" CornerRadius="7" Padding="7,4" Margin="2">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="TOK/HR" Foreground="{StaticResource SubtleTextBrush}" FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                                <TextBlock x:Name="TokenRateHealthText" Grid.Column="1" Text="0/hr" Foreground="{StaticResource TextBrush}" FontFamily="Consolas" FontSize="11" FontWeight="SemiBold" TextAlignment="Right" TextTrimming="CharacterEllipsis" Margin="8,0,0,0"/>
                                            </Grid>
                                            <ProgressBar x:Name="TokenRateHealthProgressBar" Grid.Row="1" Style="{StaticResource HealthMeterProgressBarStyle}" Foreground="#EC4899" Margin="0,4,0,0"/>
                                        </Grid>
                                    </Border>
                                    <Border Height="36" MinHeight="36" Background="#7A0F172A" BorderBrush="#405B6B82" BorderThickness="1" CornerRadius="7" Padding="7,4" Margin="2">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="TOKENS" Foreground="{StaticResource SubtleTextBrush}" FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                                <TextBlock x:Name="TokenTotalHealthText" Grid.Column="1" Text="0" Foreground="{StaticResource TextBrush}" FontFamily="Consolas" FontSize="11" FontWeight="SemiBold" TextAlignment="Right" TextTrimming="CharacterEllipsis" Margin="8,0,0,0"/>
                                            </Grid>
                                            <Border Grid.Row="1" Height="4" CornerRadius="3" Background="#334E5E74" Margin="0,4,0,0">
                                                <Border Background="#6366F1" CornerRadius="3" Width="34" HorizontalAlignment="Left"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </UniformGrid>
                            </GroupBox>
                        </Grid>
                    </Border>

                    <Grid x:Name="MainWorkspaceGrid"
                          Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition x:Name="MainWorkspacePrimaryRow" Height="*"/>
                            <RowDefinition x:Name="MainWorkspaceStackedRow" Height="0"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="SidebarColumn" Width="0" MinWidth="0"/>
                            <ColumnDefinition x:Name="DiagnosticsColumn" Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border x:Name="SidebarPanel"
                                Grid.Column="0"
                                Visibility="Collapsed"
                                Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="8"
                                Margin="0,0,14,0">
                            <TabControl x:Name="SidebarTabs"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="{StaticResource TextBrush}">
                                <TabItem Header="Explorer">
                                    <Grid Margin="0,8,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <DockPanel>
                                            <Button x:Name="RefreshExplorerButton"
                                                    Content="Refresh"
                                                    DockPanel.Dock="Right"
                                                    Click="RefreshExplorerButton_Click"
                                                    Padding="8,3"/>
                                            <Button x:Name="BrowseAccessibleDirectoryButton"
                                                    Content="Add Dir"
                                                    DockPanel.Dock="Right"
                                                    Click="BrowseAccessibleDirectoryButton_Click"
                                                    Padding="8,3"
                                                    Margin="0,0,6,0"
                                                    ToolTip="Add accessible directory"/>
                                            <TextBlock Text="Solution Explorer"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                        </DockPanel>
                                        <StackPanel Grid.Row="1" Margin="0,7,0,7">
                                            <TextBlock x:Name="FilesystemOwnerText"
                                                       Text="Owner: ip:127.0.0.1"
                                                       Foreground="{StaticResource SubtleTextBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock x:Name="FilesystemAccessStatusText"
                                                       Text="No accessible directories defined."
                                                       Foreground="{StaticResource SubtleTextBrush}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,2,0,0"/>
                                            <TextBlock x:Name="WorkspaceSummaryText"
                                                       Text="No workspace loaded"
                                                       Foreground="{StaticResource SubtleTextBrush}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <TreeView x:Name="WorkspaceTreeView"
                                                  Grid.Row="2"
                                                  Background="#66070A10"
                                                  BorderBrush="{StaticResource PanelBorderBrush}"
                                                  BorderThickness="1"
                                                  Foreground="{StaticResource TextBrush}"
                                                  SelectedItemChanged="WorkspaceTreeView_SelectedItemChanged"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                                            <TreeView.ItemContainerStyle>
                                                <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                                    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                                    <Setter Property="Padding" Value="0"/>
                                                </Style>
                                            </TreeView.ItemContainerStyle>
                                            <TreeView.ItemTemplate>
                                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                                    <Border Background="#99111924"
                                                            BorderBrush="#334E5E74"
                                                            BorderThickness="1"
                                                            CornerRadius="6"
                                                            Padding="7"
                                                            Margin="0,1,0,4">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding Icon}"
                                                                       FontFamily="Consolas"
                                                                       Foreground="{Binding AccentBrush}"
                                                                       Margin="0,1,7,0"/>
                                                            <StackPanel Grid.Column="1">
                                                                <TextBlock Text="{Binding DisplayName}"
                                                                           FontWeight="{Binding FontWeight}"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Text="{Binding Detail}"
                                                                           Foreground="{StaticResource SubtleTextBrush}"
                                                                           FontSize="11"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           Margin="0,2,0,0"/>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="2"
                                                                        Orientation="Horizontal"
                                                                        VerticalAlignment="Top"
                                                                        Margin="8,0,0,0">
                                                                <Button Content="ZIP"
                                                                        Tag="{Binding}"
                                                                        Click="DownloadWorkspaceTreeDirectoryZipButton_Click"
                                                                        Padding="7,2"
                                                                        MinWidth="36"
                                                                        Height="24"
                                                                        Margin="0,0,6,0"
                                                                        FontSize="11"
                                                                        Visibility="{Binding ZipVisibility}"
                                                                        ToolTip="Download folder as ZIP"/>
                                                                <Button Content="X"
                                                                        Tag="{Binding}"
                                                                        Click="RemoveWorkspaceTreeDirectoryButton_Click"
                                                                        Padding="7,2"
                                                                        MinWidth="26"
                                                                        Height="24"
                                                                        Visibility="{Binding RemoveVisibility}"
                                                                        ToolTip="Remove directory access"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </HierarchicalDataTemplate>
                                            </TreeView.ItemTemplate>
                                        </TreeView>
                                    </Grid>
                                </TabItem>

                                <TabItem Header="Sessions">
                                    <Grid Margin="0,8,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <DockPanel>
                                            <Button x:Name="RefreshSessionsButton"
                                                    Content="Refresh"
                                                    DockPanel.Dock="Right"
                                                    Click="RefreshSessionsButton_Click"
                                                    Padding="8,3"/>
                                            <Button x:Name="StoredSessionsMenuButton"
                                                    Content="History"
                                                    DockPanel.Dock="Right"
                                                    Click="StoredSessionsMenuButton_Click"
                                                    Padding="8,3"
                                                    Margin="0,0,6,0"/>
                                            <TextBlock Text="Sessions"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                        </DockPanel>
                                        <TextBlock x:Name="SessionsSummaryText"
                                                   Grid.Row="1"
                                                   Text="No sessions loaded"
                                                   Foreground="{StaticResource SubtleTextBrush}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,7,0,7"/>
                                        <Border Grid.Row="2"
                                                Background="#55111924"
                                                BorderBrush="#334E5E74"
                                                BorderThickness="1"
                                                CornerRadius="7"
                                                Padding="8"
                                                Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="SessionSearchTextBox"
                                                         Height="28"
                                                         VerticalContentAlignment="Center"
                                                         TextChanged="SessionSearchTextBox_TextChanged"
                                                         ToolTip="Search saved and active sessions. Turn on Regex for pattern search."
                                                         Margin="0,0,8,0"/>
                                                <CheckBox x:Name="SessionRegexCheckBox"
                                                          Grid.Column="1"
                                                          Content="Regex"
                                                          VerticalAlignment="Center"
                                                          Foreground="{StaticResource TextBrush}"
                                                          Checked="SessionRegexCheckBox_Changed"
                                                          Unchecked="SessionRegexCheckBox_Changed"/>
                                                <TextBlock x:Name="SessionRegexStatusText"
                                                           Grid.Row="1"
                                                           Grid.ColumnSpan="2"
                                                           Foreground="{StaticResource SubtleTextBrush}"
                                                           FontSize="11"
                                                           Text="Search title, owner, model, lock state, clone state, and prompt tokens."
                                                           TextWrapping="Wrap"
                                                           Margin="0,6,0,0"/>
                                                <WrapPanel Grid.Row="2"
                                                           Grid.ColumnSpan="2"
                                                           Margin="0,8,0,0">
                                                    <Button Content="Save"
                                                            Click="SessionSaveButton_Click"
                                                            Padding="8,3"
                                                            Margin="0,0,6,0"
                                                            ToolTip="Mark the selected stored session saved"/>
                                                    <Button Content="Lock"
                                                            Click="SessionLockButton_Click"
                                                            Padding="8,3"
                                                            Margin="0,0,6,0"
                                                            ToolTip="Lock or unlock the selected stored session"/>
                                                    <Button Content="Clone"
                                                            Click="SessionCloneButton_Click"
                                                            Padding="8,3"
                                                            Margin="0,0,6,0"
                                                            ToolTip="Clone the selected stored session"/>
                                                    <Button Content="Rename"
                                                            Click="SessionRenameButton_Click"
                                                            Padding="8,3"
                                                            ToolTip="Rename the selected stored session"/>
                                                </WrapPanel>
                                            </Grid>
                                        </Border>
                                        <ListBox x:Name="SessionsListBox"
                                                 Grid.Row="3"
                                                 Background="#66070A10"
                                                 BorderBrush="{StaticResource PanelBorderBrush}"
                                                 BorderThickness="1"
                                                 Foreground="{StaticResource TextBrush}"
                                                 HorizontalContentAlignment="Stretch"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                 ScrollViewer.CanContentScroll="True"
                                                 VirtualizingPanel.IsVirtualizing="True"
                                                 VirtualizingPanel.VirtualizationMode="Recycling"
                                                 VirtualizingPanel.ScrollUnit="Pixel"
                                                 SelectionChanged="SessionsListBox_SelectionChanged">
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                                    <Setter Property="Padding" Value="0"/>
                                                    <Setter Property="Margin" Value="0,0,0,7"/>
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#99111924"
                                                            BorderBrush="#334E5E74"
                                                            BorderThickness="1"
                                                            CornerRadius="7"
                                                            Padding="8">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Title}"
                                                                           FontWeight="SemiBold"
                                                                           TextWrapping="Wrap"/>
                                                                <TextBlock Text="{Binding OwnerLine}"
                                                                           Foreground="{StaticResource SubtleTextBrush}"
                                                                           TextWrapping="Wrap"
                                                                           Margin="0,4,0,0"/>
                                                                <TextBlock Text="{Binding DetailLine}"
                                                                           Foreground="{StaticResource SubtleTextBrush}"
                                                                           TextWrapping="Wrap"
                                                                           Margin="0,2,0,0"/>
                                                                <ProgressBar Height="5"
                                                                             Minimum="0"
                                                                             Maximum="100"
                                                                             Value="{Binding PromptTokenPercent}"
                                                                             Margin="0,7,0,0"
                                                                             ToolTip="{Binding PromptTokenLine}"/>
                                                                <TextBlock Text="{Binding PromptTokenLine}"
                                                                           Foreground="{StaticResource SubtleTextBrush}"
                                                                           FontSize="11"
                                                                           TextWrapping="Wrap"
                                                                           Margin="0,3,0,0"/>
                                                                <TextBlock Text="{Binding UpdatedLine}"
                                                                           Foreground="{StaticResource SubtleTextBrush}"
                                                                           TextWrapping="Wrap"
                                                                           Margin="0,2,0,0"/>
                                                            </StackPanel>
                                                            <Button Grid.Column="1"
                                                                    Content="..."
                                                                    Tag="{Binding}"
                                                                    Click="SessionAdminButton_Click"
                                                                    Padding="8,2"
                                                                    MinWidth="32"
                                                                    Height="26"
                                                                    Margin="8,0,0,0"
                                                                    VerticalAlignment="Top"
                                                                    ToolTip="Administrative options"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>
                                </TabItem>
                            </TabControl>
                        </Border>

                        <Grid x:Name="DiagnosticsPanel"
                              Grid.Column="1"
                              MinWidth="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource PanelBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="9"
                            Margin="0,0,0,10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <DockPanel>
                                        <TextBlock x:Name="PipelineSummaryText"
                                           DockPanel.Dock="Right"
                                           Foreground="{StaticResource SubtleTextBrush}"
                                           Text="Pipeline idle"
                                           TextWrapping="Wrap"
                                           Margin="16,2,0,0"/>
                                        <TextBlock Text="Diagnostics"
                                           FontSize="16"
                                           FontWeight="SemiBold"/>
                                    </DockPanel>
                                    <Grid Grid.Row="1"
                                          Grid.RowSpan="2"
                                          Margin="0,6,0,0">
                                            <Grid Margin="0,0,0,0">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>
                                    <ItemsControl x:Name="PipelineItemsControl"
                                          Grid.Row="0"
                                          Margin="0,0,0,6">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,6,4">
                                                    <Border Background="{Binding BackgroundBrush}"
                                                    BorderBrush="{Binding BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="7"
                                                    Padding="8,3">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Name}"
                                                               FontWeight="SemiBold"
                                                               FontSize="12"/>
                                                            <TextBlock Text="{Binding Detail}"
                                                               Foreground="{StaticResource SubtleTextBrush}"
                                                               FontSize="10"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <TextBlock Text=">"
                                                       Visibility="{Binding ArrowVisibility}"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       FontWeight="Bold"
                                                       VerticalAlignment="Center"
                                                       Margin="6,0,0,0"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Grid x:Name="ServicesPanelHost"
                                          Grid.Row="1"
                                          Margin="-3,0,-3,-3"
                                          MinHeight="280">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <ScrollViewer x:Name="ServicesPanelScrollViewer"
                                                      Grid.Row="0"
                                                      MaxHeight="128"
                                                      VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled"
                                                      CanContentScroll="True">
                                    <ListBox x:Name="ServicesListBox"
                                             Margin="0"
                                             Background="Transparent"
                                             BorderBrush="{x:Null}"
                                             BorderThickness="0"
                                             Foreground="{StaticResource TextBrush}"
                                             HorizontalContentAlignment="Stretch"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                             SelectionMode="Extended"
                                             SelectionChanged="ServicesListBox_SelectionChanged">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="Margin" Value="0,0,0,6"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border x:Name="ServiceBorder"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Padding="4,2"
                                                Margin="2"
                                                Height="42"
                                                MinWidth="168">
                                                    <Border.BorderBrush>
                                                        <SolidColorBrush Color="#334E5E74"/>
                                                    </Border.BorderBrush>
                                                    <Grid ToolTip="{Binding Detail}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Ellipse x:Name="ServiceDot"
                                                                 Width="8"
                                                                 Height="8"
                                                                 Margin="0,5,6,0"
                                                                 VerticalAlignment="Top">
                                                            <Ellipse.Fill>
                                                                <SolidColorBrush Color="#596777"/>
                                                            </Ellipse.Fill>
                                                        </Ellipse>
                                                        <Grid Grid.Column="1">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            <TextBlock Text="{Binding Name}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="11"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Grid.Row="1"
                                                               Text="{Binding Status}"
                                                               Foreground="{StaticResource SubtleTextBrush}"
                                                               FontSize="10"
                                                               Margin="0"
                                                               TextTrimming="CharacterEllipsis"/>
                                                        </Grid>
                                                        <StackPanel Grid.Column="2"
                                                                Orientation="Horizontal"
                                                                Margin="6,0,0,0"
                                                                VerticalAlignment="Stretch"
                                                                Visibility="{Binding BandwidthVisibility}">
                                                            <StackPanel Margin="0,0,4,0" ToolTip="{Binding BandwidthInText}">
                                                                <ProgressBar Style="{StaticResource BandwidthProgressBarStyle}"
                                                                 Minimum="{Binding BandwidthInMinimum, Mode=OneWay}"
                                                                 Maximum="{Binding BandwidthInMaximum, Mode=OneWay}"
                                                                 Value="{Binding BandwidthInValue, Mode=OneWay}"
                                                                         Height="28"
                                                                         Width="8"/>
                                                                <TextBlock Text="I"
                                                                       Foreground="{StaticResource SubtleTextBrush}"
                                                                       FontSize="9"
                                                                       TextAlignment="Center"
                                                                       Margin="0,1,0,0"/>
                                                            </StackPanel>
                                                            <StackPanel ToolTip="{Binding BandwidthOutText}">
                                                                <ProgressBar Style="{StaticResource BandwidthProgressBarStyle}"
                                                                 Minimum="{Binding BandwidthOutMinimum, Mode=OneWay}"
                                                                 Maximum="{Binding BandwidthOutMaximum, Mode=OneWay}"
                                                                 Value="{Binding BandwidthOutValue, Mode=OneWay}"
                                                                         Height="28"
                                                                         Width="8"/>
                                                                <TextBlock Text="O"
                                                                       Foreground="{StaticResource SubtleTextBrush}"
                                                                       FontSize="9"
                                                                       TextAlignment="Center"
                                                                       Margin="0,1,0,0"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsPulsing}" Value="True">
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <ColorAnimation Storyboard.TargetName="ServiceBorder"
                                                                            Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                                            To="#6BFF98"
                                                                            Duration="0:0:0.08"/>
                                                                    <ColorAnimation Storyboard.TargetName="ServiceBorder"
                                                                            Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                                            To="#334E5E74"
                                                                            BeginTime="0:0:0.5"
                                                                            Duration="0:0:0.35"/>
                                                                    <ColorAnimation Storyboard.TargetName="ServiceDot"
                                                                            Storyboard.TargetProperty="(Shape.Fill).(SolidColorBrush.Color)"
                                                                            To="#7CFF9D"
                                                                            Duration="0:0:0.06"/>
                                                                    <ColorAnimation Storyboard.TargetName="ServiceDot"
                                                                            Storyboard.TargetProperty="(Shape.Fill).(SolidColorBrush.Color)"
                                                                            To="#596777"
                                                                            BeginTime="0:0:0.14"
                                                                            Duration="0:0:0.20"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                        </ScrollViewer>
                                    <Border x:Name="ServiceDetailsPanel"
                                            Grid.Row="1"
                                            Margin="0,8,0,0"
                                            MinHeight="260"
                                            Padding="8"
                                            Background="#66070A10"
                                            BorderBrush="{StaticResource PanelBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="7"
                                            VerticalAlignment="Stretch"
                                            Visibility="Collapsed">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                            <DockPanel>
                                                <WrapPanel DockPanel.Dock="Right"
                                                           HorizontalAlignment="Right">
                                                    <Button x:Name="ServiceCopySnapshotButton"
                                                            Content="Copy details"
                                                            Click="ServiceCopySnapshotButton_Click"
                                                            Padding="7,3"
                                                            Margin="0,0,8,0"/>
                                                    <Button x:Name="ServiceClearLogButton"
                                                            Content="Clear log"
                                                            Click="ServiceClearLogButton_Click"
                                                            Padding="7,3"/>
                                                </WrapPanel>
                                                <TextBlock x:Name="SelectedServiceNameText"
                                                           Text="Service"
                                                           FontWeight="SemiBold"
                                                           FontSize="14"/>
                                            </DockPanel>
                                            <TextBlock x:Name="SelectedServiceStatusText"
                                                       Grid.Row="1"
                                                       Foreground="{StaticResource SubtleTextBrush}"
                                                       Margin="0,4,0,0"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock x:Name="SelectedServiceDetailText"
                                                       Grid.Row="2"
                                                       Foreground="{StaticResource SubtleTextBrush}"
                                                       Margin="0,6,0,8"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"/>
                                            <TabControl Grid.Row="3"
                                                        Margin="0,2,0,0"
                                                        MinHeight="240"
                                                        VerticalAlignment="Stretch">
                                                <TabItem Header="Configure">
                                                    <Grid Margin="0,8,0,0">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="*"/>
                                                        </Grid.RowDefinitions>
                                                        <TextBox x:Name="ServicePropertySearchBox"
                                                                 Grid.Row="0"
                                                                 Height="26"
                                                                 Margin="0,0,0,6"
                                                                 Padding="8,3"
                                                                 Background="#101824"
                                                                 BorderBrush="{StaticResource PanelBorderBrush}"
                                                                 Foreground="{StaticResource TextBrush}"
                                                                 CaretBrush="{StaticResource AccentBrush}"
                                                                 FontSize="11"
                                                                 TextChanged="ServicePropertySearchBox_TextChanged"
                                                                 ToolTip="Search properties"/>
                                                        <ScrollViewer Grid.Row="1"
                                                                      VerticalScrollBarVisibility="Auto"
                                                                      HorizontalScrollBarVisibility="Disabled"
                                                                      MinHeight="140"
                                                                      VerticalAlignment="Stretch"
                                                                      Padding="0">
                                                            <StackPanel x:Name="ServiceOptionsPanel"
                                                                        Margin="0,0,0,4"/>
                                                        </ScrollViewer>
                                                    </Grid>
                                                </TabItem>
                                                <TabItem Header="Debug">
                                                    <RichTextBox x:Name="ServiceEventLogTextBox"
                                                                 Margin="0,8,0,0"
                                                                 Background="#070A10"
                                                                 BorderThickness="0"
                                                                 BorderBrush="{x:Null}"
                                                                 FontFamily="Consolas"
                                                                 FontSize="12.5"
                                                                 MinHeight="220"
                                                                 VerticalAlignment="Stretch"
                                                                 IsReadOnly="True"
                                                                 Foreground="#A8FFFFFF"
                                                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                                                        <FlowDocument PagePadding="0"/>
                                                    </RichTextBox>
                                                </TabItem>
                                            </TabControl>
                                        </Grid>
                                    </Border>
                                    </Grid>
                                            </Grid>
                                    </Grid>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1"
                        Background="#E60B1018"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <DockPanel Margin="12,10,12,8">
                                        <TextBlock Text="Pending requests" FontWeight="SemiBold" FontSize="15"/>
                                    </DockPanel>
                                    <StackPanel Grid.Row="1"
                                    Margin="12,0,12,8">
                                        <ItemsControl x:Name="TerminalPermissionRequestsControl">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#F02A1820"
                                                BorderBrush="#FFFFB020"
                                                BorderThickness="1"
                                                CornerRadius="7"
                                                Padding="10"
                                                Margin="0,0,0,8">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            <TextBlock Text="{Binding Title}"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap"/>
                                                            <TextBlock Grid.Row="1"
                                                           Text="{Binding Detail}"
                                                           Foreground="{StaticResource SubtleTextBrush}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,4,0,8"/>
                                                            <WrapPanel Grid.Row="2">
                                                                <Button Content="Approve IP" Tag="{Binding}" Click="TerminalPermissionApprove_Click" Margin="0,0,6,0" Padding="8,3"/>
                                                                <Button Content="Always Approve IP" Tag="{Binding}" Click="TerminalPermissionAlwaysApprove_Click" Margin="0,0,6,0" Padding="8,3"/>
                                                                <Button Content="Deny" Tag="{Binding}" Click="TerminalPermissionDeny_Click" Margin="0,0,6,0" Padding="8,3"/>
                                                                <Button Content="Always Deny IP" Tag="{Binding}" Click="TerminalPermissionAlwaysDeny_Click" Margin="0,0,6,0" Padding="8,3"/>
                                                                <Button Content="&#x26A0; FOREVER APPROVE"
                                                            Tag="{Binding}"
                                                            Click="TerminalPermissionForeverApprove_Click"
                                                            Background="#B91C1C"
                                                            BorderBrush="#FFF16A"
                                                            Foreground="#FFF16A"
                                                            ToolTip="THIS IS DANGEROUS AND CAN BE USED TO HARM YOUR COMPUTER."
                                                            Padding="8,3"/>
                                                            </WrapPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <ItemsControl x:Name="FilesystemPermissionRequestsControl">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#F0182432"
                                                BorderBrush="#FF4B7CFF"
                                                BorderThickness="1"
                                                CornerRadius="7"
                                                Padding="10"
                                                Margin="0,0,0,8">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            <TextBlock Text="{Binding Title}"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap"/>
                                                            <TextBlock Grid.Row="1"
                                                           Text="{Binding Detail}"
                                                           Foreground="{StaticResource SubtleTextBrush}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,4,0,8"/>
                                                            <WrapPanel Grid.Row="2">
                                                                <Button Content="Allow" Tag="{Binding}" Click="FilesystemPermissionAllow_Click" Margin="0,0,6,0" Padding="8,3"/>
                                                                <Button Content="Always Allow" Tag="{Binding}" Click="FilesystemPermissionAlwaysAllow_Click" Margin="0,0,6,0" Padding="8,3"/>
                                                                <Button Content="Deny" Tag="{Binding}" Click="FilesystemPermissionDeny_Click" Margin="0,0,6,0" Padding="8,3"/>
                                                                <Button Content="Always Deny" Tag="{Binding}" Click="FilesystemPermissionAlwaysDeny_Click" Margin="0,0,6,0" Padding="8,3"/>
                                                                <Button Content="Ban IP" Tag="{Binding}" Click="FilesystemPermissionBan_Click" Padding="8,3"/>
                                                            </WrapPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>

                    <StackPanel Grid.Row="3"
                                VerticalAlignment="Bottom"
                                Orientation="Vertical"
                                Margin="2,12,0,0">
                        <TextBlock x:Name="StatusBarText"
                                 Text="Ready"
                                 Foreground="{StaticResource SubtleTextBrush}"
                                 TextWrapping="NoWrap"
                                 TextTrimming="CharacterEllipsis"
                                 ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
                        <Border x:Name="ImagePipelineStatusPanel"
                                Margin="0,6,0,0"
                                MinHeight="28"
                                Background="#26111F2A"
                                BorderBrush="#334E66"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="7,4"
                                Opacity="1"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBox x:Name="ImagePipelineStatusText"
                                         Text="Pipeline idle"
                                         IsReadOnly="True"
                                         IsTabStop="False"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Padding="0"
                                         Foreground="{StaticResource SubtleTextBrush}"
                                         FontSize="11" />
                                <StackPanel x:Name="ImagePipelineActionPanel"
                                            Orientation="Horizontal"
                                            Margin="0,5,0,0"
                                            Visibility="Collapsed">
                                    <Button x:Name="InstallCudaButton"
                                            Content="Install CUDA"
                                            Click="InstallCudaButton_Click"
                                            Padding="8,2"
                                            Margin="0,0,6,0" />
                                    <Button x:Name="RepairPytorchButton"
                                            Content="Repair PyTorch"
                                            Click="RepairPytorchButton_Click"
                                            Padding="8,2" />
                                </StackPanel>
                                <Grid x:Name="ImagePipelineProgressContainer"
                                      Height="8"
                                      Margin="0,4,0,0"
                                      ClipToBounds="True">
                                    <Border Background="#2A3646"
                                            CornerRadius="4"/>
                                    <Rectangle x:Name="ImagePipelineRgbBar"
                                               Height="8"
                                               Width="220"
                                               HorizontalAlignment="Left">
                                        <Rectangle.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#FF39D9FF" Offset="0"/>
                                                <GradientStop Color="#FFB245FF" Offset="0.33"/>
                                                <GradientStop Color="#FFFF5D8D" Offset="0.66"/>
                                                <GradientStop Color="#FF39D9FF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Rectangle.Fill>
                                        <Rectangle.OpacityMask>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#000000" Offset="0"/>
                                                <GradientStop Color="#FFFFFFFF" Offset="0.15"/>
                                                <GradientStop Color="#FFFFFFFF" Offset="0.85"/>
                                                <GradientStop Color="#000000" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Rectangle.OpacityMask>
                                        <Rectangle.RenderTransform>
                                            <TranslateTransform x:Name="ImagePipelineRgbBarTransform"/>
                                        </Rectangle.RenderTransform>
                                    </Rectangle>
                                    <Rectangle x:Name="ImagePipelineGlare"
                                               Height="8"
                                               Width="70"
                                               HorizontalAlignment="Left">
                                        <Rectangle.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#00FFFFFF" Offset="0"/>
                                                <GradientStop Color="#80FFFFFF" Offset="0.5"/>
                                                <GradientStop Color="#00FFFFFF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Rectangle.Fill>
                                        <Rectangle.RenderTransform>
                                            <TranslateTransform x:Name="ImagePipelineGlareTransform"/>
                                        </Rectangle.RenderTransform>
                                    </Rectangle>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
                </TabItem>

                <TabItem x:Name="DiagnosticsWarningsTabItem">
                    <TabItem.Header>
                        <TextBlock x:Name="UsageWarningsTabHeaderText"
                                   Text="0 Warnings"/>
                    </TabItem.Header>
                    <Grid Margin="14,12,14,14">
                        <ListBox x:Name="ModelReconfigurationListBox"
                                 Background="#33070A10"
                                 BorderBrush="{StaticResource PanelBorderBrush}"
                                 BorderThickness="1"
                                 Foreground="{StaticResource TextBrush}"
                                 HorizontalContentAlignment="Stretch"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.CanContentScroll="True"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.ScrollUnit="Pixel">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,0,0,6"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding BackgroundBrush}"
                                            BorderBrush="{Binding BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="8">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding ModelLine}"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Severity}"
                                                           Foreground="{Binding SeverityBrush}"
                                                           FontFamily="Consolas"
                                                           FontWeight="Bold"
                                                           Margin="10,0,0,0"/>
                                            </Grid>
                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding SignalLine}"
                                                       Foreground="{StaticResource SubtleTextBrush}"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"
                                                       Margin="0,3,0,0"/>
                                            <TextBlock Grid.Row="2"
                                                       Text="{Binding RecommendationLine}"
                                                       Foreground="{StaticResource TextBrush}"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"
                                                       Margin="0,3,0,0"/>
                                            <ItemsControl Grid.Row="3"
                                                          ItemsSource="{Binding Actions}"
                                                          Visibility="{Binding ActionsVisibility}"
                                                          Margin="0,8,0,0">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Content="{Binding Label}"
                                                                Tag="{Binding}"
                                                                Click="WarningActionButton_Click"
                                                                Padding="8,3"
                                                                Margin="0,0,6,4"
                                                                Background="#26384E"
                                                                BorderBrush="#4B7CFF"
                                                                Foreground="{StaticResource TextBrush}"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </TabItem>

                <TabItem x:Name="WpfChatTab"
                         Header="Chat"
                         Visibility="Collapsed"
                         IsEnabled="False">
                    <Grid Margin="14,12,14,14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="JackLLM Workstation WPF Chat"
                                               FontSize="20"
                                               FontWeight="SemiBold"/>
                                    <TextBlock x:Name="WpfChatStatusText"
                                               Text="Type, dictate, then send to the local model through JackLLM Workstation."
                                               Foreground="{StaticResource SubtleTextBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0"/>
                                    <WrapPanel Margin="0,10,0,0">
                                        <StackPanel Width="230" Margin="0,0,8,6">
                                            <TextBlock Text="Model" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                            <ComboBox x:Name="WpfChatModelComboBox"
                                                      Height="28"
                                                      IsEditable="True"
                                                      SelectionChanged="WpfChatSettings_Changed"
                                                      LostFocus="WpfChatSettings_Changed"/>
                                        </StackPanel>
                                        <StackPanel Width="150" Margin="0,0,8,6">
                                            <TextBlock Text="Service" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                            <ComboBox x:Name="WpfChatServiceComboBox"
                                                      Height="28"
                                                      SelectionChanged="WpfChatSettings_Changed">
                                                <ComboBoxItem Content="Assistant" Tag=""/>
                                                <ComboBoxItem Content="Agent" Tag="agent"/>
                                                <ComboBoxItem Content="Companion" Tag="companion"/>
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel Width="64" Margin="0,0,8,6">
                                            <TextBlock Text="Temp" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                            <TextBox x:Name="WpfChatTemperatureTextBox"
                                                     Text="0.7"
                                                     Height="28"
                                                     VerticalContentAlignment="Center"
                                                     TextChanged="WpfChatSettings_Changed"/>
                                        </StackPanel>
                                        <StackPanel Width="64" Margin="0,0,8,6">
                                            <TextBlock Text="Top P" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                            <TextBox x:Name="WpfChatTopPTextBox"
                                                     Text="1"
                                                     Height="28"
                                                     VerticalContentAlignment="Center"
                                                     TextChanged="WpfChatSettings_Changed"/>
                                        </StackPanel>
                                        <StackPanel Width="86" Margin="0,0,8,6">
                                            <TextBlock Text="Max" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                            <TextBox x:Name="WpfChatMaxTokensTextBox"
                                                     Height="28"
                                                     VerticalContentAlignment="Center"
                                                     TextChanged="WpfChatSettings_Changed"/>
                                        </StackPanel>
                                    </WrapPanel>
                                </StackPanel>
                                <WrapPanel Grid.Column="1"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center">
                                    <Button x:Name="WpfChatRefreshModelsButton"
                                            Content="Refresh Models"
                                            Click="WpfChatRefreshModelsButton_Click"
                                            Padding="10,4"
                                            Margin="0,0,8,0"/>
                                    <Button x:Name="WpfChatClearButton"
                                            Content="Clear"
                                            Click="WpfChatClearButton_Click"
                                            Padding="10,4"
                                            Margin="0,0,8,0"/>
                                    <CheckBox x:Name="WpfChatTtsCheckBox"
                                              Content="Speak responses"
                                              Checked="WpfChatTtsCheckBox_Changed"
                                              Unchecked="WpfChatTtsCheckBox_Changed"
                                              VerticalAlignment="Center"/>
                                </WrapPanel>
                            </Grid>
                        </Border>

                        <ListBox x:Name="WpfChatListBox"
                                 Grid.Row="1"
                                 Background="#66070A10"
                                 BorderBrush="{StaticResource PanelBorderBrush}"
                                 BorderThickness="1"
                                 Foreground="{StaticResource TextBrush}"
                                 HorizontalContentAlignment="Stretch"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemContainerStyle>
                                                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,0,0,8"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding BackgroundBrush}"
                                            BorderBrush="{Binding BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Header}"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Content}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,6,0,0"/>
                                            <TextBlock Text="{Binding Detail}"
                                                       Foreground="{StaticResource SubtleTextBrush}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,6,0,0"
                                                       Visibility="{Binding DetailVisibility}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Border Grid.Row="2"
                                Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10"
                                Margin="0,10,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <WrapPanel>
                                    <Button x:Name="WpfChatAttachFileButton"
                                            Content="Attach Files"
                                            Click="WpfChatAttachFileButton_Click"
                                            Padding="10,4"
                                            Margin="0,0,8,8"/>
                                    <Button x:Name="WpfChatAttachImageButton"
                                            Content="Attach Images"
                                            Click="WpfChatAttachImageButton_Click"
                                            Padding="10,4"
                                            Margin="0,0,8,8"/>
                                    <CheckBox x:Name="WpfChatRetryCheckBox"
                                              Content="Retry until success"
                                              Checked="WpfChatSettings_Changed"
                                              Unchecked="WpfChatSettings_Changed"
                                              VerticalAlignment="Center"
                                              Margin="0,0,12,8"/>
                                    <Button x:Name="WpfChatResendButton"
                                            Content="Resend"
                                            Click="WpfChatResendButton_Click"
                                            Padding="10,4"
                                            Margin="0,0,8,8"
                                            IsEnabled="False"/>
                                </WrapPanel>
                                <ListBox x:Name="WpfChatAttachmentListBox"
                                         Grid.Row="1"
                                         MaxHeight="76"
                                         Background="#44111924"
                                         BorderBrush="{StaticResource PanelBorderBrush}"
                                         BorderThickness="1"
                                         Foreground="{StaticResource TextBrush}"
                                         HorizontalContentAlignment="Stretch"
                                         Visibility="Collapsed"
                                         Margin="0,0,0,8">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <DockPanel Margin="4">
                                                <Button Content="Remove"
                                                        DockPanel.Dock="Right"
                                                        Tag="{Binding}"
                                                        Click="RemoveWpfChatAttachmentButton_Click"
                                                        Padding="7,2"
                                                        Margin="8,0,0,0"/>
                                                <TextBlock Text="{Binding DisplayLine}"
                                                           TextWrapping="Wrap"
                                                           VerticalAlignment="Center"/>
                                            </DockPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <ListBox x:Name="WpfChatSuggestionListBox"
                                         Grid.Row="2"
                                         MaxHeight="110"
                                         Background="#DD070A10"
                                         BorderBrush="{StaticResource AccentBrush}"
                                         BorderThickness="1"
                                         Foreground="{StaticResource TextBrush}"
                                         DisplayMemberPath="DisplayLine"
                                         MouseDoubleClick="WpfChatSuggestionListBox_MouseDoubleClick"
                                         KeyDown="WpfChatSuggestionListBox_KeyDown"
                                         Visibility="Collapsed"
                                         Margin="0,0,0,8"/>
                                <Grid Grid.Row="3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="WpfChatVoiceButton"
                                            Content="Dictate"
                                            Click="WpfChatVoiceButton_Click"
                                            Padding="12,8"
                                            MinWidth="82"
                                            Margin="0,0,10,0"
                                            ToolTip="Use Windows speech recognition to dictate into the prompt."/>
                                    <TextBox x:Name="WpfChatPromptTextBox"
                                             Grid.Column="1"
                                             MinHeight="74"
                                             MaxHeight="150"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             KeyDown="WpfChatPromptTextBox_KeyDown"
                                             TextChanged="WpfChatPromptTextBox_TextChanged"
                                             VerticalContentAlignment="Top"
                                             Padding="10"
                                             ToolTip="Press Enter to send. Press Shift+Enter for a new line.">
                                        <TextBox.Effect>
                                            <DropShadowEffect Color="#38BDF8"
                                                              BlurRadius="0"
                                                              ShadowDepth="0"
                                                              Opacity="0"/>
                                        </TextBox.Effect>
                                    </TextBox>
                                    <Button x:Name="WpfChatSendButton"
                                            Grid.Column="2"
                                            Content="Send"
                                            Click="WpfChatSendButton_Click"
                                            Padding="18,8"
                                            MinWidth="92"
                                            Margin="10,0,0,0"
                                            Background="#1F7A68"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem x:Name="CopilotFilesTab" Header="Copilot Files" Visibility="Collapsed">
                    <Grid Margin="14,12,14,14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="#55EAF5FF"
                                BorderBrush="#66FFFFFF"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Copilot Remote Files"
                                               FontSize="20"
                                               FontWeight="SemiBold"/>
                                    <TextBlock x:Name="CopilotDuplicatorStatusText"
                                               Text="Port 11433 mirrors remote session files into the local clone folder as Visual Studio Copilot asks for them."
                                               Foreground="{StaticResource SubtleTextBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0"/>
                                    <TextBlock x:Name="RemoteCloneRootText"
                                               Foreground="{StaticResource SubtleTextBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                                <WrapPanel Grid.Column="1"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center">
                                    <Button x:Name="RefreshRemoteClonesButton"
                                            Content="Refresh"
                                            Click="RefreshRemoteClonesButton_Click"
                                            Padding="10,4"
                                            Margin="0,0,8,8"/>
                                    <Button x:Name="OpenRemoteCloneFolderButton"
                                            Content="Open Folder"
                                            Click="OpenRemoteCloneFolderButton_Click"
                                            Padding="10,4"
                                            Margin="0,0,8,8"/>
                                    <Button x:Name="CancelSelectedRemoteClonesButton"
                                            Content="Cancel Selected"
                                            Click="CancelSelectedRemoteClonesButton_Click"
                                            Padding="10,4"
                                            Margin="0,0,8,8"/>
                                    <Button x:Name="CancelAllRemoteClonesButton"
                                            Content="Cancel All"
                                            Click="CancelAllRemoteClonesButton_Click"
                                            Padding="10,4"
                                            Margin="0,0,8,8"/>
                                    <Button x:Name="ClearCompletedRemoteClonesButton"
                                            Content="Clear Done"
                                            Click="ClearCompletedRemoteClonesButton_Click"
                                            Padding="10,4"
                                            Margin="0,0,0,8"/>
                                </WrapPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1"
                                Background="#EE101722"
                                BorderBrush="#66FFFFFF"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="1">
                            <ListView x:Name="RemoteCloneListView"
                                      Background="#DDF7FBFF"
                                      BorderThickness="0"
                                      Foreground="#101820"
                                      SelectionMode="Extended"
                                      HorizontalContentAlignment="Stretch"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      PreviewMouseLeftButtonDown="RemoteCloneListView_PreviewMouseLeftButtonDown"
                                      PreviewMouseMove="RemoteCloneListView_PreviewMouseMove"
                                      PreviewMouseLeftButtonUp="RemoteCloneListView_PreviewMouseLeftButtonUp"
                                      SelectionChanged="RemoteCloneListView_SelectionChanged">
                                <ListView.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Open" Click="OpenRemoteCloneFileMenuItem_Click"/>
                                        <MenuItem Header="Open Containing Folder" Click="OpenRemoteCloneContainingFolderMenuItem_Click"/>
                                        <Separator/>
                                        <MenuItem Header="Cancel" Click="CancelRemoteCloneMenuItem_Click"/>
                                        <MenuItem Header="Clear Completed" Click="ClearCompletedRemoteClonesButton_Click"/>
                                        <Separator/>
                                        <MenuItem Header="Copy Local Path" Click="CopyRemoteCloneLocalPathMenuItem_Click"/>
                                        <MenuItem Header="Copy Remote Path" Click="CopyRemoteCloneRemotePathMenuItem_Click"/>
                                    </ContextMenu>
                                </ListView.ContextMenu>
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem" BasedOn="{StaticResource {x:Type ListViewItem}}">
                                        <Setter Property="Padding" Value="8,5"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#220078D4"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#3378D7FF"/>
                                                <Setter Property="BorderBrush" Value="#AA0078D4"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Width="42" Header="">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Border Width="24"
                                                            Height="18"
                                                            CornerRadius="2"
                                                            Background="{Binding StatusBrush}"
                                                            BorderBrush="#AA768390"
                                                            BorderThickness="1"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Width="220" Header="Name" DisplayMemberBinding="{Binding FileName}"/>
                                        <GridViewColumn Width="118" Header="Status" DisplayMemberBinding="{Binding Status}"/>
                                        <GridViewColumn Width="88" Header="Size" DisplayMemberBinding="{Binding SizeText}"/>
                                        <GridViewColumn Width="160" Header="SHA-256" DisplayMemberBinding="{Binding HashShort}"/>
                                        <GridViewColumn Width="250" Header="Remote" DisplayMemberBinding="{Binding RemotePath}"/>
                                        <GridViewColumn Width="330" Header="Local" DisplayMemberBinding="{Binding LocalPath}"/>
                                        <GridViewColumn Width="150" Header="Updated" DisplayMemberBinding="{Binding UpdatedText}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Border>

                        <TextBlock x:Name="RemoteCloneStatusText"
                                   Grid.Row="2"
                                   Text="No remote files cloned yet."
                                   Foreground="{StaticResource SubtleTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="2,10,0,0"/>
                    </Grid>
                </TabItem>

                <TabItem x:Name="ServersTab" Header="Servers" Visibility="Collapsed" IsEnabled="False">
                    <Grid Margin="14,12,14,14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Servers"
                                               FontSize="20"
                                               FontWeight="SemiBold"/>
                                    <TextBlock x:Name="ServerPickerStatusText"
                                               Text="Refresh the SocketJack server list, filter by hardware/title/owner/IP/model/payment/availability, then route Copilot through a selected peer."
                                               Foreground="{StaticResource SubtleTextBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                                <WrapPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                    <Button x:Name="RefreshServersButton"
                                            Content="Refresh"
                                            Click="RefreshServersButton_Click"
                                            Padding="10,4"
                                            Margin="0,0,8,8"/>
                                    <Button x:Name="UseSelectedServerForCopilotButton"
                                            Content="Use for Copilot"
                                            Click="UseSelectedServerForCopilotButton_Click"
                                            Padding="10,4"
                                            Margin="0,0,8,8"/>
                                    <Button x:Name="UseLocalCopilotServerButton"
                                            Content="Use Local"
                                            Click="UseLocalCopilotServerButton_Click"
                                            Padding="10,4"
                                            Margin="0,0,8,8"/>
                                    <Button x:Name="OpenSelectedServerButton"
                                            Content="Open"
                                            Click="OpenSelectedServerButton_Click"
                                            Padding="10,4"
                                            Margin="0,0,0,8"/>
                                </WrapPanel>

                                <UniformGrid Grid.Row="1"
                                             Grid.ColumnSpan="2"
                                             Columns="4"
                                             Margin="0,10,0,0">
                                    <StackPanel Margin="0,0,8,0">
                                        <TextBlock Text="Hardware" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                        <TextBox x:Name="ServerFilterHardwareTextBox"
                                                 Height="28"
                                                 TextChanged="ServerFilterTextBox_TextChanged"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,8,0">
                                        <TextBlock Text="Title" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                        <TextBox x:Name="ServerFilterTitleTextBox"
                                                 Height="28"
                                                 TextChanged="ServerFilterTextBox_TextChanged"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,8,0">
                                        <TextBlock Text="Owner" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                        <TextBox x:Name="ServerFilterOwnerTextBox"
                                                 Height="28"
                                                 TextChanged="ServerFilterTextBox_TextChanged"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="External IP" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                        <TextBox x:Name="ServerFilterExternalIpTextBox"
                                                 Height="28"
                                                 TextChanged="ServerFilterTextBox_TextChanged"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,8,8,0">
                                        <TextBlock Text="Model" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                        <TextBox x:Name="ServerFilterModelTextBox"
                                                 Height="28"
                                                 TextChanged="ServerFilterTextBox_TextChanged"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,8,8,0">
                                        <TextBlock Text="Availability" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                        <ComboBox x:Name="ServerFilterAvailabilityComboBox"
                                                  Height="28"
                                                  SelectionChanged="ServerFilterComboBox_SelectionChanged">
                                            <ComboBoxItem Content="Any" Tag="any" IsSelected="True"/>
                                            <ComboBoxItem Content="Online" Tag="online"/>
                                            <ComboBoxItem Content="Available" Tag="available"/>
                                            <ComboBoxItem Content="Healthy" Tag="healthy"/>
                                            <ComboBoxItem Content="Watch / At Risk" Tag="watch"/>
                                            <ComboBoxItem Content="Offline" Tag="offline"/>
                                            <ComboBoxItem Content="Suspended / Blocked" Tag="blocked"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Margin="0,8,8,0">
                                        <TextBlock Text="Payment" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                        <ComboBox x:Name="ServerFilterPaymentComboBox"
                                                  Height="28"
                                                  SelectionChanged="ServerFilterComboBox_SelectionChanged">
                                            <ComboBoxItem Content="Any" Tag="any" IsSelected="True"/>
                                            <ComboBoxItem Content="Free" Tag="free"/>
                                            <ComboBoxItem Content="Paid" Tag="paid"/>
                                            <ComboBoxItem Content="Checkout Ready" Tag="checkout"/>
                                            <ComboBoxItem Content="Needs Setup" Tag="needs_setup"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Margin="0,8,0,0">
                                        <TextBlock Text="Max Price" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                        <TextBox x:Name="ServerFilterMaxPriceTextBox"
                                                 Height="28"
                                                 ToolTip="Maximum advertised lease price in USD."
                                                 TextChanged="ServerFilterTextBox_TextChanged"/>
                                    </StackPanel>
                                </UniformGrid>
                            </Grid>
                        </Border>

                        <ListView x:Name="ServerPickerListView"
                                  Grid.Row="1"
                                  Background="#66070A10"
                                  BorderBrush="{StaticResource PanelBorderBrush}"
                                  BorderThickness="1"
                                  Foreground="{StaticResource TextBrush}"
                                  SelectionMode="Single"
                                  HorizontalContentAlignment="Stretch"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  SelectionChanged="ServerPickerListView_SelectionChanged"
                                  MouseDoubleClick="ServerPickerListView_MouseDoubleClick">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem" BasedOn="{StaticResource {x:Type ListViewItem}}">
                                    <Setter Property="Padding" Value="8,5"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#22168AAD"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#3338BDF8"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Width="235" Header="Title" DisplayMemberBinding="{Binding DisplayName}"/>
                                    <GridViewColumn Width="180" Header="Owner" DisplayMemberBinding="{Binding OwnerLine}"/>
                                    <GridViewColumn Width="310" Header="Hardware" DisplayMemberBinding="{Binding CompactResourceLine}"/>
                                    <GridViewColumn Width="250" Header="Model" DisplayMemberBinding="{Binding TopModelLine}"/>
                                    <GridViewColumn Width="230" Header="Payment" DisplayMemberBinding="{Binding LeaseLine}"/>
                                    <GridViewColumn Width="150" Header="Status" DisplayMemberBinding="{Binding StatusLine}"/>
                                    <GridViewColumn Width="360" Header="Endpoint" DisplayMemberBinding="{Binding EndpointLine}"/>
                                    <GridViewColumn Width="520" Header="Information" DisplayMemberBinding="{Binding InformationLine}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <TextBlock x:Name="ServerPickerSelectedText"
                                   Grid.Row="2"
                                   Text="Copilot uses local LM Studio until a remote server is selected."
                                   Foreground="{StaticResource SubtleTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="2,10,0,0"/>
                    </Grid>
                </TabItem>

                <TabItem x:Name="ServerBrowserTab" Header="Rent My PC">
                    <ScrollViewer x:Name="RentMyPcScrollViewer"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto"
                                  CanContentScroll="False"
                                  Padding="14,12,14,14">
                        <Grid MinHeight="{Binding ViewportHeight, ElementName=RentMyPcScrollViewer}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Row="0">
                                    <TextBlock Text="Rent My PC" FontSize="22" FontWeight="SemiBold"/>
                                    <TextBlock Text="Sign in with SocketJack.com, publish this PC through Shell, and keep the master list synced."
                                               Foreground="{StaticResource SubtleTextBrush}"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Margin="0,2,0,0"/>
                                    <TextBlock x:Name="MasterServerStatusText"
                                               Text="Master list refreshes automatically while this tab is visible."
                                               Foreground="{StaticResource SubtleTextBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,6,0,0"/>
                                    <TextBox x:Name="MasterServerTextBox"
                                             Text="https://socketjack.com"
                                             Visibility="Collapsed"/>
                                </StackPanel>
                                <Border x:Name="SocketJackAuthPanel"
                                        Grid.Column="1"
                                        Background="#66101723"
                                        BorderBrush="{StaticResource PanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10"
                                        MinWidth="320"
                                        Margin="14,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="SocketJack.com Login"
                                                   FontWeight="SemiBold"/>
                                        <StackPanel x:Name="SocketJackLoginFormPanel">
                                            <Grid Margin="0,8,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="1*"/>
                                                    <ColumnDefinition Width="1*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="SocketJackUserTextBox"
                                                         Height="30"
                                                         VerticalContentAlignment="Center"
                                                         ToolTip="SocketJack.com username used as the published server owner."/>
                                                <PasswordBox x:Name="SocketJackPasswordBox"
                                                             Grid.Column="1"
                                                             Height="30"
                                                             Margin="8,0,0,0"
                                                             VerticalContentAlignment="Center"
                                                             ToolTip="SocketJack.com password. It is sent to the server for login only and is not saved locally."/>
                                            </Grid>
                                            <StackPanel Orientation="Horizontal"
                                                        Margin="0,8,0,0">
                                                <Button x:Name="SocketJackLoginButton"
                                                        Content="Login"
                                                        Click="SocketJackLoginButton_Click"
                                                        Padding="9,4"
                                                        Margin="0,0,6,0"/>
                                                <Button x:Name="SocketJackRegisterButton"
                                                        Content="Register"
                                                        Click="SocketJackRegisterButton_Click"
                                                        Padding="9,4"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <Border x:Name="SocketJackSignedInPanel"
                                                Visibility="Collapsed"
                                                Margin="0,9,0,0"
                                                Padding="8"
                                                CornerRadius="7"
                                                BorderBrush="{StaticResource ControlBorderBrush}"
                                                BorderThickness="1"
                                                Background="#66111D2A">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border x:Name="SocketJackAuthStatusDot"
                                                        Width="10"
                                                        Height="10"
                                                        CornerRadius="5"
                                                        Background="{StaticResource WarningBrush}"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,8,0"/>
                                                <StackPanel Grid.Column="1"
                                                            VerticalAlignment="Center"
                                                            Margin="0,0,10,0">
                                                    <TextBlock x:Name="SocketJackSignedInUserText"
                                                               Text="SocketJack user"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock x:Name="SocketJackSignedInDetailText"
                                                               Text="Session status"
                                                               Foreground="{StaticResource SubtleTextBrush}"
                                                               FontSize="11"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <Button x:Name="SocketJackLogoutButton"
                                                        Grid.Column="2"
                                                        Content="Logout"
                                                        Click="SocketJackLogoutButton_Click"
                                                        Padding="9,4"
                                                        VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <TextBlock x:Name="SocketJackAuthStatusText"
                                                   Text="Sign in before publishing."
                                                   Foreground="{StaticResource SubtleTextBrush}"
                                                   FontSize="11"
                                                   TextWrapping="Wrap"
                                                   Margin="0,7,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <TextBox x:Name="BrowseServerEndpointTextBox"
                                     Grid.Row="1"
                                     Text="127.0.0.1:11436"
                                     Visibility="Collapsed"/>
                             <ListBox x:Name="ServerBrowserListBox"
                                      Grid.Row="1"
                                      Visibility="Collapsed"
                                      DisplayMemberPath="DisplayName"
                                      SelectionChanged="ServerBrowserListBox_SelectionChanged"/>
                            <ListBox x:Name="ShellInstancesListBox"
                                     Grid.Row="1"
                                     Visibility="Collapsed"
                                     SelectionChanged="ShellInstancesListBox_SelectionChanged"/>

                            <Border Grid.Row="1"
                                    Background="{StaticResource PanelBrush}"
                                    BorderBrush="{StaticResource PanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10"
                                    Margin="0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="My Listing"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="Define the single listing for this PC: model, context, tools, GPU usage, payment, and Shell routing."
                                                       Foreground="{StaticResource SubtleTextBrush}"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"
                                                       Margin="0,3,16,0"/>
                                            <TextBlock x:Name="HostPublicIpStatusText"
                                                       Text="External IP fills automatically when blank."
                                                       Foreground="{StaticResource SubtleTextBrush}"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"
                                                       Margin="0,4,16,0"/>
                                            <TextBlock x:Name="ServerBrowserStatusText"
                                                       Text="My listing is ready."
                                                       Foreground="{StaticResource SubtleTextBrush}"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"
                                                       Margin="0,4,16,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1"
                                                    VerticalAlignment="Top"
                                                    HorizontalAlignment="Right">
                                            <Button x:Name="DetectPublicIpButton"
                                                    Content="Detect IP"
                                                    Click="DetectPublicIpButton_Click"
                                                    Padding="9,4"
                                                    Margin="0,0,8,0" Visibility="Collapsed"/>
                                            <ToggleButton x:Name="PublishedToggleButton"
                                                          Content="Unlisted"
                                                          Checked="PublishedToggleButton_Changed"
                                                          Unchecked="PublishedToggleButton_Changed"
                                                          Padding="9,4"
                                                          HorizontalAlignment="Right"
                                                          Background="#1F7A68"/>
                                            <Border x:Name="AutoPublishHighlightBorder"
                                                    Margin="0,8,0,0"
                                                    Padding="6,4"
                                                    BorderThickness="1"
                                                    BorderBrush="#006FF2D1"
                                                    CornerRadius="6"
                                                    HorizontalAlignment="Right"
                                                    RenderTransformOrigin="0.5,0.5">
                                                <Border.RenderTransform>
                                                    <ScaleTransform/>
                                                </Border.RenderTransform>
                                                <Border.Effect>
                                                    <DropShadowEffect Color="#6FF2D1"
                                                                      BlurRadius="18"
                                                                      ShadowDepth="0"
                                                                      Opacity="0"/>
                                                </Border.Effect>
                                                <CheckBox x:Name="AutoPublishCheckBox"
                                                          Content="Auto-Publish"
                                                          IsChecked="True"
                                                          Checked="AutoPublishCheckBox_Changed"
                                                          Unchecked="AutoPublishCheckBox_Changed"
                                                          ToolTip="Automatically publish this PC when JackLLM Workstation starts."
                                                          FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Grid.Row="2"
                                          Margin="0,10,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="0.95*"/>
                                            <ColumnDefinition Width="1.05*"/>
                                        </Grid.ColumnDefinitions>

                                    <GroupBox Grid.Column="0"
                                              Header="Connection"
                                              Margin="0,0,10,0">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <StackPanel Grid.Row="0">
                                                <TextBlock x:Name="ShellForwardValidationText"
                                                           Text="SocketJack Shell"
                                                           FontSize="17"
                                                           FontWeight="SemiBold"
                                                           Foreground="LimeGreen"/>
                                                <TextBlock x:Name="ShellForwardValidationDetailText"
                                                           Text="Published listings use SocketJack Shell automatically."
                                                           Foreground="{StaticResource SubtleTextBrush}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,4,0,0"/>
                                                <TextBlock x:Name="ShellSuggestionText"
                                                           Text="Start the proxy to publish; stop the proxy to remove it from the master list."
                                                           Foreground="{StaticResource SubtleTextBrush}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,6,0,0"/>
                                            </StackPanel>

                                            <GroupBox Grid.Row="1"
                                                      Header="Agent"
                                                      Padding="8,10,8,8"
                                                      Margin="0,10,0,0">
                                                <Border x:Name="ShellEnablePromptBorder"
                                                        Background="#66101723"
                                                        BorderBrush="#668EE6C9"
                                                        BorderThickness="1"
                                                        CornerRadius="8"
                                                        Padding="10"
                                                        RenderTransformOrigin="0.5,0.5">
                                                    <Border.RenderTransform>
                                                        <ScaleTransform/>
                                                    </Border.RenderTransform>
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="#5DFF9B"
                                                                          BlurRadius="18"
                                                                          ShadowDepth="0"
                                                                          Opacity="0"/>
                                                    </Border.Effect>
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <CheckBox x:Name="ShellEnabledCheckBox"
                                                              Content="Shell publishing"
                                                              Checked="ShellEnabledCheckBox_Changed"
                                                              Unchecked="ShellEnabledCheckBox_Changed"
                                                              FontWeight="SemiBold"
                                                              VerticalAlignment="Center"
                                                              Margin="0,0,12,0"
                                                              Visibility="Collapsed"/>
                                                    <CheckBox x:Name="ShellWebSocketTunnelCheckBox"
                                                              Content="WebSocket tunnel"
                                                              IsChecked="True"
                                                              Checked="ShellWebSocketTunnelCheckBox_Changed"
                                                              Unchecked="ShellWebSocketTunnelCheckBox_Changed"
                                                              FontWeight="SemiBold"
                                                              VerticalAlignment="Center"
                                                              Margin="0,0,12,0"
                                                              ToolTip="Use one persistent WebSocket transport for the public proxy; TCP agents remain as fallback."/>
                                                    <Button Grid.Column="1"
                                                            Content="Routes"
                                                            Click="RefreshShellInstancesButton_Click"
                                                            Padding="9,4"/>

                                                    <Grid Grid.Row="1"
                                                          Grid.ColumnSpan="2"
                                                          Margin="0,10,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="120"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox x:Name="ShellMasterServerTextBox"
                                                                 Height="28"
                                                                 Text="https://socketjack.com"
                                                                 TextChanged="ShellConfiguration_TextChanged"
                                                                 VerticalContentAlignment="Center"
                                                                 Visibility="Collapsed"/>
                                                        <StackPanel Grid.Column="0"
                                                                    Margin="0,0,8,0">
                                                            <TextBlock Text="Fallback agents" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                                            <TextBox x:Name="ShellAgentPoolTextBox"
                                                                     Height="42"
                                                                     Text="8"
                                                                     TextChanged="ShellConfiguration_TextChanged"
                                                                     VerticalContentAlignment="Center"
                                                                     ToolTip="Warm reverse TCP connections used only when the WebSocket tunnel is unavailable."/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="Local API" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                                            <TextBox x:Name="ShellLocalApiTextBox"
                                                                     Height="42"
                                                                     IsReadOnly="True"
                                                                     Text="127.0.0.1:11436"
                                                             FontFamily="Consolas"
                                                             VerticalContentAlignment="Center"/>
                                                        </StackPanel>
                                                    </Grid>

                                                    <StackPanel Grid.Row="2"
                                                                Grid.ColumnSpan="2"
                                                                Margin="0,8,0,0">
                                                        <TextBlock Text="Published title" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                                        <TextBox x:Name="ShellPublishedTitleTextBox"
                                                                 Height="42"
                                                                 IsReadOnly="True"
                                                                 VerticalContentAlignment="Center"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Row="3"
                                                                Grid.ColumnSpan="2"
                                                                Margin="0,8,0,0">
                                                        <TextBlock Text="Proxy URL" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                                        <TextBox x:Name="ShellProxyUrlPreviewTextBox"
                                                                 Height="42"
                                                                 IsReadOnly="True"
                                                                 FontFamily="Consolas"
                                                                 VerticalContentAlignment="Center"/>
                                                    </StackPanel>

                                                    <TextBox x:Name="ShellDebugTextBox"
                                                             Grid.Row="4"
                                                             Grid.ColumnSpan="2"
                                                             Height="80"
                                                             Margin="0,8,0,0"
                                                             Background="#070A10"
                                                             BorderThickness="0"
                                                             FontFamily="Consolas"
                                                             FontSize="12"
                                                             IsReadOnly="True"
                                                             AcceptsReturn="True"
                                                             TextWrapping="Wrap"
                                                             VerticalScrollBarVisibility="Auto"
                                                             Foreground="#A8FFFFFF"/>
                                                </Grid>
                                                </Border>
                                            </GroupBox>

                                            <TextBlock x:Name="ShellStatusText"
                                                       Grid.Row="2"
                                                       Text="Shell disabled."
                                                       Foreground="{StaticResource SubtleTextBrush}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,8,0,0"/>
                                        </Grid>
                                    </GroupBox>

                                        <Border Grid.Column="1"
                                                Background="#66070A10"
                                                BorderBrush="{StaticResource PanelBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="9"
                                                Margin="10,0,0,0">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>
                                                <DockPanel>
                                                    <Button Content="Refresh"
                                                            DockPanel.Dock="Right"
                                                            Click="RefreshMasterServerButton_Click"
                                                            Padding="9,4"/>
                                                    <TextBlock Text="My Listings"
                                                               FontSize="15"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center"/>
                                                </DockPanel>
                                                <ListBox x:Name="MyListingsListBox"
                                                         Grid.Row="1"
                                                         SelectionChanged="MyListingsListBox_SelectionChanged"
                                                         Margin="0,8,0,0"
                                                         MinHeight="270"
                                                         Background="#33070A10"
                                                         BorderBrush="{StaticResource PanelBorderBrush}"
                                                         BorderThickness="1"
                                                         Foreground="{StaticResource TextBrush}"
                                                         HorizontalContentAlignment="Stretch"
                                                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                                                    <ListBox.ItemContainerStyle>
                                                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                                            <Setter Property="Padding" Value="0"/>
                                                            <Setter Property="Margin" Value="0,0,0,7"/>
                                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                        </Style>
                                                    </ListBox.ItemContainerStyle>
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#88111924"
                                                                    BorderBrush="#334E5E74"
                                                                    BorderThickness="1"
                                                                    CornerRadius="6"
                                                                    Padding="8">
                                                                <Grid>
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                    </Grid.RowDefinitions>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>

                                                                    <StackPanel>
                                                                        <TextBlock Text="{Binding DisplayName}"
                                                                                   FontWeight="SemiBold"
                                                                                   TextWrapping="Wrap"/>
                                                                        <TextBlock Text="{Binding OwnerLine}"
                                                                                   Foreground="{StaticResource SubtleTextBrush}"
                                                                                   FontSize="11"
                                                                                   TextWrapping="Wrap"
                                                                                   Margin="0,2,0,0"/>
                                                                        <TextBlock Text="{Binding TopModelLine}"
                                                                                   Foreground="{StaticResource SubtleTextBrush}"
                                                                                   FontSize="11"
                                                                                   TextWrapping="Wrap"
                                                                                   Margin="0,2,0,0"/>
                                                                    </StackPanel>
                                                                    <Button Grid.Column="1"
                                                                            Content="Delete"
                                                                            Click="DeleteHostButton_Click"
                                                                            Padding="8,3"
                                                                            Margin="8,0,0,0"
                                                                            VerticalAlignment="Top"/>

                                                                    <WrapPanel Grid.Row="1"
                                                                               Grid.ColumnSpan="2"
                                                                               Margin="0,7,0,0">
                                                                        <Border Background="#3326C99B" BorderBrush="#6640E0B0" BorderThickness="1" CornerRadius="8" Padding="6,3" Margin="0,0,5,5">
                                                                            <TextBlock Text="{Binding ModelCountLine}" FontFamily="Consolas" FontSize="11"/>
                                                                        </Border>
                                                                        <Border Background="#332E8CEB" BorderBrush="#665CA8FF" BorderThickness="1" CornerRadius="8" Padding="6,3" Margin="0,0,5,5">
                                                                            <TextBlock Text="{Binding ToolsSupportLine}" FontFamily="Consolas" FontSize="11"/>
                                                                        </Border>
                                                                        <Border Background="#33F59E0B" BorderBrush="#66FDBA4D" BorderThickness="1" CornerRadius="8" Padding="6,3" Margin="0,0,5,5">
                                                                            <TextBlock Text="{Binding ImageSupportLine}" FontFamily="Consolas" FontSize="11"/>
                                                                        </Border>
                                                                        <Border Background="#3338BDF8" BorderBrush="#667DD3FC" BorderThickness="1" CornerRadius="8" Padding="6,3" Margin="0,0,5,5">
                                                                            <TextBlock Text="{Binding TokenCostLine}" FontFamily="Consolas" FontSize="11"/>
                                                                        </Border>
                                                                        <Border Background="#3326C99B" BorderBrush="#6640E0B0" BorderThickness="1" CornerRadius="8" Padding="6,3" Margin="0,0,5,5">
                                                                            <TextBlock Text="{Binding StatusLine}" FontFamily="Consolas" FontSize="11"/>
                                                                        </Border>
                                                                        <Border Background="#332E8CEB" BorderBrush="#665CA8FF" BorderThickness="1" CornerRadius="8" Padding="6,3" Margin="0,0,5,5">
                                                                            <TextBlock Text="{Binding UptimeLine}" FontFamily="Consolas" FontSize="11"/>
                                                                        </Border>
                                                                    </WrapPanel>

                                                                    <Expander Grid.Row="2"
                                                                              Grid.ColumnSpan="2"
                                                                              Header="{Binding CompactResourceLine}"
                                                                              IsExpanded="{Binding OptionsExpanded, Mode=TwoWay}"
                                                                              Margin="0,2,0,0"
                                                                              Foreground="{StaticResource TextBrush}">
                                                                        <StackPanel Margin="0,6,0,0">
                                                                            <TextBlock Text="{Binding EndpointLine}" Foreground="{StaticResource SubtleTextBrush}" FontSize="11" TextWrapping="Wrap"/>
                                                                            <TextBlock Text="{Binding ResourceLine}" Foreground="{StaticResource SubtleTextBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                                                            <TextBlock Text="{Binding ModelLine}" Foreground="{StaticResource SubtleTextBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                                                            <TextBlock Text="{Binding PaymentLine}" Foreground="{StaticResource SubtleTextBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                                                            <CheckBox Content="Publish on master list"
                                                                                      IsChecked="{Binding PublishEnabled, Mode=TwoWay}"
                                                                                      Checked="ServerBrowserPublishEnabled_Changed"
                                                                                      Unchecked="ServerBrowserPublishEnabled_Changed"
                                                                                      Margin="0,7,0,0"
                                                                                      Visibility="Collapsed"/>
                                                                        </StackPanel>
                                                                    </Expander>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </Grid>
                                        </Border>
                                    </Grid>

                                    <UniformGrid Grid.Row="1"
                                                 Columns="4"
                                                 Margin="0,10,0,8">
                                        <Border Background="#66101723" BorderBrush="#334E5E74" BorderThickness="1" CornerRadius="7" Padding="8" Margin="0,0,0,6">
                                            <StackPanel>
                                                <TextBlock Text="Listing Title" Foreground="{StaticResource SubtleTextBrush}" FontSize="10"/>
                                                <TextBox x:Name="HostServerNameTextBox"
                                                         FontWeight="SemiBold"
                                                         MinHeight="28"
                                                         Padding="6,3"
                                                         Margin="0,4,0,0"
                                                         Background="#AA0D1B28"
                                                         BorderBrush="#668EE6C9"
                                                         BorderThickness="1"
                                                         Foreground="{StaticResource TextBrush}"
                                                         CaretBrush="{StaticResource AccentBrush}"
                                                         TextChanged="HostProfileTextBox_TextChanged"
                                                         ToolTip="Editable title shown in the public server browser."/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#66101723" BorderBrush="#334E5E74" BorderThickness="1" CornerRadius="7" Padding="8" Margin="0,0,6,6">
                                            <StackPanel>
                                                <TextBlock Text="Public Host" Foreground="{StaticResource SubtleTextBrush}" FontSize="10"/>
                                                <TextBlock x:Name="HostPublicHostTextBox" TextTrimming="CharacterEllipsis" FontFamily="Consolas" Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#66101723" BorderBrush="#334E5E74" BorderThickness="1" CornerRadius="7" Padding="8" Margin="0,0,6,6">
                                            <StackPanel>
                                                <Grid>
                                                    <TextBlock Text="Cost Factor" Foreground="{StaticResource SubtleTextBrush}" FontSize="10"/>
                                                    <TextBlock x:Name="HostCostFactorText"
                                                               Text="1.0x"
                                                               Foreground="{StaticResource TextBrush}"
                                                               FontFamily="Consolas"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Right"/>
                                                </Grid>
                                                <Slider x:Name="HostCostFactorSlider"
                                                        Minimum="1"
                                                        Maximum="5"
                                                        Value="1"
                                                        TickFrequency="0.1"
                                                        IsSnapToTickEnabled="True"
                                                        Margin="0,4,0,0"
                                                        ValueChanged="HostCostFactorSlider_Changed"
                                                        ToolTip="Published multiplier used for this rent listing."/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#66101723" BorderBrush="#334E5E74" BorderThickness="1" CornerRadius="7" Padding="8" Margin="0,0,0,6">
                                            <StackPanel>
                                                <Grid>
                                                    <TextBlock Text="Throughput" Foreground="{StaticResource SubtleTextBrush}" FontSize="10"/>
                                                    <TextBlock x:Name="HostThroughputText"
                                                               Text="Unlimited"
                                                               Foreground="{StaticResource TextBrush}"
                                                               FontFamily="Consolas"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Right"/>
                                                </Grid>
                                                <Slider x:Name="HostThroughputSlider"
                                                        Minimum="1"
                                                        Maximum="241"
                                                        Value="241"
                                                        TickFrequency="1"
                                                        SmallChange="1"
                                                        LargeChange="10"
                                                        IsSnapToTickEnabled="True"
                                                        Margin="0,4,0,0"
                                                        ValueChanged="HostThroughputSlider_Changed"
                                                        ToolTip="Caps response throughput per client on the JackLLM Workstation server. Move the slider to the maximum value for unlimited Tok/sec."/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#66101723" BorderBrush="#334E5E74" BorderThickness="1" CornerRadius="7" Padding="8" Margin="0,0,6,6">
                                            <StackPanel>
                                                <TextBlock Text="GPU" Foreground="{StaticResource SubtleTextBrush}" FontSize="10"/>
                                                <TextBlock x:Name="HostGpuNameTextBox" TextTrimming="CharacterEllipsis" Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#66101723" BorderBrush="#334E5E74" BorderThickness="1" CornerRadius="7" Padding="8" Margin="0,0,6,6">
                                            <StackPanel>
                                                <TextBlock Text="VRAM / GPU Use" Foreground="{StaticResource SubtleTextBrush}" FontSize="10"/>
                                                <TextBlock x:Name="HostGpuAvailableTextBox" TextTrimming="CharacterEllipsis" Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#66101723" BorderBrush="#334E5E74" BorderThickness="1" CornerRadius="7" Padding="8" Margin="0,0,6,6">
                                            <StackPanel>
                                                <TextBlock Text="CPU" Foreground="{StaticResource SubtleTextBrush}" FontSize="10"/>
                                                <TextBlock x:Name="HostCpuNameTextBox" TextTrimming="CharacterEllipsis" Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#66101723" BorderBrush="#334E5E74" BorderThickness="1" CornerRadius="7" Padding="8" Margin="0,0,0,6">
                                            <StackPanel>
                                                <TextBlock Text="CPU / RAM" Foreground="{StaticResource SubtleTextBrush}" FontSize="10"/>
                                                <TextBlock x:Name="HostCpuAvailableTextBox" Visibility="Collapsed"/>
                                                <TextBlock x:Name="HostRamAvailableTextBox" TextTrimming="CharacterEllipsis" Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#66101723" BorderBrush="#334E5E74" BorderThickness="1" CornerRadius="7" Padding="8" Margin="0,0,6,0">
                                            <StackPanel>
                                                <TextBlock Text="Storage" Foreground="{StaticResource SubtleTextBrush}" FontSize="10"/>
                                                <TextBlock x:Name="HostStorageAvailableTextBox" TextTrimming="CharacterEllipsis" Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#66101723" BorderBrush="#334E5E74" BorderThickness="1" CornerRadius="7" Padding="8" Margin="0,0,6,0">
                                            <StackPanel>
                                                <Grid>
                                                    <TextBlock Text="Session Storage" Foreground="{StaticResource SubtleTextBrush}" FontSize="10"/>
                                                    <TextBlock x:Name="HostStorageLimitText"
                                                               Text="1.5 GB"
                                                               Foreground="{StaticResource TextBrush}"
                                                               FontFamily="Consolas"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Right"/>
                                                </Grid>
                                                <Slider x:Name="HostStorageLimitSlider"
                                                        Minimum="100"
                                                        Maximum="102400"
                                                        Value="1536"
                                                        TickFrequency="100"
                                                        SmallChange="100"
                                                        LargeChange="1024"
                                                        IsSnapToTickEnabled="True"
                                                        Margin="0,4,0,0"
                                                        ValueChanged="HostStorageLimitSlider_Changed"
                                                        ToolTip="Per-session storage cap advertised for renters."/>
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>

                                    <Grid Grid.Row="3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.2*"/>
                                            <ColumnDefinition Width="0.8*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Grid.ColumnSpan="2"
                                                Background="#66070A10"
                                                BorderBrush="{StaticResource PanelBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="9"
                                                Margin="0">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Text="Usage Defined In LM Studio"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Grid.Row="1"
                                                           Text="LM Studio owns model limits; JackLLM Workstation advertises the current PC profile."
                                                           Foreground="{StaticResource SubtleTextBrush}"
                                                           FontSize="11"
                                                           TextWrapping="Wrap"
                                                           Margin="0,3,0,5"/>
                                                <TextBlock x:Name="HostAvailableResourcesTextBox"
                                                           Grid.Row="2"
                                                           Foreground="{StaticResource TextBrush}"
                                                           FontFamily="Consolas"
                                                           FontSize="11"
                                                           TextWrapping="Wrap"
                                                           MaxHeight="48"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="0,0,0,5"/>
                                                <Grid Grid.Row="3">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox x:Name="HostRequiresPaymentCheckBox"
                                                              Content="Requires payment"
                                                              Checked="HostRequiresPaymentCheckBox_Changed"
                                                              Unchecked="HostRequiresPaymentCheckBox_Changed"
                                                              VerticalAlignment="Center"
                                                              Margin="0,0,12,0"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="Currency"
                                                               Foreground="{StaticResource SubtleTextBrush}"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Right"
                                                               Margin="0,0,8,0"/>
                                                    <TextBlock x:Name="HostStripeCurrencyTextBox"
                                                               Grid.Column="2"
                                                               Text="usd"
                                                               FontFamily="Consolas"
                                                               VerticalAlignment="Center"/>
                                                </Grid>
                                                <Border Grid.Row="4"
                                                        Background="#66101723"
                                                        BorderBrush="#334E5E74"
                                                        BorderThickness="1"
                                                        CornerRadius="7"
                                                        Padding="10"
                                                        Margin="0,10,0,0">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="Token Cost Preview" FontWeight="SemiBold"/>
                                                            <TextBlock x:Name="HostTokenCostStatusText"
                                                                       Grid.Column="1"
                                                                       Foreground="{StaticResource SubtleTextBrush}"
                                                                       FontSize="11"
                                                                       Margin="10,0,0,0"/>
                                                        </Grid>
                                                        <UniformGrid Grid.Row="1"
                                                                     Columns="3"
                                                                     Margin="0,9,0,0">
                                                            <Border Background="#55141F2D" BorderBrush="#334E5E74" BorderThickness="1" CornerRadius="6" Padding="9" Margin="0,0,6,0">
                                                                <StackPanel>
                                                                    <TextBlock Text="Quick Fix" Foreground="{StaticResource SubtleTextBrush}" FontSize="10"/>
                                                                    <TextBlock x:Name="HostTokenCostSmallText" FontFamily="Consolas" FontWeight="SemiBold" Margin="0,2,0,0"/>
                                                                </StackPanel>
                                                            </Border>
                                                            <Border Background="#55141F2D" BorderBrush="#334E5E74" BorderThickness="1" CornerRadius="6" Padding="9" Margin="0,0,6,0">
                                                                <StackPanel>
                                                                    <TextBlock Text="Agent Run" Foreground="{StaticResource SubtleTextBrush}" FontSize="10"/>
                                                                    <TextBlock x:Name="HostTokenCostMediumText" FontFamily="Consolas" FontWeight="SemiBold" Margin="0,2,0,0"/>
                                                                </StackPanel>
                                                            </Border>
                                                            <Border Background="#55141F2D" BorderBrush="#334E5E74" BorderThickness="1" CornerRadius="6" Padding="9">
                                                                <StackPanel>
                                                                    <TextBlock Text="Long Session" Foreground="{StaticResource SubtleTextBrush}" FontSize="10"/>
                                                                    <TextBlock x:Name="HostTokenCostLargeText" FontFamily="Consolas" FontWeight="SemiBold" Margin="0,2,0,0"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </UniformGrid>
                                                        <TextBlock x:Name="HostTokenCostRateText"
                                                                   Grid.Row="2"
                                                                   Foreground="{StaticResource SubtleTextBrush}"
                                                                   FontSize="12"
                                                                   TextWrapping="Wrap"
                                                                   Margin="0,8,0,0"/>
                                                    </Grid>
                                                </Border>
                                                <TextBlock x:Name="HostStripePriceIdTextBox" Visibility="Collapsed"/>
                                                <TextBlock x:Name="HostStripeAccountTextBox" Visibility="Collapsed"/>
                                                <TextBlock x:Name="HostStripeUnitAmountTextBox" Text="0" Visibility="Collapsed"/>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem x:Name="ModelsTabItem"
                         Header="Models">
                    <Grid Background="#101216">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="#66101723"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="9"
                                Margin="14,12,14,8"
