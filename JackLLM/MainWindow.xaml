                                                 Grid.Row="2"
                                                 Background="#66070A10"
                                                 BorderBrush="{StaticResource PanelBorderBrush}"
                                                 BorderThickness="1"
                                                 Foreground="{StaticResource TextBrush}"
                                                 HorizontalContentAlignment="Stretch"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                 SelectionChanged="TrustAbuseCasesListBox_SelectionChanged">
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                                    <Setter Property="Padding" Value="0"/>
                                                    <Setter Property="Margin" Value="0,0,0,8"/>
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#99111924"
                                                            BorderBrush="#334E5E74"
                                                            BorderThickness="1"
                                                            CornerRadius="7"
                                                            Padding="10">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding TitleLine}"
                                                                       FontWeight="SemiBold"
                                                                       TextWrapping="Wrap"/>
                                                            <TextBlock Text="{Binding SubjectLine}"
                                                                       Foreground="{StaticResource SubtleTextBrush}"
                                                                       TextWrapping="Wrap"
                                                                       Margin="0,5,0,0"/>
                                                            <TextBlock Text="{Binding DetailLine}"
                                                                       Foreground="{StaticResource SubtleTextBrush}"
                                                                       TextWrapping="Wrap"
                                                                       Margin="0,3,0,0"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="1"
                                        Background="{StaticResource PanelBrush}"
                                        BorderBrush="{StaticResource PanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="12">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="Open Case"
                                                   FontSize="17"
                                                   FontWeight="SemiBold"/>
                                        <UniformGrid Grid.Row="1" Columns="2" Margin="0,10,0,0">
                                            <StackPanel Margin="0,0,8,8">
                                                <TextBlock Text="Category" Foreground="{StaticResource SubtleTextBrush}"/>
                                                <ComboBox x:Name="TrustCategoryComboBox" SelectedIndex="0" Height="30">
                                                    <ComboBoxItem Content="Dispute" Tag="dispute"/>
                                                    <ComboBoxItem Content="Host verification" Tag="host_verification"/>
                                                    <ComboBoxItem Content="Renter identity" Tag="renter_identity"/>
                                                    <ComboBoxItem Content="Content abuse" Tag="content_abuse"/>
                                                    <ComboBoxItem Content="Command abuse" Tag="command_abuse"/>
                                                    <ComboBoxItem Content="Reputation" Tag="reputation"/>
                                                </ComboBox>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,0,8">
                                                <TextBlock Text="Severity" Foreground="{StaticResource SubtleTextBrush}"/>
                                                <ComboBox x:Name="TrustSeverityComboBox" SelectedIndex="1" Height="30">
                                                    <ComboBoxItem Content="Low" Tag="low"/>
                                                    <ComboBoxItem Content="Medium" Tag="medium"/>
                                                    <ComboBoxItem Content="High" Tag="high"/>
                                                    <ComboBoxItem Content="Critical" Tag="critical"/>
                                                </ComboBox>
                                            </StackPanel>
                                        </UniformGrid>
                                        <TextBox x:Name="TrustOwnerKeyTextBox"
                                                 Grid.Row="2"
                                                 Height="30"
                                                 Margin="0,0,0,8"
                                                 VerticalContentAlignment="Center"
                                                 ToolTip="Owner key, for example webauth:username"
                                                 />
                                        <TextBox x:Name="TrustUserNameTextBox"
                                                 Grid.Row="3"
                                                 Height="30"
                                                 Margin="0,0,0,8"
                                                 VerticalContentAlignment="Center"
                                                 ToolTip="Renter or host username"/>
                                        <UniformGrid Grid.Row="4" Columns="2">
                                            <TextBox x:Name="TrustServerIdTextBox"
                                                     Height="30"
                                                     Margin="0,0,8,8"
                                                     VerticalContentAlignment="Center"
                                                     ToolTip="Server id"/>
                                            <TextBox x:Name="TrustExternalIpTextBox"
                                                     Height="30"
                                                     Margin="0,0,0,8"
                                                     VerticalContentAlignment="Center"
                                                     ToolTip="External IP or host"/>
                                        </UniformGrid>
                                        <TextBox x:Name="TrustSummaryTextBox"
                                                 Grid.Row="5"
                                                 Height="30"
                                                 Margin="0,0,0,8"
                                                 VerticalContentAlignment="Center"
                                                 ToolTip="Short case summary"/>
                                        <TextBox x:Name="TrustDetailTextBox"
                                                 Grid.Row="6"
                                                 MinHeight="82"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"
                                                 ToolTip="Evidence, notes, command, or dispute details"/>
                                        <WrapPanel Grid.Row="7" Margin="0,10,0,0">
                                            <Button Content="Open Case"
                                                    Click="CreateTrustCaseButton_Click"
                                                    Padding="9,4"
                                                    Margin="0,0,8,8"/>
                                            <ComboBox x:Name="TrustInterventionComboBox"
                                                      Width="190"
                                                      Height="30"
                                                      SelectedIndex="0"
                                                      Margin="0,0,8,8">
                                                <ComboBoxItem Content="Resolve" Tag="resolve"/>
                                                <ComboBoxItem Content="Dismiss" Tag="dismiss"/>
                                                <ComboBoxItem Content="Verify Host" Tag="verify_host"/>
                                                <ComboBoxItem Content="Request Host Verification" Tag="request_host_verification"/>
                                                <ComboBoxItem Content="Verify Renter" Tag="verify_renter"/>
                                                <ComboBoxItem Content="Suspend Host" Tag="suspend_host"/>
                                                <ComboBoxItem Content="Mute Renter" Tag="mute_renter"/>
                                                <ComboBoxItem Content="Ban Renter" Tag="ban_renter"/>
                                                <ComboBoxItem Content="Block Commands" Tag="block_commands"/>
                                            </ComboBox>
                                            <Button Content="Apply"
                                                    Click="ApplyTrustInterventionButton_Click"
                                                    Padding="9,4"
                                                    Background="#893442"
                                                    Margin="0,0,8,8"/>
                                        </WrapPanel>
                                        <TextBlock x:Name="TrustAbuseStatusText"
                                                   Grid.Row="8"
                                                   Text="No trust action has run."
                                                   Foreground="{StaticResource SubtleTextBrush}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0"/>
                                    </Grid>
                                </Border>
                            </Grid>

                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem x:Name="ServerManagementTab" Header="Server Management">
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto"
                                  CanContentScroll="False"
                                  Padding="14,12,14,14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="0"/>
