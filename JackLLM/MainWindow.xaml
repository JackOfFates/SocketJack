                            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                                <TextBlock Text="Trust &amp; Abuse" FontSize="24" FontWeight="SemiBold"/>
                                <TextBlock Text="Reputation, host verification, renter identity, command controls, dispute records, and admin interventions for peer-rented inference."
