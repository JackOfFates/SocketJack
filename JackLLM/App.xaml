                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboChrome" Property="Background" Value="{StaticResource ControlHoverBrush}"/>
                                <Setter TargetName="ComboChrome" Property="BorderBrush" Value="#80FCA5A5"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboChrome" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="DropArrow" Property="RenderTransform">
