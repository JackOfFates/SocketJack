        <Style x:Key="GlassSliderThumbStyle" TargetType="Thumb">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Grid>
                            <Ellipse x:Name="ThumbHalo"
                                     Fill="#22FF5C7A"
                                     Width="18"
                                     Height="18"/>
                            <Ellipse x:Name="ThumbCore"
                                     Fill="#F1F7FF"
                                     Stroke="{StaticResource AccentBrush}"
                                     StrokeThickness="2"
                                     Width="12"
                                     Height="12"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbHalo" Property="Fill" Value="#44FF5C7A"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbHalo" Property="Fill" Value="#66FF5C7A"/>
                                <Setter TargetName="ThumbCore" Property="Fill" Value="#D9FFFBEB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid MinHeight="24" VerticalAlignment="Center">
                            <Track x:Name="PART_Track"
                                   VerticalAlignment="Center"
                                   IsDirectionReversed="{TemplateBinding IsDirectionReversed}">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource GlassSliderDecreaseButtonStyle}" Command="Slider.DecreaseLarge"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource GlassSliderIncreaseButtonStyle}" Command="Slider.IncreaseLarge"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource GlassSliderThumbStyle}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BandwidthProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Width" Value="9"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Orientation" Value="Vertical"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Background" Value="#55394C65"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="2">
                            <Grid x:Name="PART_Track"
                                  ClipToBounds="True">
                                <Border x:Name="PART_Indicator"
                                        CornerRadius="4"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Bottom"
                                        ClipToBounds="True">
                                    <Border Background="{TemplateBinding Foreground}"
                                            Width="{Binding ActualWidth, ElementName=PART_Track}"
                                            Height="{Binding ActualHeight, ElementName=PART_Track}"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Bottom"
                                            CornerRadius="4"/>
                                </Border>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HealthMeterProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="4"/>
            <Setter Property="MinHeight" Value="4"/>
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Background" Value="#334E5E74"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                SnapsToDevicePixels="True">
                            <Grid x:Name="PART_Track"
                                  ClipToBounds="True">
                                <Border x:Name="PART_Indicator"
                                        CornerRadius="3"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Stretch"
                                        ClipToBounds="True">
                                    <Border Background="{TemplateBinding Foreground}"
                                            Width="{Binding ActualWidth, ElementName=PART_Track}"
                                            Height="{Binding ActualHeight, ElementName=PART_Track}"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Stretch"
                                            CornerRadius="3"/>
                                </Border>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="MinHeight" Value="178"/>
        </Style>
    </Application.Resources>
</Application>
