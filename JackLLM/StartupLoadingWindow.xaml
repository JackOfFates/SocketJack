<Window x:Class="JackLLM.StartupLoadingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="JackLLM Workstation"
        Width="560"
        Height="248"
        MinWidth="520"
        MinHeight="230"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="True"
        Loaded="Window_Loaded"
        Closed="Window_Closed"
        Closing="Window_Closing">
    <Window.Resources>
        <Style x:Key="StartupChromeButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Foreground" Value="#DDEBFF"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                CornerRadius="7"
                                Margin="2">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#55324761"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#8838536E"/>
                                <Setter Property="Foreground" Value="#FFFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="StartupCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource StartupChromeButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#CCFF5C7A"/>
                    <Setter Property="Foreground" Value="#FFFFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#4462768F"
            BorderThickness="1"
            CornerRadius="12"
            SnapsToDevicePixels="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F20A0F16" Offset="0"/>
                <GradientStop Color="#F2131E2C" Offset="0.55"/>
                <GradientStop Color="#F2072021" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="28"
                              ShadowDepth="0"
                              Opacity="0.38"
                              Color="#05080C"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    BorderBrush="#2D72819A"
                    BorderThickness="0,0,0,1"
                    Padding="14,0,6,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Width="11"
                            Height="11"
                            CornerRadius="6"
                            Background="#FF5C7A"
                            VerticalAlignment="Center"
                            Margin="0,0,10,0"/>
                    <TextBlock Grid.Column="1"
                               Text="JackLLM Workstation"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#F1F7FF"
                               VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button x:Name="MinimizeButton"
                                Style="{StaticResource StartupChromeButtonStyle}"
                                Click="MinimizeButton_Click"
                                ToolTip="Minimize">
                            <Path Data="M 4 9 H 14"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.8"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"/>
                        </Button>
                        <Button x:Name="CloseButton"
                                Style="{StaticResource StartupCloseButtonStyle}"
                                Click="CloseButton_Click"
                                ToolTip="Cancel startup">
                            <Path Data="M 5 5 L 13 13 M 13 5 L 5 13"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.7"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="28,22,28,26">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="StatusText"
                           Text="Preparing JackLLM Workstation..."
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="#F7FBFF"
                           TextTrimming="CharacterEllipsis"/>

                <TextBlock x:Name="DetailText"
                           Grid.Row="1"
                           Text="Loading startup services."
                           FontSize="12.5"
                           Foreground="#AFC1D6"
                           Margin="0,8,0,18"
                           TextTrimming="CharacterEllipsis"/>

                <Grid x:Name="ProgressTrack"
                      Grid.Row="2"
                      Height="20"
                      Width="390"
                      HorizontalAlignment="Center"
                      ClipToBounds="True"
                      SizeChanged="ProgressTrack_SizeChanged">
                    <Border CornerRadius="10"
                            Opacity="0.72">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="#35FF3B18" Offset="0"/>
                                <GradientStop Color="#24FFC857" Offset="0.23"/>
                                <GradientStop Color="#2038DFFF" Offset="0.55"/>
                                <GradientStop Color="#2EFF5CF4" Offset="0.84"/>
                                <GradientStop Color="#35FF3B18" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <Border Background="#44111924"
                            BorderBrush="#5A6F819C"
                            BorderThickness="1"
                            CornerRadius="10"/>
                    <Grid x:Name="ProgressFillHost"
                          HorizontalAlignment="Left"
                          Width="0"
                          ClipToBounds="True">
                        <Grid x:Name="ProgressTexture"
                              Height="20"
                              HorizontalAlignment="Left">
                            <Rectangle x:Name="RgbStripe"
                                       Height="20"
                                       RadiusX="10"
                                       RadiusY="10">
                                <Rectangle.Fill>
                                    <LinearGradientBrush x:Name="RgbStripeBrush"
                                                         StartPoint="0,0.5"
                                                         EndPoint="1,0.5"
                                                         SpreadMethod="Reflect">
                                        <GradientStop x:Name="RgbStop0" Color="#FFFF2D1A" Offset="0"/>
                                        <GradientStop x:Name="RgbStop1" Color="#FFFF6A00" Offset="0.10"/>
                                        <GradientStop x:Name="RgbStop2" Color="#FFFFD166" Offset="0.22"/>
                                        <GradientStop x:Name="RgbStop3" Color="#FF4DFF88" Offset="0.36"/>
                                        <GradientStop x:Name="RgbStop4" Color="#FF29DFFF" Offset="0.52"/>
                                        <GradientStop x:Name="RgbStop5" Color="#FF6074FF" Offset="0.67"/>
                                        <GradientStop x:Name="RgbStop6" Color="#FFFF4FEA" Offset="0.82"/>
                                        <GradientStop x:Name="RgbStop7" Color="#FFFF7A25" Offset="0.92"/>
                                        <GradientStop x:Name="RgbStop8" Color="#FFFF2D1A" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <Rectangle x:Name="LavaBloom"
                                       Height="20"
                                       RadiusX="10"
                                       RadiusY="10"
                                       Opacity="0.52">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#A8FFFFFF" Offset="0"/>
                                        <GradientStop Color="#36FFFFFF" Offset="0.34"/>
                                        <GradientStop Color="#00FFFFFF" Offset="0.68"/>
                                        <GradientStop Color="#70FF3B18" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <Rectangle x:Name="LavaSheen"
                                       Height="20"
                                       RadiusX="10"
                                       RadiusY="10"
                                       Opacity="0.45">
                                <Rectangle.Fill>
                                    <LinearGradientBrush x:Name="LavaSheenBrush"
                                                         StartPoint="-0.55,0.5"
                                                         EndPoint="0.2,0.5">
                                        <GradientStop Color="#00FFFFFF" Offset="0"/>
                                        <GradientStop Color="#A8FFFFFF" Offset="0.48"/>
                                        <GradientStop Color="#00FFFFFF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                        </Grid>
                    </Grid>
                    <Border CornerRadius="10"
                            BorderBrush="#66FFFFFF"
                            BorderThickness="1"
                            Background="#18FFFFFF"/>
                </Grid>

                <Grid Grid.Row="3" Margin="0,12,0,0">
                    <TextBlock Text="Startup progress"
                               FontSize="11.5"
                               Foreground="#7F93AB"/>
                    <TextBlock x:Name="PercentText"
                               Text="0%"
                               FontSize="11.5"
                               FontWeight="SemiBold"
                               Foreground="#CFE3FF"
                               HorizontalAlignment="Right"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
