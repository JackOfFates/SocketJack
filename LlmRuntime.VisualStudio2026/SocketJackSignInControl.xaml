<DataTemplate xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:styles="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
              xmlns:colors="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0">
  <Border Background="{DynamicResource {x:Static colors:EnvironmentColors.ToolWindowBackgroundBrushKey}}"
          TextElement.Foreground="{DynamicResource {x:Static colors:EnvironmentColors.ToolWindowTextBrushKey}}"
          Padding="18">
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="360" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0"
              Background="#303030"
              BorderBrush="#585858"
              BorderThickness="1"
              Padding="16">
        <StackPanel>
          <TextBlock Text="SocketJack Sign-in"
                     FontSize="18"
                     FontWeight="SemiBold"
                     Margin="0,0,0,12" />
          <TextBlock Text="{Binding Status}"
                     TextWrapping="Wrap"
                     Margin="0,0,0,12" />
          <Button Content="Sign in with browser"
                  MinWidth="144"
                  HorizontalAlignment="Left"
                  Style="{StaticResource {x:Static styles:VsResourceKeys.ButtonStyleKey}}"
                  Command="{Binding BrowserSignInCommand}" />
          <Button Content="That didn't work, let me log in here."
                  MinWidth="220"
                  HorizontalAlignment="Left"
                  Margin="0,8,0,12"
                  Style="{StaticResource {x:Static styles:VsResourceKeys.ButtonStyleKey}}"
                  Command="{Binding ShowInlineSignInCommand}" />
          <StackPanel>
            <StackPanel.Style>
              <Style TargetType="{x:Type StackPanel}">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsInlineSignInVisible}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </StackPanel.Style>
            <TextBlock Text="User name" />
            <TextBox MinHeight="26"
                     Margin="0,4,0,10"
                     Text="{Binding SignInUserName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource {x:Static styles:VsResourceKeys.TextBoxStyleKey}}" />
            <TextBlock Text="Password" />
            <TextBox MinHeight="26"
                     Margin="0,4,0,10"
                     Text="{Binding SignInPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     FontFamily="Wingdings"
                     Style="{StaticResource {x:Static styles:VsResourceKeys.TextBoxStyleKey}}" />
            <CheckBox Content="Remember this sign-in"
                      Margin="0,0,0,12"
                      IsChecked="{Binding RememberSignIn, Mode=TwoWay}" />
            <Button Content="Sign in here"
                    MinWidth="96"
                    HorizontalAlignment="Left"
                    Style="{StaticResource {x:Static styles:VsResourceKeys.ButtonStyleKey}}"
                    Command="{Binding SignInCommand}" />
          </StackPanel>
          <Button Content="Sign out"
                  MinWidth="88"
                  HorizontalAlignment="Left"
                  Margin="0,8,0,0"
                  Style="{StaticResource {x:Static styles:VsResourceKeys.ButtonStyleKey}}"
                  Command="{Binding SignOutCommand}" />
          <TextBlock Text="{Binding SignInError}"
                     Foreground="#FFB4A9"
                     TextWrapping="Wrap"
                     Margin="0,12,0,0" />
          <TextBlock Text="{Binding AuthStatus}"
                     Foreground="#CFCFCF"
                     TextWrapping="Wrap"
                     Margin="0,8,0,0" />
        </StackPanel>
      </Border>
    </Grid>
  </Border>
</DataTemplate>
