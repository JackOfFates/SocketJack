<DataTemplate xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:styles="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
              xmlns:colors="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0">
  <Border Background="{DynamicResource {x:Static colors:EnvironmentColors.ToolWindowBackgroundBrushKey}}"
          TextElement.Foreground="{DynamicResource {x:Static colors:EnvironmentColors.ToolWindowTextBrushKey}}"
          Padding="10">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,8"
                 IsEnabled="{Binding SessionControlsEnabled}">
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
          <Menu Margin="4,0,0,0"
                Background="#303030"
                Foreground="#E8E8E8">
            <Menu.Resources>
              <Style TargetType="{x:Type MenuItem}">
                <Setter Property="Background" Value="#303030" />
                <Setter Property="Foreground" Value="#E8E8E8" />
                <Setter Property="BorderBrush" Value="#585858" />
                <Setter Property="Padding" Value="10,4" />
              </Style>
              <Style TargetType="{x:Type Separator}">
                <Setter Property="Background" Value="#585858" />
                <Setter Property="Margin" Value="4,3" />
              </Style>
            </Menu.Resources>
            <MenuItem Header="Manage">
              <MenuItem Header="Import Repo"
                        Command="{Binding ShowImportRepoCommand}" />
              <Separator />
              <MenuItem Header="Reset Session"
                        Command="{Binding ResetSessionCommand}" />
            </MenuItem>
          </Menu>
          <Button Content="Refresh"
                  MinWidth="72"
                  Margin="4,0,0,0"
                  Style="{StaticResource {x:Static styles:VsResourceKeys.ButtonStyleKey}}"
                  Command="{Binding RefreshCommand}" />
          <Button Content="Pull"
                  MinWidth="64"
                  Margin="4,0,0,0"
                  Style="{StaticResource {x:Static styles:VsResourceKeys.ButtonStyleKey}}"
                  IsEnabled="{Binding CanPull}"
                  Command="{Binding PullCommand}" />
          <Button Content="Push"
                  MinWidth="64"
                  Margin="4,0,0,0"
                  Style="{StaticResource {x:Static styles:VsResourceKeys.ButtonStyleKey}}"
                  Command="{Binding PushCommand}" />
        </StackPanel>
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="Session"
                     VerticalAlignment="Center"
                     Margin="0,0,6,0" />
          <TextBox MinWidth="260"
                   MinHeight="26"
                   Margin="0,0,8,0"
                   IsReadOnly="True"
                   Text="{Binding SessionId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                   Style="{StaticResource {x:Static styles:VsResourceKeys.TextBoxStyleKey}}" />
          <TextBlock Text="{Binding EndpointSummary}"
                     VerticalAlignment="Center"
                     TextTrimming="CharacterEllipsis" />
        </StackPanel>
      </DockPanel>

      <TreeView Grid.Row="1"
                Background="#303030"
                BorderBrush="#585858"
                Foreground="#E8E8E8"
                IsEnabled="{Binding SessionControlsEnabled}"
                ItemsSource="{Binding TreeItems}">
        <TreeView.Resources>
          <Style TargetType="{x:Type TreeViewItem}">
            <Setter Property="Background" Value="#303030" />
            <Setter Property="Foreground" Value="#E8E8E8" />
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
          </Style>
        </TreeView.Resources>
        <TreeView.ItemTemplate>
          <HierarchicalDataTemplate ItemsSource="{Binding Children}">
            <Grid MinHeight="22"
                  Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType={x:Type TreeView}}}">
              <Grid.ContextMenu>
                <ContextMenu Background="#303030" Foreground="#E8E8E8">
                  <MenuItem Header="Open File Location"
                            Command="{Binding PlacementTarget.Tag.OpenFileLocationCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                            CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
                  <Separator />
                  <MenuItem Header="Ignore"
                            Command="{Binding PlacementTarget.Tag.IgnoreCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                            CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
                  <MenuItem Header="Ignore Remote Changes"
                            Command="{Binding PlacementTarget.Tag.IgnoreRemoteCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                            CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
                  <MenuItem Header="Remove From Ignore List"
                            Command="{Binding PlacementTarget.Tag.RemoveIgnoreCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                            CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
                  <Separator />
                  <MenuItem Header="Properties"
                            Command="{Binding PlacementTarget.Tag.PropertiesCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                            CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
                </ContextMenu>
              </Grid.ContextMenu>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="124" />
                <ColumnDefinition Width="132" />
                <ColumnDefinition Width="96" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0"
                         Text="{Binding StatusGlyph}"
                         Foreground="{Binding StatusColor}"
                         FontWeight="Bold"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
              <TextBlock Grid.Column="1"
                         Text="{Binding Name}"
                         Foreground="#E8E8E8"
                         TextTrimming="CharacterEllipsis"
                         VerticalAlignment="Center">
                <TextBlock.Style>
                  <Style TargetType="{x:Type TextBlock}">
                    <Setter Property="TextDecorations" Value="{x:Null}" />
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding IsIgnored}" Value="True">
                        <Setter Property="TextDecorations" Value="Strikethrough" />
                        <Setter Property="Foreground" Value="#9A9A9A" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </TextBlock.Style>
              </TextBlock>
              <TextBlock Grid.Column="2"
                         Margin="8,0,0,0"
                         Text="{Binding StatusText}"
                         Foreground="#CFCFCF"
                         TextTrimming="CharacterEllipsis"
                         VerticalAlignment="Center" />
              <ProgressBar Grid.Column="3"
                           Width="112"
                           Height="8"
                           Minimum="0"
                           Maximum="100"
                           Value="{Binding Progress}"
                           Background="#202020"
                           Foreground="#5FB3FF"
                           VerticalAlignment="Center" />
              <TextBlock Grid.Column="4"
                         Margin="8,0,0,0"
                         Text="{Binding MetricText}"
                         Foreground="#BDBDBD"
                         TextAlignment="Right"
                         TextTrimming="CharacterEllipsis"
                         VerticalAlignment="Center" />
            </Grid>
          </HierarchicalDataTemplate>
        </TreeView.ItemTemplate>
      </TreeView>

      <StackPanel Grid.Row="2" Margin="0,8,0,0">
        <TextBlock Text="{Binding Status}" TextWrapping="Wrap" />
        <TextBlock Margin="0,4,0,0"
                   Text="{Binding SelectedDetails}"
                   TextWrapping="Wrap"
                   Foreground="#D6D6D6" />
      </StackPanel>

      <Grid Grid.RowSpan="3" Background="#CC202020">
        <Grid.Style>
          <Style TargetType="{x:Type Grid}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsSessionBootstrapVisible}" Value="True">
                <Setter Property="Visibility" Value="Visible" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Grid.Style>
        <Button Content="{Binding CreateSessionButtonText}"
                MinWidth="220"
                MinHeight="34"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Style="{StaticResource {x:Static styles:VsResourceKeys.ButtonStyleKey}}"
                Command="{Binding CreateSessionCommand}" />
      </Grid>

      <Grid Grid.RowSpan="3" Background="#DD202020">
        <Grid.Style>
          <Style TargetType="{x:Type Grid}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsImportRepoVisible}" Value="True">
                <Setter Property="Visibility" Value="Visible" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Grid.Style>
        <Border Width="520"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#303030"
                BorderBrush="#585858"
                BorderThickness="1"
                Padding="16">
          <StackPanel>
            <TextBlock Text="Import GitHub Repository"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Margin="0,0,0,10" />
            <DockPanel LastChildFill="True">
              <Button DockPanel.Dock="Right"
                      Content="Import"
                      MinWidth="80"
                      Margin="8,0,0,0"
                      Style="{StaticResource {x:Static styles:VsResourceKeys.ButtonStyleKey}}"
                      Command="{Binding ImportRepoCommand}" />
              <TextBox MinHeight="26"
                       Text="{Binding ImportRepository, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       Style="{StaticResource {x:Static styles:VsResourceKeys.TextBoxStyleKey}}" />
            </DockPanel>
            <TextBox MinHeight="26"
                     Margin="0,8,0,0"
                     ToolTip="Optional GitHub token for private repositories"
                     Text="{Binding ImportGitHubToken, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     FontFamily="Wingdings"
                     Style="{StaticResource {x:Static styles:VsResourceKeys.TextBoxStyleKey}}" />
            <TextBlock Text="{Binding ImportRepoError}"
                       Foreground="#FF6F6F"
                       TextWrapping="Wrap"
                       Margin="0,8,0,0" />
            <TextBlock Text="{Binding ImportRepoStatus}"
                       Foreground="#CFCFCF"
                       TextWrapping="Wrap"
                       Margin="0,8,0,0" />
            <Button Content="Close"
                    MinWidth="80"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0"
                    Style="{StaticResource {x:Static styles:VsResourceKeys.ButtonStyleKey}}"
                    Command="{Binding CancelImportRepoCommand}" />
          </StackPanel>
        </Border>
      </Grid>

      <Grid Grid.RowSpan="3" Background="#DD202020">
        <Grid.Style>
          <Style TargetType="{x:Type Grid}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsSignInOverlayVisible}" Value="True">
                <Setter Property="Visibility" Value="Visible" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Grid.Style>
        <Border Width="360"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#303030"
                BorderBrush="#585858"
                BorderThickness="1"
                Padding="16">
          <StackPanel>
            <TextBlock Text="Local Workstation Required"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Margin="0,0,0,10" />
            <TextBlock Text="Start JackLLM Workstation at 127.0.0.1:11436 to create and sync Visual Studio session files locally."
                       TextWrapping="Wrap"
                       Margin="0,0,0,12" />
            <TextBlock Text="{Binding SignInError}"
                       Foreground="#FFB4A9"
                       TextWrapping="Wrap"
                       Margin="0,12,0,0" />
            <TextBlock Text="{Binding AuthStatus}"
                       Foreground="#CFCFCF"
                       TextWrapping="Wrap"
                       Margin="0,8,0,0" />
          </StackPanel>
        </Border>
      </Grid>
    </Grid>
  </Border>
</DataTemplate>
