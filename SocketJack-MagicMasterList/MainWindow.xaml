<Window x:Class="SocketJack.MagicMasterList.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="SocketJack-MagicMasterList"
        Width="1430"
        Height="820"
        MinWidth="1050"
        MinHeight="620"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="CanResize"
        StateChanged="Window_StateChanged"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44"
                            ResizeBorderThickness="7"
                            GlassFrameThickness="0"
                            CornerRadius="6"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border x:Name="WindowFrame"
            BorderBrush="{StaticResource PanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="6"
            SnapsToDevicePixels="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#A8080B10" Offset="0"/>
                <GradientStop Color="#A8111827" Offset="0.45"/>
                <GradientStop Color="#A8072021" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="14,0,6,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Width="11"
                            Height="11"
                            CornerRadius="6"
                            Background="{StaticResource AccentBrush}"
                            VerticalAlignment="Center"
                            Margin="0,0,10,0"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Style="{StaticResource WindowChromeButtonStyle}"
                                Click="MinimizeButton_Click"
                                ToolTip="Minimize">
                            <Path Data="M 4 9 H 12"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.7"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"/>
                        </Button>
                        <Button Style="{StaticResource WindowChromeButtonStyle}"
                                Click="MaximizeRestoreButton_Click"
                                ToolTip="Maximize">
                            <Grid Width="16" Height="16">
                                <Path x:Name="MaximizeGlyph"
                                      Data="M 4 4 H 12 V 12 H 4 Z"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1.35"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"/>
                                <Path x:Name="RestoreGlyph"
                                      Data="M 6 3 H 13 V 10 M 3 6 H 10 V 13 H 3 Z"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1.35"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Visibility="Collapsed"/>
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource WindowChromeCloseButtonStyle}"
                                Click="CloseButton_Click"
                                ToolTip="Close">
                            <Path Data="M 4 4 L 12 12 M 12 4 L 4 12"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.6"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <TabControl Grid.Row="1"
                        Background="Transparent"
                        BorderThickness="0">
                <TabItem Header="Servers">
            <Grid Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="SocketJack-MagicMasterList"
                                   FontSize="26"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="SocketJack MutableTcpServer + SocketJack database"
                                   Foreground="{StaticResource SubtleTextBrush}"
                                   FontSize="13"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                    <Border Grid.Column="1"
                            Background="#66387A73"
                            BorderBrush="{StaticResource AccentBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12,8"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding ServerCountText}"
                                       FontWeight="SemiBold"
                                       Margin="0,0,12,0"/>
                            <TextBlock Text="{Binding LastUpdatedText}"
                                       Foreground="{StaticResource SubtleTextBrush}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <GroupBox Grid.Row="1"
                          Header="Host"
                          Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.1*"/>
                            <ColumnDefinition Width="1.25*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <UniformGrid Grid.Column="0"
                                     Columns="2"
                                     Rows="2"
                                     Margin="0,0,12,0">
                            <StackPanel Margin="0,0,10,8">
                                <TextBlock Text="Status" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                <TextBlock Text="{Binding StatusText}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,10,8">
                                <TextBlock Text="Ports" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                <TextBlock Text="{Binding PortText}" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="Database" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                <TextBlock Text="{Binding DatabaseText}" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="SQL Admin" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                <TextBlock Text="{Binding SqlAdminText}" FontWeight="SemiBold"/>
                            </StackPanel>
                        </UniformGrid>

                        <UniformGrid Grid.Column="1"
                                     Columns="1"
                                     Rows="2"
                                     Margin="0,0,12,0">
                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Text="Public URLs" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                <TextBlock Text="{Binding PublicUrlText}"
                                           TextWrapping="Wrap"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Data file" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                <TextBlock Text="{Binding DataPathText}"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource SubtleTextBrush}"/>
                            </StackPanel>
                        </UniformGrid>

                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button Content="Start"
                                    IsEnabled="{Binding CanStart}"
                                    Click="StartButton_Click"
                                    Margin="0,0,8,0"/>
                            <Button Content="Stop"
                                    IsEnabled="{Binding CanStop}"
                                    Click="StopButton_Click"
                                    Margin="0,0,8,0"/>
                            <Button Content="Refresh"
                                    Click="RefreshButton_Click"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <Grid Grid.Row="2" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             MinHeight="36"
                             VerticalContentAlignment="Center"/>
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="12,0,0,0">
                        <TextBlock Text="{Binding FilterText}"
                                   Foreground="{StaticResource SubtleTextBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>
                        <Button Content="Open"
                                IsEnabled="{Binding CanManageSelectedServer}"
                                Click="OpenSelectedServerButton_Click"
                                Margin="0,0,8,0"/>
                        <Button Content="Copy URL"
                                IsEnabled="{Binding CanManageSelectedServer}"
                                Click="CopySelectedServerUrlButton_Click"
                                Margin="0,0,8,0"/>
                        <Button Content="Mark Offline"
                                IsEnabled="{Binding CanManageSelectedServer}"
                                Click="MarkSelectedServerOfflineButton_Click"
                                Margin="0,0,8,0"/>
                        <Button Content="Delete"
                                IsEnabled="{Binding CanManageSelectedServer}"
                                Click="DeleteSelectedServerButton_Click"
                                Background="#893442"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="3">
                    <ListBox ItemsSource="{Binding ServersView}"
                             SelectedItem="{Binding SelectedServer, Mode=TwoWay}"
                             VirtualizingStackPanel.IsVirtualizing="True"
                             VirtualizingStackPanel.VirtualizationMode="Recycling">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ServerCardStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding TitleText}"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding EndpointText}"
                                                           Foreground="{StaticResource SubtleTextBrush}"
                                                           FontSize="12"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="0,3,0,0"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Top"
                                                        Margin="12,0,0,0">
                                                <Border Background="#55387A73"
                                                        BorderBrush="{StaticResource AccentBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="7"
                                                        Padding="8,5"
                                                        Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding IpText}" FontWeight="SemiBold"/>
                                                </Border>
                                                <Border Background="#44263448"
                                                        BorderBrush="{StaticResource ControlBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="7"
                                                        Padding="8,5"
                                                        Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding LastSeenText}" Foreground="{StaticResource SubtleTextBrush}"/>
                                                </Border>
                                                <Border Background="#55387A73"
                                                        BorderBrush="{StaticResource AccentBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="7"
                                                        Padding="8,5"
                                                        Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding OnlineText}" FontWeight="SemiBold"/>
                                                </Border>
                                                <Border Background="#44263448"
                                                        BorderBrush="{StaticResource ControlBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="7"
                                                        Padding="8,5"
                                                        Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding LmStudioConnectedText}" Foreground="{StaticResource SubtleTextBrush}"/>
                                                </Border>
                                                <Border Background="#44263448"
                                                        BorderBrush="{StaticResource ControlBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="7"
                                                        Padding="8,5"
                                                        Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding ModelRuntimeText}" Foreground="{StaticResource SubtleTextBrush}"/>
                                                </Border>
                                                <Border Background="#44263448"
                                                        BorderBrush="{StaticResource ControlBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="7"
                                                        Padding="8,5">
                                                    <TextBlock Text="{Binding LlmRuntimeConnectedText}" Foreground="{StaticResource SubtleTextBrush}"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>

                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding DescriptionText}"
                                                   Foreground="{StaticResource SubtleTextBrush}"
                                                   TextWrapping="Wrap"
                                                   MaxHeight="38"
                                                   Margin="0,8,0,10"/>

                                        <WrapPanel Grid.Row="2">
                                            <Border Style="{StaticResource ServerFactPillStyle}" MinWidth="300" MaxWidth="440">
                                                <StackPanel>
                                                    <TextBlock Text="Available Models" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                                    <TextBlock Text="{Binding AvailableModelsText}" TextWrapping="Wrap" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource ServerFactPillStyle}" MinWidth="260" MaxWidth="380">
                                                <StackPanel>
                                                    <TextBlock Text="Tools Allowed" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                                    <TextBlock Text="{Binding ToolsAllowedText}" TextWrapping="Wrap" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource ServerFactPillStyle}" MinWidth="260" MaxWidth="380">
                                                <StackPanel>
                                                    <TextBlock Text="Model Runtime" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                                    <TextBlock Text="{Binding ModelRuntimeText}" TextWrapping="Wrap" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource ServerFactPillStyle}" MinWidth="220" MaxWidth="320">
                                                <StackPanel>
                                                    <TextBlock Text="LlmRuntime" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                                    <TextBlock Text="{Binding LlmRuntimeConnectedText}" TextWrapping="Wrap" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource ServerFactPillStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="RAM" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                                    <TextBlock Text="{Binding AvailableRamText}" TextWrapping="Wrap" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource ServerFactPillStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="VRAM" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                                    <TextBlock Text="{Binding AvailableVramText}" TextWrapping="Wrap" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource ServerFactPillStyle}" MinWidth="230" MaxWidth="360">
                                                <StackPanel>
                                                    <TextBlock Text="GPU Model" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                                    <TextBlock Text="{Binding GpuModelText}" TextWrapping="Wrap" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource ServerFactPillStyle}" MinWidth="230" MaxWidth="360">
                                                <StackPanel>
                                                    <TextBlock Text="CPU Model" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                                    <TextBlock Text="{Binding CpuModelText}" TextWrapping="Wrap" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource ServerFactPillStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="Max Tokens" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                                    <TextBlock Text="{Binding MaxTokensText}" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource ServerFactPillStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="Cost" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                                    <TextBlock Text="{Binding CostText}" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource ServerFactPillStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="Cost Factor" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                                    <TextBlock Text="{Binding CostFactorText}" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource ServerFactPillStyle}" MinWidth="220" MaxWidth="320">
                                                <StackPanel>
                                                    <TextBlock Text="Owner" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                                    <TextBlock Text="{Binding OwnerText}" TextWrapping="Wrap" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource ServerFactPillStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="Visibility" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                                    <TextBlock Text="{Binding VisibilityText}" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource ServerFactPillStyle}" MinWidth="280" MaxWidth="420">
                                                <StackPanel>
                                                    <TextBlock Text="Ports" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                                    <TextBlock Text="{Binding PortsText}" TextWrapping="Wrap" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource ServerFactPillStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="Storage" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                                    <TextBlock Text="{Binding StorageText}" TextWrapping="Wrap" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource ServerFactPillStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="Uptime" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                                    <TextBlock Text="{Binding UptimeText}" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource ServerFactPillStyle}" MinWidth="260" MaxWidth="420">
                                                <StackPanel>
                                                    <TextBlock Text="Stripe" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                                    <TextBlock Text="{Binding StripeText}" TextWrapping="Wrap" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource ServerFactPillStyle}" MinWidth="320" MaxWidth="620">
                                                <StackPanel>
                                                    <TextBlock Text="Launch URL" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                                    <TextBlock Text="{Binding LaunchText}" TextWrapping="Wrap" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Border>
                                            <Expander Header="Capabilities, benchmarks, and raw registration"
                                                      Foreground="{StaticResource TextBrush}"
                                                      Margin="0,4,8,8"
                                                      MinWidth="640">
                                                <Grid Margin="0,8,0,0">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="120"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Text="{Binding ModelCapabilitiesText}"
                                                               Foreground="{StaticResource SubtleTextBrush}"
                                                               TextWrapping="Wrap"
                                                               Margin="0,0,0,6"/>
                                                    <TextBlock Grid.Row="1"
                                                               Text="{Binding ModelBenchmarksText}"
                                                               Foreground="{StaticResource SubtleTextBrush}"
                                                               TextWrapping="Wrap"
                                                               Margin="0,0,0,6"/>
                                                    <TextBox Grid.Row="2"
                                                             Text="{Binding RawRegistrationText, Mode=OneWay}"
                                                             IsReadOnly="True"
                                                             FontFamily="Consolas"
                                                             FontSize="12"
                                                             TextWrapping="NoWrap"
                                                             HorizontalScrollBarVisibility="Auto"
                                                             VerticalScrollBarVisibility="Auto"/>
                                                </Grid>
                                            </Expander>
                                            <Button Content="Open"
                                                    Click="OpenServerButton_Click"
                                                    Tag="{Binding}"
                                                    Margin="4,4,8,8"/>
                                            <Button Content="Mark Offline"
                                                    Click="MarkServerOfflineButton_Click"
                                                    Tag="{Binding}"
                                                    Margin="0,4,8,8"/>
                                            <Button Content="Delete"
                                                    Click="DeleteServerButton_Click"
                                                    Tag="{Binding}"
                                                    Background="#893442"
                                                    Margin="0,4,8,8"/>
                                        </WrapPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border Visibility="{Binding EmptyStateVisibility}"
                            Background="#66111924"
                            BorderBrush="{StaticResource PanelBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="22"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="No available JackLLM servers"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding EmptyStateDetail}"
                                       Foreground="{StaticResource SubtleTextBrush}"
                                       TextAlignment="Center"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
                </TabItem>
                <TabItem Header="Shell">
                    <Grid Margin="18">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="180"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Shell"
                                           FontSize="26"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="Auto-created JackLLM shell proxies for hosts behind a firewall."
                                           Foreground="{StaticResource SubtleTextBrush}"
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>
                                <TextBlock Text="Forwarding is configured by JackLLM. This window only monitors persisted /proxy/{encoded title} routes."
                                           Foreground="{StaticResource SubtleTextBrush}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <CheckBox Content="{Binding ShellEnabledText}"
                                          IsChecked="{Binding SelectedShellEnabled, Mode=TwoWay}"
                                          IsEnabled="{Binding CanManageSelectedShell}"
                                          Margin="0,0,12,0"
                                          VerticalAlignment="Center"/>
                                <Button Content="Refresh"
                                        Click="RefreshShellButton_Click"
                                        Margin="0,0,8,0"/>
                                <Button Content="Delete"
                                        Click="DeleteShellButton_Click"
                                        IsEnabled="{Binding CanManageSelectedShell}"
                                        Background="#893442"/>
                            </StackPanel>
                        </Grid>

                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding ShellRelays}"
                                 SelectedItem="{Binding SelectedShellRelay, Mode=TwoWay}"
                                 Background="#66070A10"
                                 BorderBrush="{StaticResource PanelBorderBrush}"
                                 BorderThickness="1">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource ServerCardStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding TitleText}" FontSize="17" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Endpoint}"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           FontFamily="Consolas"
                                                           Margin="0,4,0,0"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding DetailText}"
                                                           Foreground="{StaticResource SubtleTextBrush}"
                                                           Margin="0,4,0,0"/>
                                                <TextBlock Text="{Binding RuntimeText}"
                                                           Foreground="{StaticResource SubtleTextBrush}"
                                                           Margin="0,3,0,0"/>
                                            </StackPanel>
                                            <Border Grid.Column="1"
                                                    Background="#55387A73"
                                                    BorderBrush="{StaticResource AccentBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="7"
                                                    Padding="8,5"
                                                    VerticalAlignment="Top"
                                                    Margin="12,0,0,0">
                                                <TextBlock Text="{Binding Enabled, StringFormat=Enabled: {0}}" FontWeight="SemiBold"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Border Grid.Row="2"
                                Background="#E60B1018"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Margin="0,12,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Debug"
                                           FontWeight="SemiBold"
                                           FontSize="15"
                                           Margin="12,10,12,8"/>
                                <TextBox Grid.Row="1"
                                         Text="{Binding SelectedShellDebugText, Mode=OneWay}"
                                         Margin="12,0,12,12"
                                         Background="#070A10"
                                         BorderThickness="0"
                                         FontFamily="Consolas"
                                         FontSize="12.5"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Foreground="#A8FFFFFF"/>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>
                <TabItem Header="Payments">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="18">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Margin="0,0,0,14">
                                <TextBlock Text="Payments"
                                           FontSize="26"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="Master website Stripe and OAuth configuration"
                                           Foreground="{StaticResource SubtleTextBrush}"
                                           FontSize="13"
                                           Margin="0,4,0,0"/>
                            </StackPanel>

                            <GroupBox Grid.Row="1"
                                      Header="Stripe"
                                      Margin="0,0,0,14">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Margin="0,0,10,10">
                                        <TextBlock Text="Publishable key" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                        <TextBox Text="{Binding StripePublishableKey, UpdateSourceTrigger=PropertyChanged}"
                                                 MinHeight="34"
                                                 VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="0,0,0,10">
                                        <TextBlock Text="Restricted key" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                        <PasswordBox x:Name="StripeSecretKeyPasswordBox"
                                                     PasswordChanged="PaymentPasswordBox_PasswordChanged"
                                                     MinHeight="34"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Margin="0,0,10,10">
                                        <TextBlock Text="Webhook secret" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                        <PasswordBox x:Name="StripeWebhookSecretPasswordBox"
                                                     PasswordChanged="PaymentPasswordBox_PasswordChanged"
                                                     MinHeight="34"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,10">
                                        <TextBlock Text="Webhook endpoint" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                        <TextBox Text="{Binding StripeWebhookUrl, Mode=OneWay}"
                                                 IsReadOnly="True"
                                                 MinHeight="34"
                                                 VerticalContentAlignment="Center"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Margin="0,0,10,0">
                                        <TextBlock Text="Service fee percent" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                        <TextBox Text="{Binding StripeServiceFeePercent, UpdateSourceTrigger=PropertyChanged}"
                                                 MinHeight="34"
                                                 VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </GroupBox>

                            <GroupBox Grid.Row="2"
                                      Header="OAuth Redirects"
                                      Margin="0,0,0,14">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Margin="0,0,10,10">
                                        <TextBlock Text="Connect redirect URL" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                        <TextBox Text="{Binding StripeConnectRedirectUrl, UpdateSourceTrigger=PropertyChanged}"
                                                 MinHeight="34"
                                                 VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="0,0,0,10">
                                        <TextBlock Text="Token USD per token" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                        <TextBox Text="{Binding StripeTokenUsdPerToken, UpdateSourceTrigger=PropertyChanged}"
                                                 MinHeight="34"
                                                 VerticalContentAlignment="Center"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Margin="0,0,10,0">
                                        <TextBlock Text="Checkout success URL" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                        <TextBox Text="{Binding StripeCheckoutSuccessUrl, UpdateSourceTrigger=PropertyChanged}"
                                                 MinHeight="34"
                                                 VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="1">
                                        <TextBlock Text="Checkout cancel URL" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                        <TextBox Text="{Binding StripeCheckoutCancelUrl, UpdateSourceTrigger=PropertyChanged}"
                                                 MinHeight="34"
                                                 VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </GroupBox>

                            <GroupBox Grid.Row="3"
                                      Header="Token Products"
                                      Margin="0,0,0,14">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="260"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Stripe product exports are stored here. Add Price IDs when you create reusable Stripe prices; otherwise Checkout uses the configured product with the package amount."
                                               Foreground="{StaticResource SubtleTextBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,8"/>
                                    <DataGrid Grid.Row="1"
                                              ItemsSource="{Binding StripeTokenProducts}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="True"
                                              CanUserDeleteRows="True"
                                              HeadersVisibility="Column"
                                              GridLinesVisibility="Horizontal"
                                              Background="#66070A10"
                                              BorderBrush="{StaticResource PanelBorderBrush}"
                                              BorderThickness="1">
                                        <DataGrid.Columns>
                                            <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="72"/>
                                            <DataGridTextColumn Header="Name" Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="130"/>
                                            <DataGridTextColumn Header="Tokens" Binding="{Binding TokenAmount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="100"/>
                                            <DataGridTextColumn Header="Amount cents" Binding="{Binding UnitAmountCents, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="110"/>
                                            <DataGridTextColumn Header="Product ID" Binding="{Binding ProductId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="180"/>
                                            <DataGridTextColumn Header="Price ID" Binding="{Binding PriceId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="180"/>
                                            <DataGridTextColumn Header="Currency" Binding="{Binding Currency, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="82"/>
                                            <DataGridTextColumn Header="Description" Binding="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </GroupBox>

                            <DockPanel Grid.Row="4">
                                <StackPanel DockPanel.Dock="Right"
                                            Orientation="Horizontal">
                                    <Button Content="Reset Products"
                                            Click="ResetPaymentProductsButton_Click"
                                            Margin="0,0,8,0"/>
                                    <Button Content="Reload"
                                            Click="ReloadPaymentConfigButton_Click"
                                            Margin="0,0,8,0"/>
                                    <Button Content="Save Payment Config"
                                            Click="SavePaymentConfigButton_Click"/>
                                </StackPanel>
                                <TextBlock Text="{Binding PaymentConfigStatus}"
                                           Foreground="{StaticResource SubtleTextBrush}"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </DockPanel>
                        </Grid>
                    </ScrollViewer>
                </TabItem>
                <TabItem Header="Accounts">
                    <Grid Margin="18">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Accounts"
                                           FontSize="26"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="SocketJack web auth users, token limits, known clients, and publish defaults"
                                           Foreground="{StaticResource SubtleTextBrush}"
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="Refresh"
                                    Click="RefreshAccountsButton_Click"
                                    VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.35*"/>
                                <ColumnDefinition Width="0.85*"/>
                            </Grid.ColumnDefinitions>

                            <ListView ItemsSource="{Binding Accounts}"
                                      SelectedItem="{Binding SelectedAccount, Mode=TwoWay}"
                                      Margin="0,0,12,0">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="User" DisplayMemberBinding="{Binding UserName}" Width="150"/>
                                        <GridViewColumn Header="Enabled" DisplayMemberBinding="{Binding Enabled}" Width="72"/>
                                        <GridViewColumn Header="Admin" DisplayMemberBinding="{Binding IsAdministrator}" Width="64"/>
                                        <GridViewColumn Header="Auto Publish" DisplayMemberBinding="{Binding AutoPublish}" Width="96"/>
                                        <GridViewColumn Header="Used" DisplayMemberBinding="{Binding TokensUsed}" Width="100"/>
                                        <GridViewColumn Header="Limit" DisplayMemberBinding="{Binding TokenLimit}" Width="100"/>
                                        <GridViewColumn Header="Last Login" DisplayMemberBinding="{Binding LastLoginUtc}" Width="170"/>
                                        <GridViewColumn Header="Client IP" DisplayMemberBinding="{Binding LastClientIp}" Width="140"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>

                            <GroupBox Grid.Column="1" Header="Selected Account">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="{Binding SelectedAccount.UserName, TargetNullValue=No account selected}"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,10"/>
                                    <WrapPanel Grid.Row="1" Margin="0,0,0,10">
                                        <CheckBox Content="Enabled"
                                                  IsChecked="{Binding SelectedAccountEnabled, Mode=TwoWay}"
                                                  IsEnabled="{Binding CanManageSelectedAccount}"
                                                  Margin="0,0,14,8"/>
                                        <CheckBox Content="Administrator"
                                                  IsChecked="{Binding SelectedAccountAdministrator, Mode=TwoWay}"
                                                  IsEnabled="{Binding CanManageSelectedAccount}"
                                                  Margin="0,0,14,8"/>
                                        <CheckBox Content="Auto-publish"
                                                  IsChecked="{Binding SelectedAccountAutoPublish, Mode=TwoWay}"
                                                  IsEnabled="{Binding CanManageSelectedAccount}"
                                                  Margin="0,0,0,8"/>
                                    </WrapPanel>
                                    <Grid Grid.Row="2" Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,8,0">
                                            <TextBlock Text="Token limit" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                            <TextBox Text="{Binding SelectedAccountTokenLimit, UpdateSourceTrigger=PropertyChanged}"
                                                     IsEnabled="{Binding CanManageSelectedAccount}"
                                                     MinHeight="34"
                                                     VerticalContentAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Add tokens" Foreground="{StaticResource SubtleTextBrush}" FontSize="11"/>
                                            <TextBox Text="{Binding SelectedAccountTokenDelta, UpdateSourceTrigger=PropertyChanged}"
                                                     IsEnabled="{Binding CanManageSelectedAccount}"
                                                     MinHeight="34"
                                                     VerticalContentAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock Grid.Row="3"
                                               Text="{Binding SelectedAccountUsageText}"
                                               Foreground="{StaticResource SubtleTextBrush}"
                                               Margin="0,0,0,10"/>
                                    <WrapPanel Grid.Row="4" Margin="0,0,0,10">
                                        <Button Content="Save Account"
                                                Click="SaveAccountButton_Click"
                                                IsEnabled="{Binding CanManageSelectedAccount}"
                                                Margin="0,0,8,8"/>
                                        <Button Content="Reset Used"
                                                Click="ResetAccountUsageButton_Click"
                                                IsEnabled="{Binding CanManageSelectedAccount}"
                                                Background="#893442"
                                                BorderBrush="{StaticResource DangerBrush}"
                                                Margin="0,0,8,8"/>
                                    </WrapPanel>
                                    <TextBlock Grid.Row="5"
                                               Text="{Binding AccountStatusText}"
                                               Foreground="{StaticResource SubtleTextBrush}"
                                               TextWrapping="Wrap"/>
                                </Grid>
                            </GroupBox>
                        </Grid>

                        <TextBlock Grid.Row="2"
                                   Text="Token limit 0 means unlimited for admin operations; paid web users are still charged by the master usage APIs when limits are set."
                                   Foreground="{StaticResource SubtleTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,12,0,0"/>
                    </Grid>
                </TabItem>
                <TabItem Header="Reports">
                    <Grid Margin="18">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Runtime Reports"
                                           FontSize="26"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="Model runtime fallback and routing reports posted by JackLLM clients"
                                           Foreground="{StaticResource SubtleTextBrush}"
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="Refresh"
                                    Click="RefreshReportsButton_Click"
                                    VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="0.9*"/>
                            </Grid.ColumnDefinitions>
                            <ListView ItemsSource="{Binding RuntimeReports}"
                                      SelectedItem="{Binding SelectedRuntimeReport, Mode=TwoWay}"
                                      Margin="0,0,12,0">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Severity" DisplayMemberBinding="{Binding Severity}" Width="90"/>
                                        <GridViewColumn Header="Category" DisplayMemberBinding="{Binding Category}" Width="160"/>
                                        <GridViewColumn Header="Provider" DisplayMemberBinding="{Binding PrimaryProvider}" Width="120"/>
                                        <GridViewColumn Header="Fallback" DisplayMemberBinding="{Binding FallbackProvider}" Width="120"/>
                                        <GridViewColumn Header="Server" DisplayMemberBinding="{Binding ServerName}" Width="160"/>
                                        <GridViewColumn Header="Created" DisplayMemberBinding="{Binding CreatedUtc}" Width="180"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                            <TextBox Grid.Column="1"
                                     Text="{Binding RuntimeReportDetailText, Mode=OneWay}"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"
                                     FontSize="12.5"/>
                        </Grid>
                    </Grid>
                </TabItem>
                <TabItem Header="Logs">
                    <Grid Margin="18">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Master Logs"
                                           FontSize="26"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="Recent SocketJack master-list service, account, registration, and runtime log entries"
                                           Foreground="{StaticResource SubtleTextBrush}"
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="Refresh"
                                    Click="RefreshLogsButton_Click"
                                    VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.25*"/>
                                <ColumnDefinition Width="0.85*"/>
                            </Grid.ColumnDefinitions>
                            <ListView ItemsSource="{Binding MasterLogs}"
                                      SelectedItem="{Binding SelectedMasterLog, Mode=TwoWay}"
                                      Margin="0,0,12,0">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Level" DisplayMemberBinding="{Binding Level}" Width="80"/>
                                        <GridViewColumn Header="Category" DisplayMemberBinding="{Binding Category}" Width="150"/>
                                        <GridViewColumn Header="Message" DisplayMemberBinding="{Binding Message}" Width="360"/>
                                        <GridViewColumn Header="User" DisplayMemberBinding="{Binding UserName}" Width="130"/>
                                        <GridViewColumn Header="Path" DisplayMemberBinding="{Binding Path}" Width="180"/>
                                        <GridViewColumn Header="Created" DisplayMemberBinding="{Binding CreatedUtc}" Width="180"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                            <TextBox Grid.Column="1"
                                     Text="{Binding MasterLogDetailText, Mode=OneWay}"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"
                                     FontSize="12.5"/>
                        </Grid>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</Window>
