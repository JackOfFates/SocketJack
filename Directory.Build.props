<Project>
  <PropertyGroup>
    <SuppressNETCoreSdkPreviewMessage>true</SuppressNETCoreSdkPreviewMessage>
    <EnableWindowsTargeting Condition="'$(OS)' != 'Windows_NT'">true</EnableWindowsTargeting>
  </PropertyGroup>
  <ItemGroup>
    <Compile Remove="codex\**\*.cs" />
    <Compile Remove="artifacts\**\*.cs" />
    <None Remove="codex\**\*" />
    <None Remove="artifacts\**\*" />
  </ItemGroup>

  <ItemGroup>
    <Content Remove="codex\**\*" />
    <Content Remove="artifacts\**\*" />
  </ItemGroup>
</Project>
