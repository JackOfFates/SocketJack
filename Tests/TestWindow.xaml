<Window x:Class="TestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Select a Test" Height="160" Width="1500" MinWidth="420" MinHeight="120"
        Name="TestWindow" WindowStartupLocation="CenterScreen"
        Background="#FF1A1A1A">
    <Window.Resources>
        <!-- Fancy test-launcher button style -->
        <Style x:Key="TestButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="MinHeight" Value="48"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Foreground" Value="#FFEA4040"/>
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#FF3A0A0A"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="18,10"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect Color="#40000000" BlurRadius="8" ShadowDepth="2" Opacity="0.4" Direction="270"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF2E1010"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FF8B0000"/>
                                <Setter Property="Foreground" Value="#FFFF4444"/>
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#CC8B0000" BlurRadius="16" ShadowDepth="0" Opacity="0.55"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF3A1515"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FFBB0000"/>
                                <Setter Property="Foreground" Value="#FFFF6666"/>
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#CCBB0000" BlurRadius="20" ShadowDepth="0" Opacity="0.7"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <TabControl x:Name="Tabs" Background="#FF1A1A1A" BorderThickness="0">
        <TabItem Header="Tests">
            <Border Background="#FF1E1E1E" CornerRadius="0" Padding="8">
                <!-- Items wrap to new rows when the window is too narrow -->
                <ItemsControl>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel HorizontalAlignment="Center" Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <Button x:Name="ButtonMaxClients"       Content="⚡  Max Clients"       Style="{StaticResource TestButtonStyle}"/>
                    <Button x:Name="ButtonBandwidth"        Content="📶  Bandwidth"         Style="{StaticResource TestButtonStyle}"/>
                    <Button x:Name="ButtonChat"             Content="💬  P2P Chat"           Style="{StaticResource TestButtonStyle}"/>
                    <Button x:Name="ButtonHttpServer"       Content="🌐  HttpServer"        Style="{StaticResource TestButtonStyle}"/>
                    <Button x:Name="ButtonWebSockets"       Content="🔌  WebSockets"        Style="{StaticResource TestButtonStyle}"/>
                    <Button x:Name="ButtonControlShare"     Content="🖥  Control Share"     Style="{StaticResource TestButtonStyle}"/>
                    <Button x:Name="ButtonMutableTcpServer" Content="🧬  MutableTcpServer"  Style="{StaticResource TestButtonStyle}"/>
                </ItemsControl>
            </Border>
        </TabItem>
    </TabControl>
</Window>
