<Window x:Class="MagnetLinkDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Magnet Link" Height="180" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FF1A1A1A">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Paste a magnet link below:" Foreground="#FFEA4040"
                   FontFamily="Segoe UI Semibold" FontSize="13" Margin="0,0,0,8"/>

        <TextBox x:Name="MagnetTextBox" Grid.Row="1"
                 Background="#FF1E1E1E" Foreground="White"
                 BorderBrush="#FF3A0A0A" BorderThickness="1"
                 CaretBrush="#FFEA4040" SelectionBrush="#FF8B0000"
                 FontFamily="Segoe UI" FontSize="12"
                 Padding="8,6" Margin="0,0,0,12"
                 AcceptsReturn="False"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="OkButton" Content="Add" Width="80" Height="30"
                    IsDefault="True" Margin="0,0,8,0"
                    Background="#FF1E1E1E" Foreground="#FFEA4040"
                    BorderBrush="#FF3A0A0A" FontFamily="Segoe UI Semibold"/>
            <Button x:Name="CancelButton" Content="Cancel" Width="80" Height="30"
                    IsCancel="True"
                    Background="#FF1E1E1E" Foreground="#FFC5C5C5"
                    BorderBrush="#FF3A0A0A" FontFamily="Segoe UI"/>
        </StackPanel>
    </Grid>
</Window>
