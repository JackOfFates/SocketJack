<UserControl x:Class="TorrentClientTest"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:syntax="clr-namespace:UI.SyntaxBox;assembly=UI.SyntaxBox"
             xmlns:SyntaxBox="clr-namespace:UI.SyntaxBox;assembly=UI.SyntaxBox"
             mc:Ignorable="d" 
             d:DesignHeight="680" d:DesignWidth="1100">

    <UserControl.Resources>

        <!-- W11-Style Thin Scrollbar -->
        <Style x:Key="W11ScrollBarPageButton" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="W11ScrollBarThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBd" Background="#44EA4040" CornerRadius="3" Margin="1" SnapsToDevicePixels="True"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBd" Property="Background" Value="#88EA4040"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBd" Property="Background" Value="#CCEA4040"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="OverridesDefaultStyle" Value="True"/>
                    <Setter Property="Width" Value="6"/>
                    <Setter Property="MinWidth" Value="6"/>
                    <Setter Property="Opacity" Value="0.5"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="Transparent">
                                    <Track x:Name="PART_Track" IsDirectionReversed="True" IsEnabled="{TemplateBinding IsMouseOver}">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource W11ScrollBarPageButton}" Command="ScrollBar.PageUpCommand"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource W11ScrollBarThumb}"/>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource W11ScrollBarPageButton}" Command="ScrollBar.PageDownCommand"/>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="OverridesDefaultStyle" Value="True"/>
                    <Setter Property="Height" Value="6"/>
                    <Setter Property="MinHeight" Value="6"/>
                    <Setter Property="Opacity" Value="0.5"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="Transparent">
                                    <Track x:Name="PART_Track" IsDirectionReversed="False" IsEnabled="{TemplateBinding IsMouseOver}">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource W11ScrollBarPageButton}" Command="ScrollBar.PageLeftCommand"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource W11ScrollBarThumb}"/>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource W11ScrollBarPageButton}" Command="ScrollBar.PageRightCommand"/>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- W11-Style GroupBox -->
        <Style x:Key="SidebarGroup" TargetType="GroupBox">
            <Setter Property="Foreground" Value="#FFC5C5C5"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid SnapsToDevicePixels="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#FF222222" CornerRadius="6,6,0,0"
                                    BorderBrush="#FF3A0A0A" BorderThickness="1,1,1,0" Padding="10,6">
                                <Grid>
                                    <Border Height="2" VerticalAlignment="Top" Margin="-10,-6,-10,0"
                                            Background="#FFEA4040" CornerRadius="6,6,0,0" Opacity="0.6"/>
                                    <ContentPresenter ContentSource="Header" RecognizesAccessKey="True" Margin="0,2,0,0">
                                        <ContentPresenter.Resources>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#FFEA4040"/>
                                                <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
                                                <Setter Property="FontSize" Value="11"/>
                                            </Style>
                                        </ContentPresenter.Resources>
                                    </ContentPresenter>
                                </Grid>
                            </Border>
                            <Border Grid.Row="1" Background="#FF1E1E1E" CornerRadius="0,0,6,6"
                                    BorderBrush="#FF3A0A0A" BorderThickness="1,0,1,1"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Button styles -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="14,5"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Foreground" Value="#FFEA4040"/>
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="#FF3A0A0A" BorderThickness="1" CornerRadius="6"
                                Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect Color="#40000000" BlurRadius="8" ShadowDepth="2" Opacity="0.4" Direction="270"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF2E1010"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FF8B0000"/>
                                <Setter Property="Foreground" Value="#FFFF4444"/>
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#CC8B0000" BlurRadius="16" ShadowDepth="0" Opacity="0.55"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF3A1515"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FFBB0000"/>
                                <Setter Property="Foreground" Value="#FFFF6666"/>
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#CCBB0000" BlurRadius="20" ShadowDepth="0" Opacity="0.7"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#FF181818"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FF2A2A2A"/>
                                <Setter Property="Foreground" Value="#FF555555"/>
                                <Setter TargetName="Bd" Property="Effect" Value="{x:Null}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SmallButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="MinHeight" Value="24"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <!-- Red-Accent CheckBox -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFC5C5C5"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <DockPanel>
                            <Border x:Name="CheckBd" DockPanel.Dock="Left" Width="18" Height="18"
                                    CornerRadius="4" Background="#FF1E1E1E" BorderBrush="#FF555555"
                                    BorderThickness="1.5" VerticalAlignment="Center" Margin="0,0,6,0"
                                    SnapsToDevicePixels="True">
                                <Path x:Name="CheckGlyph" Data="M 3,8 L 7,12 L 14,4"
                                      Stroke="#FFEA4040" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                      Visibility="Collapsed" Margin="0,-1,0,0"
                                      VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </DockPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="CheckBd" Property="Background" Value="#FF2A0808"/>
                                <Setter TargetName="CheckBd" Property="BorderBrush" Value="#FFEA4040"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBd" Property="BorderBrush" Value="#FF8B0000"/>
                                <Setter TargetName="CheckBd" Property="Background" Value="#FF2E1010"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Red-Accent TextBox -->
        <Style x:Key="ConfigInput" TargetType="TextBox">
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF3A0A0A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="#FFEA4040"/>
            <Setter Property="SelectionBrush" Value="#FF8B0000"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="TxBd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="False"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TxBd" Property="BorderBrush" Value="#FF5A1A1A"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="TxBd" Property="BorderBrush" Value="#FFEA4040"/>
                                <Setter TargetName="TxBd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#88EA4040" BlurRadius="6" ShadowDepth="0" Opacity="0.4"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Red-Accent ListBox + ListBoxItem -->
        <Style x:Key="SidebarList" TargetType="ListBox">
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF3A0A0A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="MaxHeight" Value="100"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" SnapsToDevicePixels="True">
                            <ScrollViewer Focusable="False" Padding="2">
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Foreground" Value="#FFC5C5C5"/>
                        <Setter Property="Padding" Value="6,3"/>
                        <Setter Property="Margin" Value="1"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="ItemBd" Background="Transparent" CornerRadius="4"
                                            Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ItemBd" Property="Background" Value="#FF2E1010"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBd" Property="Background" Value="#FF3A1010"/>
                                            <Setter Property="Foreground" Value="#FFEA4040"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Red-Accent ProgressBar -->
        <Style x:Key="TorrentProgress" TargetType="ProgressBar">
            <Setter Property="Height" Value="14"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="Foreground" Value="#FFEA4040"/>
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="BorderBrush" Value="#FF3A0A0A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border x:Name="PART_Track" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" SnapsToDevicePixels="True">
                            <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}"
                                    CornerRadius="3" HorizontalAlignment="Left" Margin="1"
                                    SnapsToDevicePixels="True"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark Menu / MenuItem / ContextMenu styles -->
        <Style TargetType="Menu">
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="Foreground" Value="#FFEA4040"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="Foreground" Value="#FFC5C5C5"/>
            <Setter Property="BorderBrush" Value="#FF4A1515"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="2"/>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="#FFC5C5C5"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,4"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#FF2E1010"/>
                    <Setter Property="Foreground" Value="#FFEA4040"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Dark TabControl / TabItem -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="#FF1A1A1A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#FF9A9A9A"/>
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBd" Background="#FF1E1E1E" CornerRadius="6,6,0,0"
                                Padding="{TemplateBinding Padding}" Margin="2,0,0,0"
                                BorderBrush="#FF3A0A0A" BorderThickness="1,1,1,0" SnapsToDevicePixels="True">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBd" Property="Background" Value="#FF1A1A1A"/>
                                <Setter Property="Foreground" Value="#FFEA4040"/>
                                <Setter TargetName="TabBd" Property="BorderBrush" Value="#FF4A1515"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBd" Property="Background" Value="#FF2E1010"/>
                                <Setter Property="Foreground" Value="#FFCC8080"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark GridViewColumnHeader -->
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="#FF222222"/>
            <Setter Property="Foreground" Value="#FFEA4040"/>
            <Setter Property="BorderBrush" Value="#FF3A0A0A"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <!-- Dark ListView + ListViewItem -->
        <Style x:Key="TransferList" TargetType="ListView">
            <Setter Property="Background" Value="#FF1A1A1A"/>
            <Setter Property="Foreground" Value="#FFC5C5C5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="#FFC5C5C5"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#FF2A2A2A"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF2E1010"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FF3A1010"/>
                    <Setter Property="Foreground" Value="#FFEA4040"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Sidebar labels -->
        <Style x:Key="SidebarLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF9A9A9A"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,2,6,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SidebarValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFEA4040"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <!-- Status bar text -->
        <Style x:Key="StatusText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFCC8080"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>

        <Style x:Key="StatusSep" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF5A1A1A"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Text" Value="&#x2502;"/>
        </Style>

    </UserControl.Resources>

    <Grid Background="#FF1A1A1A">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Menu Bar -->
        <Border Grid.Row="0" Background="#FF1E1E1E" BorderBrush="#FF4A1515" BorderThickness="0,0,0,1">
            <Menu Background="#FF1E1E1E">
                <MenuItem Header="_File">
                    <MenuItem x:Name="MenuAddMagnet" Header="Add _Magnet Link..." InputGestureText="Ctrl+M"/>
                    <MenuItem x:Name="MenuSeedFile" Header="_Seed File..." InputGestureText="Ctrl+O"/>
                    <Separator/>
                    <MenuItem x:Name="MenuStopAll" Header="S_top All"/>
                </MenuItem>
                <MenuItem Header="_Edit">
                    <MenuItem x:Name="MenuClearLog" Header="_Clear Log"/>
                    <MenuItem x:Name="MenuClearTransfers" Header="Clear _Completed"/>
                </MenuItem>
                <MenuItem Header="_View">
                    <MenuItem x:Name="MenuToggleLog" Header="Show _Log Panel" IsCheckable="True" IsChecked="True"/>
                </MenuItem>
                <MenuItem Header="_Options">
                    <MenuItem x:Name="MenuUseMutable" Header="Use _MutableTcpServer" IsCheckable="True"/>
                    <Separator/>
                    <MenuItem Header="_Tracker Port">
                        <TextBox x:Name="TextBoxTrackerPort" Text="7700" Width="80" Style="{StaticResource ConfigInput}"/>
                    </MenuItem>
                    <MenuItem Header="_Seeder Port">
                        <TextBox x:Name="TextBoxSeederPort" Text="7800" Width="80" Style="{StaticResource ConfigInput}"/>
                    </MenuItem>
                    <MenuItem Header="Piece _Size (KB)">
                        <TextBox x:Name="TextBoxPieceSize" Text="64" Width="80" Style="{StaticResource ConfigInput}"/>
                    </MenuItem>
                </MenuItem>
                </Menu>
            </Border>

        <!-- Main Content -->
        <TabControl x:Name="MainTabs" Grid.Row="1">

            <!-- Transfers Tab -->
            <TabItem x:Name="TransfersTab">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x2B07; Transfers"/>
                        <Border x:Name="TransferBadge" Background="#FFEA4040" CornerRadius="8"
                                MinWidth="16" Height="16" Padding="4,0" Margin="6,0,0,0"
                                VerticalAlignment="Center" Visibility="Collapsed">
                            <TextBlock x:Name="TransferBadgeText" Text="0" Foreground="White"
                                       FontSize="10" FontFamily="Segoe UI Semibold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </TabItem.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition x:Name="LogRowDef" Height="200"/>
                    </Grid.RowDefinitions>

                    <!-- Transfer list -->
                    <ListView x:Name="TransferListView" Grid.Row="0" Style="{StaticResource TransferList}">
                        <ListView.ContextMenu>
                            <ContextMenu>
                                <MenuItem x:Name="CtxCopyMagnet" Header="Copy Magnet Link" Click="CtxCopyMagnet_Click" />
                                <MenuItem x:Name="CtxCopyHash" Header="Copy Info Hash" Click="CtxCopyHash_Click" />
                                <Separator/>
                                <MenuItem x:Name="CtxStopTransfer" Header="Stop" Click="CtxStopTransfer_Click" />
                                <MenuItem x:Name="CtxRemoveTransfer" Header="Remove" Click="CtxRemoveTransfer_Click" />
                            </ContextMenu>
                        </ListView.ContextMenu>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Name" Width="260" DisplayMemberBinding="{Binding Name}"/>
                                <GridViewColumn Header="Size" Width="80" DisplayMemberBinding="{Binding Size}"/>
                                <GridViewColumn Header="Progress" Width="180">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <ProgressBar Value="{Binding ProgressValue}" Style="{StaticResource TorrentProgress}"/>
                                                <TextBlock Text="{Binding ProgressText}" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" Foreground="White" FontSize="9"
                                                           FontFamily="Segoe UI"/>
                                            </Grid>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Speed" Width="90" DisplayMemberBinding="{Binding Speed}"/>
                                <GridViewColumn Header="ETA" Width="80" DisplayMemberBinding="{Binding ETA}"/>
                                <GridViewColumn Header="Peers" Width="60" DisplayMemberBinding="{Binding Peers}"/>
                                <GridViewColumn Header="Status" Width="100" DisplayMemberBinding="{Binding Status}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <!-- Splitter between transfers and log -->
                    <GridSplitter x:Name="LogSplitter" Grid.Row="1" Height="3" HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center" Background="#FF4A1515"
                                  ResizeBehavior="PreviousAndNext" ResizeDirection="Rows"/>

                    <!-- Log panel -->
                    <TextBox x:Name="TextboxLog" Grid.Row="2"
                             FontFamily="Consolas" FontSize="11"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             Padding="0" Margin="0"
                             TextWrapping="NoWrap"
                             AcceptsReturn="True"
                             IsReadOnly="True"
                             Text="" Foreground="#FFEAEAEA" BorderThickness="0" Background="#FF141414"
                             syntax:SyntaxBox.Enable="False"
                             syntax:SyntaxBox.ExpandTabs="True"
                             syntax:SyntaxBox.AutoIndent="True"
                             syntax:SyntaxBox.ShowLineNumbers="True"
                             syntax:SyntaxBox.LineNumbersBackground="#FF1A1A1A"
                             syntax:SyntaxBox.LineNumbersForeground="#FF555555">
                        <SyntaxBox:SyntaxBox.SyntaxDrivers>
                            <SyntaxBox:SyntaxConfig>
                                <SyntaxBox:KeywordRule Foreground="#FF9CFF82" Keywords="Connected,Complete,Verified,Seeding,Downloaded,Registered,PASSED" WholeWordsOnly="True"/>
                                <SyntaxBox:KeywordRule Foreground="#FFF5FF9D" Keywords="Connecting,Announcing,Requesting,Searching,Waiting" WholeWordsOnly="True"/>
                                <SyntaxBox:KeywordRule Foreground="#FFFF9A9A" Keywords="Disconnected,Failed,Error,Mismatch,WARNING,Timeout" WholeWordsOnly="True"/>
                                <SyntaxBox:KeywordRule Foreground="#FF00B3FF" Keywords="Tracker,Peer,Piece,Torrent,Swarm,InfoHash" WholeWordsOnly="True"/>
                                <SyntaxBox:RegexRule Op="Line" Foreground="#FF0A8600" Pattern="\s*\/\/.*"/>
                                <SyntaxBox:RegexRule Op="Line" Foreground="Red" Pattern="\s(ERROR)"/>
                                <SyntaxBox:RegexRule Op="Line" Foreground="#FF656EFF" Pattern="^\[[^\]]*(?:T|t)racker[^\]]*\]"/>
                                <SyntaxBox:RegexRule Op="Line" Foreground="#FFFFBF8A" Pattern="^\[[^\]]*(?:S|s)eeder[^\]]*\]"/>
                                <SyntaxBox:RegexRule Op="Line" Foreground="#FF9ACFFF" Pattern="^\[[^\]]*(?:L|l)eecher[^\]]*\]"/>
                                <SyntaxBox:RegexRule Op="Line" Foreground="#FFE0A0FF" Pattern="^\[[^\]]*(?:M|m)agnet[^\]]*\]"/>
                                <SyntaxBox:RegexRule Op="Line" Foreground="#FFFFDD57" Pattern="^\[[^\]]*RuTracker[^\]]*\]"/>
                            </SyntaxBox:SyntaxConfig>
                        </SyntaxBox:SyntaxBox.SyntaxDrivers>
                    </TextBox>
                </Grid>
            </TabItem>

            <!-- RuTracker Search Tab -->
            <TabItem Header="RuTracker Search">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Login bar -->
                    <Border Grid.Row="0" Background="#FF1E1E1E" Padding="8,6">
                        <DockPanel>
                            <Button x:Name="ButtonRuTrackerLogin" DockPanel.Dock="Left" Content="Login via Browser" Click="ButtonRuTrackerLogin_Click"
                                    Style="{StaticResource SmallButton}" Margin="0,0,10,0"/>
                            <TextBlock x:Name="RuTrackerLoginStatus" Text="Not logged in" Foreground="#FF888888"
                                       VerticalAlignment="Center" FontSize="11"/>
                        </DockPanel>
                    </Border>

                    <!-- Search bar -->
                    <Border Grid.Row="1" Background="#FF1E1E1E" Padding="8">
                        <DockPanel>
                            <Button x:Name="ButtonRuTrackerSearch" DockPanel.Dock="Right" Content="Search" Click="ButtonRuTrackerSearch_Click"
                                    Style="{StaticResource SmallButton}" Margin="8,0,0,0"/>
                            <Button x:Name="ButtonRuTrackerNext" DockPanel.Dock="Right" Content="Next ?"
                                    Style="{StaticResource SmallButton}" Margin="4,0,0,0" IsEnabled="False"/>
                            <Button x:Name="ButtonRuTrackerPrev" DockPanel.Dock="Right" Content="? Prev"
                                    Style="{StaticResource SmallButton}" Margin="4,0,0,0" IsEnabled="False"/>
                            <TextBox x:Name="RuTrackerSearchQuery" Style="{StaticResource ConfigInput}"
                                     FontSize="12"/>
                        </DockPanel>
                    </Border>

                    <!-- Search results -->
                    <ListView x:Name="RuTrackerResultsView" Grid.Row="2" Style="{StaticResource TransferList}"
                              MouseDoubleClick="RuTrackerResult_DoubleClick">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Title" Width="400" DisplayMemberBinding="{Binding Title}"/>
                                <GridViewColumn Header="Size" Width="100" DisplayMemberBinding="{Binding Size}"/>
                                <GridViewColumn Header="Seeds" Width="60" DisplayMemberBinding="{Binding Seeds}"/>
                                <GridViewColumn Header="Leechers" Width="60" DisplayMemberBinding="{Binding Leechers}"/>
                                <GridViewColumn Header="Magnet" Width="300" DisplayMemberBinding="{Binding MagnetShort}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#FF1E1E1E" BorderBrush="#FF4A1515" BorderThickness="0,1,0,0" Padding="8,4">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="StatusTracker" Text="Tracker: Offline" Style="{StaticResource StatusText}"/>
                <TextBlock Style="{StaticResource StatusSep}"/>
                <TextBlock x:Name="StatusTransfers" Text="Transfers: 0" Style="{StaticResource StatusText}"/>
                <TextBlock Style="{StaticResource StatusSep}"/>
                <TextBlock x:Name="StatusPeers" Text="Peers: 0" Style="{StaticResource StatusText}"/>
                <TextBlock Style="{StaticResource StatusSep}"/>
                <TextBlock x:Name="StatusSpeed" Text="&#x2193; 0 B/s" Style="{StaticResource StatusText}"/>
                <TextBlock Style="{StaticResource StatusSep}"/>
                <TextBlock x:Name="StatusSearch" Text="Search: Idle" Style="{StaticResource StatusText}"/>
            </StackPanel>
        </Border>
    </Grid>

</UserControl>





