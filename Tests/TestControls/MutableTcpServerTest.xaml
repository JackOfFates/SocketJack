<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:SyntaxBox="clr-namespace:UI.SyntaxBox;assembly=UI.SyntaxBox"
             xmlns:local="clr-namespace:SocketJackTests" x:Class="MutableTcpServerTest" 
             mc:Ignorable="d" 
             d:DesignHeight="608.886" d:DesignWidth="1500">
    <UserControl.Resources>
        <local:MetricColorConverter x:Key="MetricColor"/>
    </UserControl.Resources>
    <Grid>
        <!-- Bottom button bar -->
        <Grid VerticalAlignment="Bottom" Margin="10,0,10,5" Height="56">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="ButtonStartStop" Content="Start Test" Width="126"/>
                <CheckBox x:Name="CheckRunParallel" Content="Run Parallel" Foreground="#FFB0B0B0" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" Margin="14,0,0,0"/>
            </StackPanel>
            <!-- Summary -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0">
                <TextBlock Text="Passed: " Foreground="#FF888888" FontFamily="Consolas" FontSize="13" VerticalAlignment="Center"/>
                <TextBlock x:Name="LabelPassed" Text="0" Foreground="#FF9CFF82" FontFamily="Consolas" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,14,0"/>
                <TextBlock Text="Failed: " Foreground="#FF888888" FontFamily="Consolas" FontSize="13" VerticalAlignment="Center"/>
                <TextBlock x:Name="LabelFailed" Text="0" Foreground="#FFFF9A9A" FontFamily="Consolas" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,14,0"/>
                <TextBlock Text="Total: " Foreground="#FF888888" FontFamily="Consolas" FontSize="13" VerticalAlignment="Center"/>
                <TextBlock x:Name="LabelTotal" Text="0" Foreground="#FFEAEAEA" FontFamily="Consolas" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
        <!-- Main content -->
        <Grid Margin="10,10,10,66">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="850"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!-- Test results list -->
            <Border Background="#CC1A1A1A" CornerRadius="4" Padding="0" Margin="0,0,5,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <!-- Header with Select All -->
                    <StackPanel Orientation="Horizontal" Margin="8,6,0,4">
                        <TextBlock Text="Test Results" Foreground="#FFC5C5C5" FontFamily="Consolas" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                        <CheckBox x:Name="CheckSelectAll" Content="Select All" IsChecked="True" Foreground="#FFB0B0B0" FontFamily="Consolas" FontSize="11" VerticalAlignment="Center" Margin="16,0,0,0"/>
                    </StackPanel>
                    <!-- Category checkboxes -->
                    <WrapPanel Grid.Row="1" Margin="8,2,8,4">
                        <CheckBox x:Name="CatProperties" Content="Properties" IsChecked="True" Foreground="#FFB0B0B0" FontFamily="Consolas" FontSize="10" Margin="0,0,10,2" Tag="Properties"/>
                        <CheckBox x:Name="CatRegistration" Content="Registration" IsChecked="True" Foreground="#FFB0B0B0" FontFamily="Consolas" FontSize="10" Margin="0,0,10,2" Tag="Registration"/>
                        <CheckBox x:Name="CatLifecycle" Content="Lifecycle" IsChecked="True" Foreground="#FFB0B0B0" FontFamily="Consolas" FontSize="10" Margin="0,0,10,2" Tag="Lifecycle"/>
                        <CheckBox x:Name="CatHttp" Content="HTTP" IsChecked="True" Foreground="#FFB0B0B0" FontFamily="Consolas" FontSize="10" Margin="0,0,10,2" Tag="HTTP"/>
                        <CheckBox x:Name="CatSocketJack" Content="SocketJack" IsChecked="True" Foreground="#FFB0B0B0" FontFamily="Consolas" FontSize="10" Margin="0,0,10,2" Tag="SocketJack"/>
                        <CheckBox x:Name="CatWebSocket" Content="WebSocket" IsChecked="True" Foreground="#FFB0B0B0" FontFamily="Consolas" FontSize="10" Margin="0,0,10,2" Tag="WebSocket"/>
                        <CheckBox x:Name="CatBroadcast" Content="Broadcast" IsChecked="True" Foreground="#FFB0B0B0" FontFamily="Consolas" FontSize="10" Margin="0,0,10,2" Tag="Broadcast"/>
                        <CheckBox x:Name="CatCrossProtocol" Content="Cross-Protocol" IsChecked="True" Foreground="#FFB0B0B0" FontFamily="Consolas" FontSize="10" Margin="0,0,10,2" Tag="Cross-Protocol"/>
                        <CheckBox x:Name="CatDispose" Content="Dispose" IsChecked="True" Foreground="#FFB0B0B0" FontFamily="Consolas" FontSize="10" Margin="0,0,10,2" Tag="Dispose"/>
                        <CheckBox x:Name="CatSerialization" Content="Serialization" IsChecked="True" Foreground="#FFB0B0B0" FontFamily="Consolas" FontSize="10" Margin="0,0,10,2" Tag="Serialization"/>
                        <CheckBox x:Name="CatCompression" Content="Compression" IsChecked="True" Foreground="#FFB0B0B0" FontFamily="Consolas" FontSize="10" Margin="0,0,10,2" Tag="Compression"/>
                    </WrapPanel>
                    <!-- Test results list -->
                    <ListView x:Name="TestResultsList" Grid.Row="2" Background="Transparent" BorderThickness="0" Foreground="#FFEAEAEA" FontFamily="Consolas" FontSize="11"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              GridViewColumnHeader.Click="ColumnHeader_Click">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Width="30">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Status" Width="50" DisplayMemberBinding="{Binding Status}"/>
                                <GridViewColumn Header="Test" Width="170" DisplayMemberBinding="{Binding Name}"/>
                                <GridViewColumn Header="Time" Width="66">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Duration}" Foreground="{Binding ElapsedMs, Converter={StaticResource MetricColor}, ConverterParameter=Time}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Cycles" Width="54">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Cycles}" Foreground="{Binding CycleCount, Converter={StaticResource MetricColor}, ConverterParameter=Cycles}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="I/O" Width="66">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Bytes}" Foreground="{Binding ByteCount, Converter={StaticResource MetricColor}, ConverterParameter=IO}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="CPU %" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Compute}" Foreground="{Binding CpuPercent, Converter={StaticResource MetricColor}, ConverterParameter=Cpu}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Memory" Width="78">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Memory}" Foreground="{Binding MemoryDeltaBytes, Converter={StaticResource MetricColor}, ConverterParameter=Memory}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Rating" Width="46">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Rating}" Foreground="{Binding RatingValue, Converter={StaticResource MetricColor}, ConverterParameter=Rating}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Result" Width="50">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ResultText}" Foreground="{Binding ResultText, Converter={StaticResource MetricColor}, ConverterParameter=Result}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Foreground" Value="#FFEAEAEA"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Status}" Value="PASS">
                                        <Setter Property="Foreground" Value="#FF9CFF82"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="FAIL">
                                        <Setter Property="Foreground" Value="#FFFF9A9A"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="RUN">
                                        <Setter Property="Foreground" Value="#FFF5FF9D"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>
                </Grid>
            </Border>
            <!-- Log output -->
            <TextBox x:Name="TextLog" Grid.Column="1"
                FontFamily="Consolas"
                VerticalScrollBarVisibility="Auto" 
                Padding="0,0,0,0" 
                TextWrapping="NoWrap" 
                AcceptsReturn="true" 
                IsReadOnly="True" Foreground="#FFEAEAEA" BorderThickness="0,0,0,0" Background="#540C0C0C"
                SyntaxBox:SyntaxBox.Enable="True"
                SyntaxBox:SyntaxBox.ExpandTabs="True"
                SyntaxBox:SyntaxBox.AutoIndent="True"
                SyntaxBox:SyntaxBox.ShowLineNumbers="True"
                SyntaxBox:SyntaxBox.LineNumbersBackground="#363636"
                SyntaxBox:SyntaxBox.LineNumbersForeground="SlateGray" Margin="5,0,0,0">
                <SyntaxBox:SyntaxBox.SyntaxDrivers>
                    <SyntaxBox:SyntaxConfig>
                        <SyntaxBox:KeywordRule Foreground="#FF9CFF82" Keywords="PASS,Connected" WholeWordsOnly="True" />
                        <SyntaxBox:KeywordRule Foreground="#FFFF9A9A" Keywords="FAIL,failed,Disconnected" WholeWordsOnly="True" />
                        <SyntaxBox:KeywordRule Foreground="#FFF5FF9D" Keywords="RUN,Connecting,Running" WholeWordsOnly="True" />
                        <SyntaxBox:KeywordRule Foreground="#FF00B3FF" Keywords="HTTP,SocketJack,WebSocket,BroadcastServer,CrossProtocol,Protocol,Property,Dispose,Serialization,Compression" WholeWordsOnly="True" />
                        <SyntaxBox:RegexRule Op="Line" Foreground="#FF0A8600" Pattern="\s*\/\/.*" />
                        <SyntaxBox:RegexRule Op="Line" Foreground="Red" Pattern="\s(ERROR)"/>
                        <SyntaxBox:RegexRule Op="Line" Foreground="#FF656EFF" Pattern="^\[Server\]\s"/>
                        <SyntaxBox:RegexRule Op="Line" Foreground="#FFFFBF8A" Pattern="^\[Client\]\s"/>
                        <SyntaxBox:RegexRule Op="Line" Foreground="#FF82C8FF" Pattern="^\[Test\]\s"/>
                    </SyntaxBox:SyntaxConfig>
                </SyntaxBox:SyntaxBox.SyntaxDrivers>
            </TextBox>
        </Grid>
    </Grid>
</UserControl>
