<Window x:Class="RuTrackerLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="RuTracker Login" Width="900" Height="650"
        WindowStartupLocation="CenterOwner"
        Background="#FF1E1E1E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Log in to RuTracker below, then click 'Done' when logged in."
                   Foreground="#FFDDDDDD" FontSize="12" Margin="10,8" HorizontalAlignment="Center"/>

        <wv2:WebView2 x:Name="LoginBrowser" Grid.Row="1" Margin="0"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10,8">
            <Button x:Name="DoneButton" Content="Done" Width="80" Height="28" Margin="0,0,8,0"
                    Background="#FF8B2020" Foreground="White" BorderBrush="#FF6B1010" FontSize="12"/>
            <Button x:Name="CancelButton" Content="Cancel" Width="80" Height="28"
                    Background="#FF3E3E42" Foreground="#FFDDDDDD" BorderBrush="#FF555555" FontSize="12"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
