<Window x:Class="SocketJack.SocketChat.Windows.StreamWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SocketChat Stream" Width="780" Height="620" MinWidth="680" MinHeight="520"
        WindowStartupLocation="CenterOwner" Background="{StaticResource WindowBrush}" Foreground="{StaticResource TextBrush}">
    <Grid Background="#C8121A27"><Grid Margin="20"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="260"/><RowDefinition/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <StackPanel><TextBlock Text="Screen &amp; camera streaming" FontSize="23" FontWeight="SemiBold"/><TextBlock Text="wShare-style screen capture with SocketJack RTMP ingest and OBS/VLC compatibility." Foreground="{StaticResource MutedBrush}" Margin="0,6,0,14"/></StackPanel>
        <Border Grid.Row="1" Background="#05080D" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10"><Grid><Image x:Name="ScreenPreview" Stretch="Uniform"/><TextBlock x:Name="PreviewPlaceholder" Text="Start preview to capture your primary display" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}"/></Grid></Border>
        <Grid Grid.Row="2" Margin="0,16,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
            <StackPanel Margin="0,0,10,0"><TextBlock Text="SocketJack RTMP host" FontWeight="SemiBold"/><TextBlock x:Name="HostStatusText" Text="Stopped" Foreground="{StaticResource MutedBrush}" Margin="0,5,0,10"/><TextBlock Text="OBS server" Foreground="{StaticResource MutedBrush}"/><TextBox x:Name="RtmpServerBox" IsReadOnly="True" Padding="8" Text="rtmp://127.0.0.1:1935/stream"/><TextBlock Text="Stream key" Foreground="{StaticResource MutedBrush}" Margin="0,10,0,0"/><TextBox x:Name="StreamKeyBox" IsReadOnly="True" Padding="8"/><StackPanel Orientation="Horizontal" Margin="0,10,0,0"><Button x:Name="HostButton" Content="Start RTMP host" Click="HostButton_Click"/><Button Content="Open OBS" Click="OpenObs_Click" Margin="8,0,0,0"/></StackPanel></StackPanel>
            <StackPanel Grid.Column="1" Margin="10,0,0,0"><TextBlock Text="Viewer" FontWeight="SemiBold"/><TextBlock Text="VLC and browser viewers consume SocketJack's FLV relay." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,5,0,10"/><TextBlock Text="VLC URL" Foreground="{StaticResource MutedBrush}"/><TextBox x:Name="VlcUrlBox" IsReadOnly="True" Padding="8" Text="http://127.0.0.1:1935/stream/data"/><StackPanel Orientation="Horizontal" Margin="0,10,0,0"><Button Content="Open VLC" Click="OpenVlc_Click"/><Button x:Name="PreviewButton" Content="Start screen preview" Click="PreviewButton_Click" Margin="8,0,0,0"/></StackPanel><TextBlock Text="For camera streaming, add a Video Capture Device source in OBS. For screen streaming, add Display Capture, then use the server and stream key shown here." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,14,0,0"/></StackPanel>
        </Grid>
        <TextBlock Grid.Row="3" Text="The RTMP host stays local unless you explicitly forward port 1935 or configure the lobby host reverse relay." Foreground="{StaticResource MutedBrush}" Margin="0,14,0,0"/>
    </Grid></Grid>
</Window>
