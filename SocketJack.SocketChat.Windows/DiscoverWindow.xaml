<Window x:Class="SocketJack.SocketChat.Windows.DiscoverWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SocketChat Friends &amp; Servers" Width="780" Height="600" MinWidth="680" MinHeight="500"
        WindowStartupLocation="CenterOwner" Background="{StaticResource WindowBrush}" Foreground="{StaticResource TextBrush}">
    <Grid Background="#C8121A27"><Grid Margin="20"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Friends &amp; servers" FontSize="24" FontWeight="SemiBold"/><TextBlock x:Name="MasterListStatusText" Text="Dropbox masterlist" Foreground="{StaticResource MutedBrush}" Margin="0,5,0,0"/></StackPanel><Button Grid.Column="1" Content="Refresh" Click="Refresh_Click"/></Grid>
        <TextBox x:Name="SearchBox" Grid.Row="1" Margin="0,16,0,12" Padding="10" TextChanged="SearchBox_TextChanged" ToolTip="Search usernames, fingerprints, or server names"/>
        <TabControl Grid.Row="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}">
            <TabItem Header="Find people"><ListBox x:Name="PeopleList" Background="Transparent" BorderThickness="0" Padding="10"><ListBox.ItemTemplate><DataTemplate><Border Background="#C8142633" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,4"><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="{Binding Username}" Foreground="White" FontWeight="SemiBold"/><TextBlock Text="{Binding FingerprintDisplay}" Foreground="{StaticResource MutedBrush}" FontSize="10"/><TextBlock Text="{Binding Presence}" Foreground="{StaticResource AccentBrush}" FontSize="11"/></StackPanel><Button Grid.Column="1" Content="{Binding FriendAction}" Tag="{Binding}" Click="FriendAction_Click"/></Grid></Border></DataTemplate></ListBox.ItemTemplate></ListBox></TabItem>
            <TabItem Header="Friends"><ListBox x:Name="FriendsList" Background="Transparent" BorderThickness="0" Padding="10"><ListBox.ItemTemplate><DataTemplate><Border Background="#C8142633" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,4"><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="{Binding Username}" Foreground="White" FontWeight="SemiBold"/><TextBlock Text="{Binding Presence}" Foreground="{StaticResource MutedBrush}"/></StackPanel><Button Grid.Column="1" Content="Remove" Tag="{Binding}" Click="RemoveFriend_Click"/></Grid></Border></DataTemplate></ListBox.ItemTemplate></ListBox></TabItem>
            <TabItem Header="Requests"><ListBox x:Name="RequestsList" Background="Transparent" BorderThickness="0" Padding="10"><ListBox.ItemTemplate><DataTemplate><Border Background="#C8142633" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,4"><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="{Binding Username}" Foreground="White" FontWeight="SemiBold"/><TextBlock Text="sent you a friend request" Foreground="{StaticResource MutedBrush}"/></StackPanel><Button Grid.Column="1" Content="Accept" Tag="{Binding}" Click="AcceptRequest_Click"/></Grid></Border></DataTemplate></ListBox.ItemTemplate></ListBox></TabItem>
            <TabItem Header="Servers"><ListBox x:Name="ServersList" Background="Transparent" BorderThickness="0" Padding="10"><ListBox.ItemTemplate><DataTemplate><Border Background="#C8142633" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,4"><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="{Binding Name}" Foreground="White" FontWeight="SemiBold"/><TextBlock Text="{Binding Detail}" Foreground="{StaticResource MutedBrush}"/><TextBlock Text="{Binding Presence}" Foreground="{StaticResource AccentBrush}" FontSize="11"/></StackPanel><Button Grid.Column="1" Content="Join" Tag="{Binding}" Click="JoinServer_Click"/></Grid></Border></DataTemplate></ListBox.ItemTemplate></ListBox></TabItem>
        </TabControl>
        <TextBlock Grid.Row="3" Text="Entries are read from and written to the configured Dropbox masterlist.json. Friend identities remain anchored to device fingerprints." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,12,0,0"/>
    </Grid></Grid>
</Window>
