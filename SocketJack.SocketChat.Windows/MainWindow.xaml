<Window x:Class="SocketJack.SocketChat.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SocketChat" Width="1180" Height="760" MinWidth="860" MinHeight="560"
        Background="{StaticResource WindowBrush}" Foreground="{StaticResource TextBrush}"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#A80C1119">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="72"/><ColumnDefinition Width="250"/><ColumnDefinition Width="*"/><ColumnDefinition Width="235"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#D9090D14" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid Margin="10,14"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <Border Width="48" Height="48" CornerRadius="16" Background="{StaticResource AccentBrush}"><TextBlock Text="SC" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                <Button Grid.Row="1" Content="L" Width="48" Height="48" Margin="0,12,0,0" BorderBrush="{StaticResource AccentBrush}" Foreground="{StaticResource AccentBrush}"/>
                <Button Grid.Row="2" Content="Friends" Width="52" Height="42" VerticalAlignment="Top" Margin="0,12,0,0" FontSize="10" Click="FriendsButton_Click"/>
                <Button Grid.Row="3" Content="⚙" Width="48" Height="42" ToolTip="SocketChat settings" Click="SettingsButton_Click"/>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid><Grid.RowDefinitions><RowDefinition Height="68"/><RowDefinition/><RowDefinition Height="70"/></Grid.RowDefinitions>
                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,11">
                    <StackPanel><TextBlock x:Name="LobbyNameText" Text="Local Lobby" FontWeight="SemiBold" FontSize="17"/><TextBlock x:Name="LobbyStatusText" Text="Managed encrypted cache" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,4,0,0"/></StackPanel>
                </Border>
                <ListBox x:Name="ChannelList" Grid.Row="1" Background="Transparent" BorderThickness="0" Padding="10" SelectionChanged="ChannelList_SelectionChanged">
                    <ListBox.ItemTemplate><DataTemplate><Border Padding="10,9" Margin="0,2" CornerRadius="7"><StackPanel Orientation="Horizontal"><TextBlock Text="{Binding Glyph}" Width="24" Foreground="{StaticResource AccentBrush}"/><TextBlock Text="{Binding Name}"/></StackPanel></Border></DataTemplate></ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle><Style TargetType="ListBoxItem"><Setter Property="HorizontalContentAlignment" Value="Stretch"/><Setter Property="Foreground" Value="White"/><Setter Property="Background" Value="Transparent"/><Setter Property="BorderThickness" Value="0"/><Style.Triggers><Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#B8214052"/><Setter Property="Foreground" Value="White"/></Trigger></Style.Triggers></Style></ListBox.ItemContainerStyle>
                </ListBox>
                <Border Grid.Row="2" Background="#D90E151F" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="12">
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="40"/><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <Grid Width="34" Height="34"><Ellipse Fill="{StaticResource AccentBrush}"/><Ellipse><Ellipse.Fill><ImageBrush x:Name="UserAvatarBrush" Stretch="UniformToFill"/></Ellipse.Fill></Ellipse><TextBlock x:Name="UserInitialsText" Text="ME" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Grid>
                        <StackPanel Grid.Column="1" Margin="9,0"><TextBlock x:Name="UsernameText" Text="SocketChat User"/><TextBlock x:Name="FingerprintText" Text="Loading identity..." Foreground="{StaticResource MutedBrush}" FontSize="10" TextTrimming="CharacterEllipsis"/></StackPanel>
                        <Button Grid.Column="2" x:Name="MuteButton" Content="Mute" Click="MuteButton_Click" Padding="8,5"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions><RowDefinition Height="68"/><RowDefinition Height="Auto"/><RowDefinition/><RowDefinition Height="72"/></Grid.RowDefinitions>
            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="20,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel VerticalAlignment="Center" Orientation="Horizontal"><TextBlock x:Name="ChannelTitle" Text="# general" FontSize="16" FontWeight="SemiBold"/><TextBlock x:Name="ChannelDescription" Text="Encrypted managed SocketJack chat" Foreground="{StaticResource MutedBrush}" Margin="12,2,0,0"/></StackPanel><Button Grid.Column="1" Content="Stream" Click="StreamButton_Click" Margin="0,0,12,0" Padding="12,5"/><Border Grid.Column="2" Background="#12302C" BorderBrush="#2C6159" BorderThickness="1" CornerRadius="12" Padding="10,4" VerticalAlignment="Center"><TextBlock Text="LOCAL" Foreground="{StaticResource AccentBrush}" FontSize="11"/></Border></Grid></Border>
            <Border x:Name="VoicePanel" Grid.Row="1" Visibility="Collapsed" Margin="16,12,16,0" Padding="14" CornerRadius="10" Background="#C8172A36" BorderBrush="#8831546B" BorderThickness="1"><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Lobby voice" FontWeight="SemiBold"/><TextBlock x:Name="VoiceStatusText" Text="Microphone disconnected" Foreground="{StaticResource MutedBrush}" Margin="0,3,0,0"/></StackPanel><Button Grid.Column="1" x:Name="JoinVoiceButton" Content="Join voice" Click="JoinVoiceButton_Click" Margin="8,0"/><Button Grid.Column="2" Content="Leave" Background="#CC7F2D40" Click="LeaveVoiceButton_Click"/></Grid></Border>
            <Grid Grid.Row="2">
                <ListBox x:Name="MessageList" Background="Transparent" BorderThickness="0" Padding="18" ScrollViewer.VerticalScrollBarVisibility="Auto" Foreground="{StaticResource TextBrush}">
                    <ListBox.ItemContainerStyle><Style TargetType="ListBoxItem"><Setter Property="HorizontalContentAlignment" Value="Stretch"/><Setter Property="Background" Value="#C8142633"/><Setter Property="Foreground" Value="White"/><Setter Property="BorderBrush" Value="#8843A7CB"/><Setter Property="BorderThickness" Value="1"/><Setter Property="Padding" Value="10"/><Setter Property="Margin" Value="0,4"/></Style></ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate><DataTemplate><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="44"/><ColumnDefinition/></Grid.ColumnDefinitions><Border Width="36" Height="36" CornerRadius="18" Background="#3E7D79" VerticalAlignment="Top"><TextBlock Text="ME" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/></Border><StackPanel Grid.Column="1"><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel Orientation="Horizontal"><TextBlock Text="{Binding Sender}" Foreground="White" FontWeight="SemiBold"/><TextBlock Text="{Binding Time}" Foreground="{StaticResource MutedBrush}" FontSize="10" Margin="9,3,0,0"/><TextBlock Text=" (edited)" Foreground="{StaticResource MutedBrush}" FontSize="10" Margin="4,3,0,0" Visibility="{Binding EditedVisibility}"/></StackPanel><StackPanel Grid.Column="1" Orientation="Horizontal" Visibility="{Binding ManageVisibility}"><Button Content="Edit" Tag="{Binding}" Click="EditMessage_Click" Padding="7,3"/><Button Content="Delete" Tag="{Binding}" Click="DeleteMessage_Click" Padding="7,3" Margin="5,0,0,0" Background="#997F2D40"/></StackPanel></Grid><TextBlock Text="{Binding Text}" Foreground="White" TextWrapping="Wrap" Margin="0,4,0,0"/><Border Background="#B81C2B3B" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="7" Padding="9" Margin="0,8,0,0" Visibility="{Binding AttachmentVisibility}"><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="{Binding AttachmentTitle}" Foreground="White" FontWeight="SemiBold"/><TextBlock Text="{Binding AttachmentDetail}" Foreground="{StaticResource MutedBrush}" FontSize="10" TextTrimming="CharacterEllipsis"/></StackPanel><Button Grid.Column="1" Content="{Binding DownloadLabel}" Tag="{Binding}" Click="DownloadAttachment_Click" Margin="12,0,0,0"/><Button Grid.Column="2" Content="Delete file(s)" Tag="{Binding}" Click="DeleteAttachments_Click" Margin="5,0,0,0" Background="#997F2D40" Visibility="{Binding ManageVisibility}"/></Grid></Border></StackPanel></Grid></DataTemplate></ListBox.ItemTemplate>
                </ListBox>
                <Border x:Name="EmptyPanel" Background="#B8111B29" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="24" Margin="22" VerticalAlignment="Top"><StackPanel><TextBlock x:Name="EmptyTitle" Text="Welcome to SocketChat" FontSize="22" FontWeight="SemiBold"/><TextBlock x:Name="EmptyText" Text="Messages are encrypted in a managed SocketJack database." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,8,0,0"/><Button x:Name="PairingButton" Content="Create pairing code" Click="PairingButton_Click" HorizontalAlignment="Left" Margin="0,16,0,0" Visibility="Collapsed"/><TextBlock x:Name="PairingCodeText" FontSize="28" FontWeight="Bold" FontFamily="Consolas" Margin="0,14,0,0"/></StackPanel></Border>
            </Grid>
            <Border x:Name="ComposerPanel" Grid.Row="3" Margin="18,8,18,16" Background="#D91A2636" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="8"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><Button x:Name="AttachButton" Content="Attach" Click="AttachButton_Click" Margin="0,0,8,0"/><TextBox Grid.Column="1" x:Name="MessageBox" BorderThickness="0" Background="Transparent" Foreground="White" Padding="8" KeyDown="MessageBox_KeyDown"/><Button Grid.Column="2" x:Name="CancelEditButton" Content="Cancel" Click="CancelEditButton_Click" Visibility="Collapsed" Margin="0,0,6,0"/><Button Grid.Column="3" x:Name="SendButton" Content="Send" Background="#CC2C887A" Click="SendButton_Click"/></Grid></Border>
        </Grid>

        <Border Grid.Column="3" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0">
            <StackPanel><Border Height="68" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16"><StackPanel VerticalAlignment="Center"><TextBlock Text="Members — 1" FontWeight="SemiBold" FontSize="16"/><TextBlock Text="Tailscale P2P enabled" Foreground="{StaticResource MutedBrush}" FontSize="11"/></StackPanel></Border><Border Margin="12" Padding="12" Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="9"><StackPanel><TextBlock Text="Tailscale coordinator" FontWeight="SemiBold"/><TextBlock Text="Direct → Peer Relay → DERP" Foreground="{StaticResource MutedBrush}" Margin="0,5,0,0"/><Button Content="Connection details" Margin="0,10,0,0" Click="DropboxButton_Click"/></StackPanel></Border><TextBlock Text="ONLINE" Foreground="{StaticResource MutedBrush}" FontSize="10" Margin="18,18,0,8"/><StackPanel Orientation="Horizontal" Margin="16,5"><Ellipse Width="9" Height="9" Fill="{StaticResource AccentBrush}" VerticalAlignment="Center"/><Grid Width="34" Height="34" Margin="10,0"><Ellipse Fill="#3E7D79"/><Ellipse><Ellipse.Fill><ImageBrush x:Name="MemberAvatarBrush" Stretch="UniformToFill"/></Ellipse.Fill></Ellipse><TextBlock x:Name="MemberInitialsText" Text="ME" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/></Grid><StackPanel><TextBlock x:Name="MemberUsernameText" Text="SocketChat User"/><TextBlock Text="Lobby host" Foreground="{StaticResource MutedBrush}" FontSize="11"/></StackPanel></StackPanel></StackPanel>
        </Border>
    </Grid>
</Window>
