<Window x:Class="SocketJack.SocketChat.Windows.SettingsWindow"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Title="SocketChat Settings" Width="720" Height="720" MinWidth="640" MinHeight="600"
 WindowStartupLocation="CenterOwner" Background="{StaticResource WindowBrush}" Foreground="{StaticResource TextBrush}">
 <Grid Background="#C8121A27" Margin="22"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
  <StackPanel><TextBlock Text="SocketChat settings" FontSize="24" FontWeight="SemiBold"/><TextBlock Text="Profile, voice, controls, and streaming preferences are stored on this device." Foreground="{StaticResource MutedBrush}" Margin="0,6,0,14"/></StackPanel>
  <TabControl Grid.Row="1" Background="#B8121A27" Foreground="White" BorderBrush="{StaticResource BorderBrush}">
   <TabItem Header="Profile"><ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="18">
    <StackPanel Orientation="Horizontal"><Ellipse Width="76" Height="76" Stroke="{StaticResource BorderBrush}" StrokeThickness="2"><Ellipse.Fill><ImageBrush x:Name="AvatarPreviewBrush" Stretch="UniformToFill"/></Ellipse.Fill></Ellipse><StackPanel Margin="16,6"><TextBlock Text="Profile picture" FontWeight="SemiBold"/><StackPanel Orientation="Horizontal" Margin="0,10,0,0"><Button Content="Choose image" Click="ChooseImage_Click"/><Button Content="Remove" Click="RemoveImage_Click" Margin="8,0,0,0"/></StackPanel></StackPanel></StackPanel>
    <TextBlock Text="Username" Margin="0,18,0,6"/><TextBox x:Name="UsernameBox" MaxLength="32" Padding="9"/>
    <TextBlock Text="Device identity" Margin="0,16,0,6"/><TextBox x:Name="FingerprintBox" IsReadOnly="True" Padding="9"/>
    <TextBlock Text="Ban identity" Margin="0,14,0,6"/><TextBox x:Name="BanKeyBox" IsReadOnly="True" Padding="9"/><TextBlock x:Name="NetworkEvidenceText" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" FontSize="11" Margin="0,7,0,0"/>
    <TextBlock Text="Tailscale coordinator URL" Margin="0,16,0,6"/><TextBox x:Name="CoordinatorUrlBox" Padding="9"/><CheckBox x:Name="HostCoordinatorBox" Content="Host discovery, accounts, bans, and lobby metadata on this machine" Margin="0,10,0,0"/>
   </StackPanel></ScrollViewer></TabItem>
   <TabItem Header="Microphone"><ScrollViewer><StackPanel Margin="18">
    <TextBlock Text="Input device" FontWeight="SemiBold"/><ComboBox x:Name="MicrophoneBox" Margin="0,7,0,14" Padding="8" DisplayMemberPath="Name" SelectedValuePath="DeviceNumber"/>
    <TextBlock Text="Input level" FontWeight="SemiBold"/><Grid Margin="0,7,0,15"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="55"/></Grid.ColumnDefinitions><Slider x:Name="MicrophoneLevelSlider" Minimum="0" Maximum="2" TickFrequency="0.05" ValueChanged="MicrophoneLevelSlider_ValueChanged"/><TextBlock Grid.Column="1" x:Name="MicrophoneLevelText" HorizontalAlignment="Right"/></Grid>
    <CheckBox x:Name="VoiceActivationBox" Content="Voice activation" Margin="0,5"/><TextBlock Text="Activation sensitivity" Margin="0,12,0,4"/><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="65"/></Grid.ColumnDefinitions><Slider x:Name="SensitivitySlider" Minimum="-70" Maximum="-10" TickFrequency="1" ValueChanged="SensitivitySlider_ValueChanged"/><TextBlock Grid.Column="1" x:Name="SensitivityText" HorizontalAlignment="Right"/></Grid>
    <Border Background="#B81A2636" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="7" Padding="12" Margin="0,18,0,0"><StackPanel><TextBlock Text="Microphone test" FontWeight="SemiBold"/><ProgressBar x:Name="MicMeter" Height="12" Minimum="-70" Maximum="0" Value="-70" Margin="0,9,0,7"/><TextBlock x:Name="MicTestStatus" Text="Press Test microphone to monitor the selected input." Foreground="{StaticResource MutedBrush}"/><Button x:Name="MicTestButton" Content="Test microphone" Click="MicTestButton_Click" HorizontalAlignment="Left" Margin="0,10,0,0"/></StackPanel></Border>
   </StackPanel></ScrollViewer></TabItem>
   <TabItem Header="Voice filters"><StackPanel Margin="18"><TextBlock Text="Voice processing" FontSize="18" FontWeight="SemiBold"/><TextBlock Text="These filters are applied before encoded audio is sent to peers." Foreground="{StaticResource MutedBrush}" Margin="0,5,0,14"/><CheckBox x:Name="NoiseSuppressionBox" Content="Noise suppression" Margin="0,7"/><CheckBox x:Name="EchoCancellationBox" Content="Echo cancellation" Margin="0,7"/><CheckBox x:Name="AutomaticGainBox" Content="Automatic gain control" Margin="0,7"/><CheckBox x:Name="HighPassBox" Content="High-pass filter (remove rumble)" Margin="0,7"/></StackPanel></TabItem>
   <TabItem Header="Key bindings"><StackPanel Margin="18"><TextBlock Text="Voice controls" FontSize="18" FontWeight="SemiBold"/><CheckBox x:Name="PushToTalkBox" Content="Enable push-to-talk" Margin="0,14,0,8"/><TextBlock Text="Push-to-talk key"/><ComboBox x:Name="PushToTalkKeyBox" Margin="0,6,0,14" Padding="7"/><TextBlock Text="Toggle mute key"/><ComboBox x:Name="MuteKeyBox" Margin="0,6,0,14" Padding="7"/><TextBlock Text="Bindings are active while SocketChat is focused." Foreground="{StaticResource MutedBrush}"/></StackPanel></TabItem>
   <TabItem Header="Streaming"><ScrollViewer><StackPanel Margin="18"><TextBlock Text="Capture and RTMP" FontSize="18" FontWeight="SemiBold"/>
    <TextBlock Text="Capture source" Margin="0,14,0,5"/><ComboBox x:Name="StreamSourceBox" Padding="7"><ComboBoxItem Content="Display"/><ComboBoxItem Content="Camera via OBS"/><ComboBoxItem Content="Window via OBS"/></ComboBox>
    <TextBlock Text="Monitor" Margin="0,13,0,5"/><ComboBox x:Name="MonitorBox" Padding="7"/>
    <Grid Margin="0,13,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions><StackPanel Margin="0,0,8,0"><TextBlock Text="Preview FPS"/><TextBox x:Name="PreviewFpsBox" Padding="8" Margin="0,5,0,0"/></StackPanel><StackPanel Grid.Column="1" Margin="8,0,0,0"><TextBlock Text="Video bitrate (Kbps)"/><TextBox x:Name="BitrateBox" Padding="8" Margin="0,5,0,0"/></StackPanel></Grid>
    <TextBlock Text="RTMP port" Margin="0,13,0,5"/><TextBox x:Name="StreamPortBox" Padding="8"/>
    <TextBlock Text="OBS executable" Margin="0,13,0,5"/><TextBox x:Name="ObsPathBox" Padding="8"/><TextBlock Text="VLC executable" Margin="0,13,0,5"/><TextBox x:Name="VlcPathBox" Padding="8"/>
   </StackPanel></ScrollViewer></TabItem>
  </TabControl>
  <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0"><Button Content="Cancel" Click="Cancel_Click"/><Button Content="Save settings" Background="#3B8F81" Margin="10,0,0,0" Click="Save_Click"/></StackPanel>
 </Grid>
</Window>
